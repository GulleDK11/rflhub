-- #region DependencyService
Services.DependencyService = {
	_links = {},
}

function Services.DependencyService:Link(flagA, flagB, mapFn)
	self._links[flagA] = self._links[flagA] or {}
	table.insert(self._links[flagA], { other = flagB, map = mapFn })
	Services.StateService:OnFlagChanged(flagA, function(v)
		for _, L in ipairs(self._links[flagA]) do
			local nv = L.map and L.map(v) or v
			Services.StateService:SetFlag(L.other, nv)
		end
	end)
end

function Services.DependencyService:RegisterDependency(flagA, flagB, mapFn)
	self:Link(flagA, flagB, mapFn)
end

function Services.DependencyService:Watch(flag, callback)
	Services.StateService:OnFlagChanged(flag, callback)
end

function Services.DependencyService:When(flag, predicate, callback)
	Services.StateService:OnFlagChanged(flag, function(v, old)
		if predicate(v, old) then
			callback(v, old)
		end
	end)
end

function Services.DependencyService:BindElements(sourceFlag, targetFlag, mapper)
	self:Link(sourceFlag, targetFlag, mapper)
end
-- #endregion

-- #region Core internal UI builders
function Core.GetColors(window)
	local C = Utils.DeepCopy(Services.ThemeService.Current)
	if window and window._themeOverride then
		local o = window._themeOverride
		if type(o.Colors) == "table" then
			Utils.DeepMerge(C, o.Colors)
		end
		local groups = Services.ThemeService.TokenGroupKeys
		for k, v in pairs(o) do
			if k ~= "Colors" and k ~= "Tokens" and (not groups or not groups[k]) and typeof(v) == "Color3" then
				C[k] = v
			end
		end
	end
	return C
end

function Core.GetTokens(window)
	local T = Utils.DeepCopy(Services.ThemeService.Tokens)
	if window and window._themeOverride then
		local o = window._themeOverride
		if type(o.Tokens) == "table" then
			Utils.DeepMerge(T, o.Tokens)
		end
		local groups = Services.ThemeService.TokenGroupKeys
		if groups then
			for k, v in pairs(o) do
				if groups[k] and type(v) == "table" then
					T[k] = T[k] or {}
					Utils.DeepMerge(T[k], v)
				end
			end
		end
	end
	return T
end

function Core.AddThemeRef(window, inst, propertyName, themeKey)
	if not inst then
		return
	end
	window._themeRefs = window._themeRefs or {}
	table.insert(window._themeRefs, { inst, propertyName, themeKey })
	local T = Core.GetColors(window)
	if T[themeKey] ~= nil then
		inst[propertyName] = T[themeKey]
	end
end

function Core.ApplyThemeRefs(window)
	local T = Core.GetColors(window)
	for _, r in ipairs(window._themeRefs or {}) do
		local inst, prop, key = r[1], r[2], r[3]
		if inst.Parent and T[key] ~= nil then
			inst[prop] = T[key]
		end
	end
end

