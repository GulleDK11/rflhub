		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = preview })
		Utils.Create("UIStroke", { Color = theme.Border, Parent = preview })

		local sliders = { "R", "G", "B" }
		local vals = { math.floor(col.R * 255), math.floor(col.G * 255), math.floor(col.B * 255) }
		local fills = {}

		local function push()
			local c = Color3.fromRGB(vals[1], vals[2], vals[3])
			preview.BackgroundColor3 = c
			if flag then
				Services.StateService:SetFlag(flag, { vals[1], vals[2], vals[3] })
			end
			if opts.Callback then
				task.spawn(opts.Callback, c)
			end
		end

		for i, label in ipairs(sliders) do
			local sw = Utils.Create("Frame", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 30),
				LayoutOrder = i,
				Parent = wrap,
			})
			Utils.Create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(0, 24, 1, 0),
				Font = Enum.Font.GothamBold,
				TextSize = etok.Control.SecondaryTextSize,
				TextColor3 = theme.TextDim,
				Text = label,
				Parent = sw,
			})
			local track = Utils.Create("Frame", {
				BackgroundColor3 = theme.SurfaceHover,
				Position = UDim2.fromOffset(28, 11),
				Size = UDim2.new(1, -28, 0, thk),
				BorderSizePixel = 0,
				Parent = sw,
			})
			Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = track })
			local fill = Utils.Create("Frame", {
				BackgroundColor3 = theme.Accent,
				Size = UDim2.new(vals[i] / 255, 0, 1, 0),
				BorderSizePixel = 0,
				Parent = track,
			})
			fills[i] = fill
			Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = fill })
			local drag = false
			track.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					drag = true
					local rel = Utils.Clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
					vals[i] = math.floor(rel * 255)
					fill.Size = UDim2.new(rel, 0, 1, 0)
					push()
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					drag = false
				end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if
					drag
					and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch)
				then
					local rel = Utils.Clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
					vals[i] = math.floor(rel * 255)
					fill.Size = UDim2.new(rel, 0, 1, 0)
					push()
				end
			end)
		end

		if flag then
			Services.StateService:OnFlagChanged(flag, function(v)
				if type(v) == "table" and v[1] and v[2] and v[3] then
					vals[1], vals[2], vals[3] = v[1], v[2], v[3]
					for j = 1, 3 do
						if fills[j] then
							fills[j].Size = UDim2.new(vals[j] / 255, 0, 1, 0)
						end
					end
					preview.BackgroundColor3 = Color3.fromRGB(vals[1], vals[2], vals[3])
				end
			end)
		end

		return {
			Get = getColor,
			Set = function(_, c)
				if typeof(c) == "Color3" then
					vals[1] = math.floor(c.R * 255)
					vals[2] = math.floor(c.G * 255)
					vals[3] = math.floor(c.B * 255)
				elseif type(c) == "table" and c[1] then
					vals[1], vals[2], vals[3] = c[1], c[2], c[3]
				end
				for j = 1, 3 do
					if fills[j] then
						fills[j].Size = UDim2.new(vals[j] / 255, 0, 1, 0)
					end
				end
				push()
			end,
		}
	end

