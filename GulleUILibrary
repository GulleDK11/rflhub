	table.insert(window._dragConns, leftDrag.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
		end
	end))
	table.insert(window._dragConns, UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end))
	table.insert(window._dragConns, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end))

	local rsDragging, rsStart, rsSize
	table.insert(window._dragConns, resizeGrip.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			rsDragging = true
			rsStart = input.Position
			rsSize = main.AbsoluteSize
		end
	end))
	table.insert(window._dragConns, UserInputService.InputChanged:Connect(function(input)
		if not rsDragging then
			return
		end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end
		local delta = input.Position - rsStart
		local newW = math.max(minW, math.floor(rsSize.X + delta.X + 0.5))
		local newH = math.max(minH, math.floor(rsSize.Y + delta.Y + 0.5))
		main.Size = UDim2.fromOffset(newW, newH)
	end))
	table.insert(window._dragConns, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if rsDragging then
