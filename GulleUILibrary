	function window:Notify(data)
		Services.NotificationService:Notify(data)
	end

	function window:SetTitle(text)
		title.Text = tostring(text)
	end

	function window:SetSubtitle(text)
		subTitle.Text = tostring(text)
	end

	function window:ModifyTheme(newTheme)
		Services.ThemeService:ModifyTheme(newTheme)
		self:Notify({
			Title = "Theme",
			Message = type(newTheme) == "string" and ("Applied preset: " .. tostring(newTheme)) or "Custom theme applied.",
			Duration = 2.5,
		})
	end

	function window:SetVisible(visible)
		screen.Enabled = visible and true or false
	end

	function window:IsVisible()
		return screen.Enabled
	end

	function window:SaveConfiguration()
		return Services.ConfigService:SaveToPath(self._configFolder, self._configFileName)
	end

	function window:LoadConfiguration()
		return Services.ConfigService:LoadFromPath(self._configFolder, self._configFileName)
	end

	function window:_scheduleAutosave()
		if not self._configEnabled then
			return
		end
		if self._autosaveThread then
			task.cancel(self._autosaveThread)
			self._autosaveThread = nil
		end
		self._autosaveThread = task.delay(0.75, function()
			self._autosaveThread = nil
			if self._destroyed then
				return
			end
			Services.ConfigService:SaveToPath(self._configFolder, self._configFileName)
		end)
	end

	Core.AddThemeRef(window, main, "BackgroundColor3", "Background")
	Core.AddThemeRef(window, mainStroke, "Color", "Border")
	Core.AddThemeRef(window, accent, "BackgroundColor3", "Accent")
	Core.AddThemeRef(window, title, "TextColor3", "Text")
	Core.AddThemeRef(window, subTitle, "TextColor3", "TextDim")
	Core.AddThemeRef(window, sidebar, "BackgroundColor3", "SurfaceMuted")
	Core.AddThemeRef(window, sideStroke, "Color", "Border")
	Core.AddThemeRef(window, tabList, "ScrollBarImageColor3", "Accent")
	Core.AddThemeRef(window, contentShell, "BackgroundColor3", "BackgroundElevated")
	Core.AddThemeRef(window, contentShellStroke, "Color", "Border")
	Core.AddThemeRef(window, loading, "BackgroundColor3", "Background")
	Core.AddThemeRef(window, loadTitle, "TextColor3", "Text")
	Core.AddThemeRef(window, loadSub, "TextColor3", "TextDim")
	Core.AddThemeRef(window, loadBarBg, "BackgroundColor3", "SurfaceHover")
	Core.AddThemeRef(window, loadBarFill, "BackgroundColor3", "Accent")
	window._unsubscribeTheme = Services.ThemeService:RegisterWindowTheme(function()
		Core.ApplyThemeRefs(window)
		for _, hook in ipairs(window._tabThemeHooks) do
			pcall(hook)
		end
	end)

	function window:SetLocked(locked)
		main.Interactable = not locked
		for _, p in ipairs(pages:GetChildren()) do
			if p:IsA("GuiObject") then
				p.Interactable = not locked
			end
		end
	end

	function window:LockUI()
		self:SetLocked(true)
	end

	function window:UnlockUI()
		self:SetLocked(false)
	end

	local dragging, dragStart, startPos
	table.insert(window._dragConns, titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
		end
	end))
	table.insert(window._dragConns, UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end))
	table.insert(window._dragConns, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end))

	if opts.ToggleUIKeybind then
		local kb = opts.ToggleUIKeybind
		if type(kb) == "string" then
			kb = Enum.KeyCode[kb]
		end
		if typeof(kb) == "EnumItem" and kb.EnumType == Enum.KeyCode then
			table.insert(window._dragConns, UserInputService.InputBegan:Connect(function(input, processed)
				if processed then
					return
				end
				if input.KeyCode == kb then
					screen.Enabled = not screen.Enabled
				end
			end))
		end
	end

	function window:Destroy()
		if self._destroyed then
			return
		end
		self._destroyed = true
		if self._unsubscribeTheme then
			self._unsubscribeTheme()
		end
		if self._autosaveThread then
			task.cancel(self._autosaveThread)
		end
		for i, w in ipairs(Services.ConfigService._autoWindows) do
			if w == self then
				table.remove(Services.ConfigService._autoWindows, i)
				break
			end
		end
		for _, c in ipairs(self._dragConns) do
			c:Disconnect()
		end
		screen:Destroy()
	end

	function window:_syncTabStyles()
		local th = Services.ThemeService.Current
		for _, t in ipairs(self._tabs) do
			local isOn = self._activeTab == t
			if isOn then
				t._button.BackgroundColor3 = th.SurfaceHover
				t._button.TextColor3 = th.Text
				t._button.BackgroundTransparency = 0
				t._stroke.Color = th.Accent
				t._stroke.Transparency = 0.35
			else
				t._button.BackgroundColor3 = th.Surface
				t._button.TextColor3 = th.TabInactive
				t._button.BackgroundTransparency = 0.35
				t._stroke.Color = th.Border
				t._stroke.Transparency = 0.85
			end
		end
	end

	function window:CreateTab(name)
		local T = Services.ThemeService.Current
		local btn = Utils.Create("TextButton", {
			Text = name,
			Font = Enum.Font.GothamMedium,
			TextSize = 14,
			TextColor3 = T.TabInactive,
			BackgroundColor3 = T.Surface,
			BackgroundTransparency = 0.35,
			Size = UDim2.new(1, 0, 0, tok.Tab.ItemHeight),
			AutoButtonColor = false,
			Parent = tabList,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, tok.Tab.ItemRadius), Parent = btn })
		local btnStroke = Utils.Create("UIStroke", {
			ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
			Color = T.Border,
			Thickness = 1,
			Transparency = 0.8,
			Parent = btn,
		})

		local page = Utils.Create("ScrollingFrame", {
			Name = name,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromScale(1, 1),
			CanvasSize = UDim2.new(0, 0, 0, 0),
			ScrollBarThickness = tok.Tab.PageScrollBarThickness,
			ScrollBarImageColor3 = T.Accent,
			Visible = false,
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			Parent = pages,
		})
		Utils.Create("UIPadding", {
			PaddingTop = UDim.new(0, 6),
			PaddingBottom = UDim.new(0, 14),
			PaddingLeft = UDim.new(0, 4),
			PaddingRight = UDim.new(0, 6),
			Parent = page,
		})
		local pageList = Utils.Create("UIListLayout", {
			Padding = UDim.new(0, 12),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = page,
		})

		local tabObj = {
			_window = window,
			_button = btn,
			_page = page,
			_layout = pageList,
			_stroke = btnStroke,
		}

		function tabObj:CreateSection(titleText)
			return Elements.CreateSection(self, titleText)
		end

		local function selectTab()
			for _, t in ipairs(window._tabs) do
				t._page.Visible = false
				local th = Services.ThemeService.Current
				Utils.Tween(t._button, TweenInfo.new(0.22, Enum.EasingStyle.Quart), {
					BackgroundTransparency = 0.35,
					TextColor3 = th.TabInactive,
				})
				Utils.Tween(t._stroke, TweenInfo.new(0.22), { Transparency = 0.85, Color = th.Border })
			end
			page.Visible = true
			window._activeTab = tabObj
			local th = Services.ThemeService.Current
			Utils.Tween(btn, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0,
				TextColor3 = th.Text,
			})
			btn.BackgroundColor3 = th.SurfaceHover
			Utils.Tween(btnStroke, TweenInfo.new(0.24), { Transparency = 0.35, Color = th.Accent })
		end

		btn.MouseButton1Click:Connect(selectTab)

		btn.MouseEnter:Connect(function()
			if window._activeTab ~= tabObj then
				Utils.Tween(btn, TweenInfo.new(0.16), { BackgroundTransparency = 0.12 })
			end
		end)
		btn.MouseLeave:Connect(function()
			if window._activeTab ~= tabObj then
				Utils.Tween(btn, TweenInfo.new(0.16), { BackgroundTransparency = 0.35 })
			end
		end)

		table.insert(window._tabs, tabObj)
		if #window._tabs == 1 then
			selectTab()
		end

		return tabObj
	end

	Services.NotificationService:_ensureContainer(screen)

	if configEnabled then
		table.insert(Services.ConfigService._autoWindows, window)
	end

	task.defer(function()
		Utils.Tween(
			loadBarFill,
			TweenInfo.new(tok.Animation.LoadingBarDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Size = UDim2.new(1, 0, 1, 0) }
		)
		task.wait(0.28)
		Utils.Tween(loading, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
		Utils.Tween(loadTitle, TweenInfo.new(0.25), { TextTransparency = 1 })
		Utils.Tween(loadSub, TweenInfo.new(0.25), { TextTransparency = 1 })
		Utils.Tween(loadBarBg, TweenInfo.new(0.25), { BackgroundTransparency = 1 })
		Utils.Tween(loadBarFill, TweenInfo.new(0.25), { BackgroundTransparency = 1 })
		task.wait(0.32)
		loading.Visible = false
	end)

	table.insert(window._tabThemeHooks, function()
		window:_syncTabStyles()
	end)

	return window
end
