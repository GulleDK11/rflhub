-- #region Elements
local _keybindSeq = 0

local function elementApi(root, apiTable)
	apiTable.Remove = function()
		if root and root.Parent then
			root:Destroy()
		end
	end
	return apiTable
end

local function ElemCtx(windowRef)
	if windowRef then
		return Core.GetColors(windowRef), Core.GetTokens(windowRef)
	end
	return Services.ThemeService.Current, Services.ThemeService.Tokens
end

-- Parent must be a GuiObject frame (e.g. section rowsHost). Never parent rows to UIListLayout — they will not show (Rayfield/wind pattern: layout + siblings).
local function createControlRowCard(rowsParent, theme, etok, win)
	local padX = etok.Section.RowPaddingX or 8
	local padY = etok.Section.RowPaddingY or 4
	local card = Utils.Create("Frame", {
		BackgroundColor3 = theme.RowBackground,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = rowsParent,
	})
	Utils.Create("UICorner", { CornerRadius = UDim.new(0, etok.Section.BoxRadius), Parent = card })
	local stroke = Utils.Create("UIStroke", {
		Color = theme.Border,
		Thickness = 1,
		Transparency = etok.Section.RowStrokeTransparency or 0.93,
		Parent = card,
	})
	Utils.Create("UIPadding", {
		PaddingTop = UDim.new(0, padY),
		PaddingBottom = UDim.new(0, padY),
		PaddingLeft = UDim.new(0, padX),
		PaddingRight = UDim.new(0, padX),
		Parent = card,
	})
	if win then
		Core.AddThemeRef(win, card, "BackgroundColor3", "RowBackground")
		Core.AddThemeRef(win, stroke, "Color", "Border")
	end
	return card
end

function Elements.CreateSection(tab, arg1, arg2)
	local win = tab._window
	local theme, etok = ElemCtx(win)
	local titleText, descriptionText, columnKey
	if type(arg1) == "table" then
		titleText = arg1.Name or arg1.Title or arg1[1]
		descriptionText = arg1.Description or arg1[2]
		columnKey = arg1.Column or arg1.Side
	else
		titleText = arg1
		descriptionText = arg2
		columnKey = nil
	end
	titleText = titleText or "Section"

	local useRight = false
	if columnKey ~= nil then
		local ck = string.lower(tostring(columnKey))
		if ck == "right" or ck == "r" or columnKey == 2 then
			useRight = true
		end
	end
	local host = (useRight and tab._contentRight) or tab._contentLeft or tab._content or tab._page
	local wrap = Utils.Create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = host,
	})
	Utils.Create("UIListLayout", {
		Padding = UDim.new(0, etok.Section.TitleSpacing),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = wrap,
	})
	local wrapTail = math.max(0, math.floor(tonumber(etok.Section.WrapPaddingBottom) or 0))
	if wrapTail > 0 then
		Utils.Create("UIPadding", {
			PaddingBottom = UDim.new(0, wrapTail),
			Parent = wrap,
		})
	end

	local lo = 0
	local headerH = math.max(14, math.floor((etok.Section.HeaderTextSize or 12) + 4))
	local header = Utils.Create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamBold,
		TextSize = etok.Section.HeaderTextSize,
		TextColor3 = theme.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, 0, 0, headerH),
		Text = titleText,
		LayoutOrder = lo,
		Parent = wrap,
	})
	lo = lo + 1

	if type(descriptionText) == "string" and descriptionText ~= "" then
		local descLbl = Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Section.DescriptionTextSize,
			TextColor3 = theme.TextDim,
			TextTransparency = 0.15,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true,
			AutomaticSize = Enum.AutomaticSize.Y,
			Size = UDim2.new(1, 0, 0, 0),
			Text = descriptionText,
			LayoutOrder = lo,
			Parent = wrap,
		})
		if win then
			Core.AddThemeRef(win, descLbl, "TextColor3", "TextDim")
		end
		lo = lo + 1
	end

	local rowsHost = Utils.Create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		LayoutOrder = lo,
		Parent = wrap,
	})
	local innerPad = math.max(0, math.floor(tonumber(etok.Section.InnerPadding) or 0))
	if innerPad > 0 then
		Utils.Create("UIPadding", {
			PaddingTop = UDim.new(0, innerPad),
			PaddingBottom = UDim.new(0, innerPad),
			PaddingLeft = UDim.new(0, innerPad),
			PaddingRight = UDim.new(0, innerPad),
			Parent = rowsHost,
		})
	end
	local list = Utils.Create("UIListLayout", {
		Padding = UDim.new(0, etok.Section.RowSpacing),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = rowsHost,
	})
	if win then
		Core.AddThemeRef(win, header, "TextColor3", "TextDim")
	end

	local section = { _box = rowsHost, _list = rowsHost, _tab = tab, _wrap = wrap }

	function section:Remove()
		if wrap.Parent then
			wrap:Destroy()
		end
	end

	function section:CreateToggle(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local flag = opts.Flag
		local def = opts.Default == true
		if flag then
			Services.StateService:SetFlag(flag, Services.StateService:GetFlag(flag) ~= nil and Services.StateService:GetFlag(flag) or def)
		end
		local value = flag and Services.StateService:GetFlag(flag) or def

		local card = createControlRowCard(rowsHost, theme, etok, win)
		local row = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, etok.Control.ToggleRowHeight),
			Parent = card,
		})
		local name = Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1, -54, 1, 0),
			Text = opts.Name or "Toggle",
			Parent = row,
		})

		local switch = Utils.Create("TextButton", {
			BackgroundTransparency = 1,
			Size = UDim2.fromOffset(46, 24),
			Position = UDim2.new(1, -46, 0.5, -12),
			Text = "",
			AutoButtonColor = false,
			Parent = row,
		})
		local track = Utils.Create("Frame", {
			BackgroundColor3 = value and theme.Accent or theme.Surface,
			Size = UDim2.fromScale(1, 1),
			BorderSizePixel = 0,
			Parent = switch,
		})
		local tr = etok.Control.TogglePill and UDim.new(1, 0) or UDim.new(0, etok.Control.DefaultRadius)
		Utils.Create("UICorner", { CornerRadius = tr, Parent = track })
		local knob = Utils.Create("Frame", {
			BackgroundColor3 = Color3.new(1, 1, 1),
			Size = UDim2.fromOffset(18, 18),
			Position = value and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
			BorderSizePixel = 0,
			Parent = track,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })

		local function setState(v, animate)
			value = v
			if flag then
				Services.StateService:SetFlag(flag, v)
			end
			local th = select(1, ElemCtx(win))
			if animate then
				Utils.Tween(track, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					BackgroundColor3 = v and th.Accent or th.Surface,
				})
				Utils.Tween(
					knob,
					TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
					{ Position = v and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9) }
				)
			else
				track.BackgroundColor3 = v and th.Accent or th.Surface
				knob.Position = v and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
			end
			if opts.Callback then
				task.spawn(opts.Callback, v)
			end
		end

		switch.MouseButton1Click:Connect(function()
			setState(not value, true)
		end)

		if flag then
			Services.StateService:OnFlagChanged(flag, function(v)
				if type(v) == "boolean" and v ~= value then
					setState(v, true)
				end
			end)
		end

		return elementApi(card, {
			Set = function(_, v)
				setState(v, true)
			end,
			Get = function()
				return value
			end,
		})
	end

	function section:CreateButton(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local card = createControlRowCard(rowsHost, theme, etok, win)
		local btnStroke
		local btn = Utils.Create("TextButton", {
			BackgroundColor3 = theme.Surface,
			Font = Enum.Font.GothamMedium,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			Text = opts.Name or "Button",
			Size = UDim2.new(1, 0, 0, etok.Control.ButtonHeight),
			AutoButtonColor = false,
			Parent = card,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, etok.Control.DefaultRadius), Parent = btn })
