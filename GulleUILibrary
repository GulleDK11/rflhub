local function ElemCtx(windowRef)
	if windowRef then
		return Core.GetColors(windowRef), Core.GetTokens(windowRef)
	end
	return Services.ThemeService.Current, Services.ThemeService.Tokens
end

function Elements.CreateSection(tab, titleText)
	local win = tab._window
	local theme, etok = ElemCtx(win)
	local wrap = Utils.Create("Frame", {
