-- #region Library
function Library:Init(opts)
	opts = type(opts) == "table" and opts or {}
	if type(opts.AllowedPlaceIds) == "table" then
		Services._allowedPlaceIds = opts.AllowedPlaceIds
	else
		Services._allowedPlaceIds = nil
	end

	local api = {
		Services = Services,
		Theme = Services.ThemeService,
		Config = Services.ConfigService,
		Dependency = Services.DependencyService,
		Window = nil,
	}

	function api.NewWindow(_, opts)
		opts = opts or {}
		if opts.PrintCredits == true then
			print("GulleUI — single-file Roblox UI (flat layout). API: Create* + optional rolibwaita-style New* (see GulleUILibrary.md).")
		end
		local w = Core.CreateWindow({
			Name = opts.Name,
			Subtitle = opts.Subtitle,
			Theme = opts.Theme,
			ToggleUIKeybind = opts.Keybind or opts.ToggleUIKeybind,
			UseCoreGui = opts.UseCoreGui,
			LoadingTitle = opts.LoadingTitle,
			LoadingSubtitle = opts.LoadingSubtitle,
			ConfigurationSaving = opts.ConfigurationSaving,
			DeveloperUserIds = opts.DeveloperUserIds,
			SidebarRank = opts.SidebarRank,
			HideSidebarProfile = opts.HideSidebarProfile,
			Logo = opts.Logo,
			LogoImage = opts.LogoImage,
			LogoPosition = opts.LogoPosition,
			LogoPlacement = opts.LogoPlacement,
			MobileOpenButton = opts.MobileOpenButton,
			MobileOpenButtonImage = opts.MobileOpenButtonImage,
			MobileOpenButtonText = opts.MobileOpenButtonText,
			MobileOpenButtonSize = opts.MobileOpenButtonSize,
			MobileOpenButtonCorner = opts.MobileOpenButtonCorner,
			MobileOpenButtonMargin = opts.MobileOpenButtonMargin,
			MobileOpenButtonDisplayOrder = opts.MobileOpenButtonDisplayOrder,
			MobileOpenButtonTouchOnly = opts.MobileOpenButtonTouchOnly,
		})
		api.Window = w
		return w
	end

	function api.CreateWindow(_, opts)
		opts = opts or {}
		if opts.PrintCredits == true then
			print("GulleUI — single-file Roblox UI. See GulleUILibrary.md for API.")
		end
		local w = Core.CreateWindow(opts)
		api.Window = w
		return w
	end

	--[[
		Run validation before the hub is created. `CreateWindow` is called only when the check passes.
		opts.Validate() → must return true (sync). Or opts.ValidateAsync(function(done) done(ok, err?) end).
		opts.Window = same table as for CreateWindow. opts.Build(Window) = create tabs/sections.
	]]
	function api.OpenAfterValidate(_, opts)
		opts = opts or {}
		local winOpts = type(opts.Window) == "table" and opts.Window or {}
		if not currentPlaceAllowed() then
			placeDeniedToastGui(resolveGuiParent(winOpts))
		end

		local function finishOpen()
			if opts.PrintCredits == true then
				print("GulleUI — OpenAfterValidate → CreateWindow. See GulleUILibrary.md.")
			end
			local w = Core.CreateWindow(winOpts)
			api.Window = w
			if type(opts.Build) == "function" then
				local okBuild, errBuild = pcall(opts.Build, w)
				if not okBuild then
					warn("[GulleUI] OpenAfterValidate Build failed: ", errBuild)
				end
			end
			return w
		end

		if type(opts.ValidateAsync) == "function" then
			task.spawn(function()
				local doneOnce = false
				local function done(ok, err)
					if doneOnce then
						return
					end
					doneOnce = true
					if ok == true then
						task.defer(finishOpen)
					elseif type(opts.OnDenied) == "function" then
						task.defer(opts.OnDenied, err)
					end
				end
				local okCall, errCall = pcall(opts.ValidateAsync, done)
				if not okCall then
					done(false, errCall)
				end
			end)
			return nil
		end

		if type(opts.Validate) == "function" then
			local okCall, res = pcall(opts.Validate)
			if not okCall or res ~= true then
				if type(opts.OnDenied) == "function" then
					opts.OnDenied(okCall and res or res)
				end
				return nil
			end
		end

		return finishOpen()
	end

	--[[
		Separate key UI (own ScreenGui). On success it is destroyed; then CreateWindow + Build — same flow as OpenAfterValidate.
		Validation (first match): KeyValidateAsync(key, done), KeyValidate(key), Validate(key), or whitelist Keys / Key.
		No whitelist and not AllowAny → rejected. KeyTheme = optional { Colors, Tokens } for the key screen only.
	]]
	function api.CreateWindowAfterKey(_, opts)
		opts = opts or {}
		local winOpts = type(opts.Window) == "table" and opts.Window or {}
		local guiParent = resolveGuiParent({ UseCoreGui = winOpts.UseCoreGui })
		if not currentPlaceAllowed() then
			placeDeniedToastGui(guiParent)
		end
		local themeStub = { _themeOverride = type(opts.KeyTheme) == "table" and opts.KeyTheme or nil }
		local C = Core.GetColors(themeStub)
		local tok = Core.GetTokens(themeStub)
		local animTok = tok.Animation or {}
		local keyOpenDur = animTok.KeyGateOpenDuration or animTok.WindowOpenDuration or 0.32
		local keyCloseDur = animTok.KeyGateCloseDuration or (animTok.WindowOpenDuration or 0.32) * 0.85
		local keyPauseBeforeHub = animTok.KeyGatePauseBeforeHub
		if keyPauseBeforeHub == nil then
			keyPauseBeforeHub = 0.1
		end

		local titleText = opts.Title or opts.KeyTitle or "Key required"
		local descText = opts.Description or opts.Subtitle or "Enter your key to continue."
		local placeholder = opts.Placeholder or "Key"
		local wrongDefault = opts.WrongText or "Invalid key."
		local submitLabel = opts.SubmitText or "Continue"
		local closeLabel = opts.CloseText or "Close"
		local showClose = opts.ShowClose ~= false

		local opened = false
		local exiting = false

		local screen = Utils.Create("ScreenGui", {
			Name = "GulleUI_KeyGate",
			ResetOnSpawn = false,
			ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
			DisplayOrder = type(opts.KeyDisplayOrder) == "number" and opts.KeyDisplayOrder or 550,
			Parent = guiParent,
		})
		Services.NotificationService:_ensureContainer(screen)

		local keyFadeRoot = Utils.TryCreateCanvasGroup({
			Name = "GulleKeyFade",
			GroupTransparency = (animTok.KeyGateContentFadeIn == false) and 0 or 1,
			Parent = screen,
		})
		local overlayParent = keyFadeRoot or screen

		local overlay = Utils.Create("Frame", {
			Name = "Overlay",
			BackgroundTransparency = 1,
			Active = true,
			BorderSizePixel = 0,
			Size = UDim2.fromScale(1, 1),
			Parent = overlayParent,
		})

		local card = Utils.Create("Frame", {
			Name = "Card",
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.fromScale(0.5, 0.5),
			Size = UDim2.fromOffset(380, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			BackgroundColor3 = C.Surface,
			BorderSizePixel = 0,
			Parent = overlay,
		})
		local cardStrokeTargetT = 0.5
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, tok.Window.CornerRadius), Parent = card })
		local cardStroke = Utils.Create("UIStroke", {
			Color = C.Border,
			Thickness = 1,
			Transparency = cardStrokeTargetT,
			ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
			Parent = card,
		})

		Utils.Create("UIPadding", {
			PaddingTop = UDim.new(0, 18),
			PaddingBottom = UDim.new(0, 18),
			PaddingLeft = UDim.new(0, 18),
			PaddingRight = UDim.new(0, 18),
			Parent = card,
		})

		local stack = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromScale(1, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = card,
		})
		Utils.Create("UIListLayout", {
			FillDirection = Enum.FillDirection.Vertical,
			Padding = UDim.new(0, 10),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = stack,
		})

		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 22),
			Font = Enum.Font.GothamBold,
			TextSize = 18,
			TextColor3 = C.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Text = titleText,
			Parent = stack,
		})

		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextColor3 = C.TextDim,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true,
			Text = descText,
			Parent = stack,
		})

		local inputWrap = Utils.Create("Frame", {
			BackgroundColor3 = C.SurfaceMuted,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, tok.Control.InputRowHeight),
			Parent = stack,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, tok.Control.DefaultRadius), Parent = inputWrap })
		Utils.Create("UIStroke", { Color = C.Border, Thickness = 1, Transparency = 0.65, Parent = inputWrap })
		Utils.Create("UIPadding", {
			PaddingLeft = UDim.new(0, 10),
			PaddingRight = UDim.new(0, 10),
			Parent = inputWrap,
		})

		local box = Utils.Create("TextBox", {
			BackgroundTransparency = 1,
			Size = UDim2.fromScale(1, 1),
			Font = Enum.Font.Gotham,
			TextSize = 14,
			TextColor3 = C.Text,
			PlaceholderColor3 = C.TextDim,
			PlaceholderText = placeholder,
			ClearTextOnFocus = false,
			Text = "",
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = inputWrap,
		})

		local wrong = Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 0),
			Visible = false,
			AutomaticSize = Enum.AutomaticSize.Y,
			Font = Enum.Font.Gotham,
			TextSize = 12,
			TextColor3 = C.Error,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextWrapped = true,
			Text = wrongDefault,
			Parent = stack,
		})

		local btnRow = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, tok.Control.ButtonHeight),
			Parent = stack,
		})
		Utils.Create("UIListLayout", {
			FillDirection = Enum.FillDirection.Horizontal,
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
			Padding = UDim.new(0, 8),
			Parent = btnRow,
		})

		local function makeTextButton(text, accent)
			local b = Utils.Create("TextButton", {
				AutoButtonColor = false,
				BackgroundColor3 = accent and C.Accent or C.SurfaceHover,
				Size = UDim2.fromOffset(0, tok.Control.ButtonHeight),
				AutomaticSize = Enum.AutomaticSize.X,
				Font = Enum.Font.GothamSemibold,
				TextSize = 13,
				TextColor3 = C.Text,
				Text = text,
				Parent = btnRow,
			})
			Utils.Create("UICorner", { CornerRadius = UDim.new(0, tok.Control.DefaultRadius), Parent = b })
			Utils.Create("UIPadding", { PaddingLeft = UDim.new(0, 16), PaddingRight = UDim.new(0, 16), Parent = b })
			return b
		end

		local closeBtn = showClose and makeTextButton(closeLabel, false) or nil
		local submitBtn = makeTextButton(submitLabel, true)

		local function setBusy(busy)
			submitBtn.Active = not busy
			submitBtn.AutoButtonColor = not busy
			if closeBtn then
				closeBtn.Active = not busy
				closeBtn.AutoButtonColor = not busy
			end
			box.TextEditable = not busy
		end

		local function showWrong(msg)
			wrong.Text = type(msg) == "string" and msg ~= "" and msg or wrongDefault
			wrong.Visible = true
		end

		local function hideWrong()
			wrong.Visible = false
		end

		local function keyCheckSync(trimmed)
			if trimmed == "" then
				return false
			end
			if type(opts.KeyValidate) == "function" then
				local ok, res = pcall(opts.KeyValidate, trimmed)
				return ok and res == true
			end
			if type(opts.Validate) == "function" then
				local ok, res = pcall(opts.Validate, trimmed)
				return ok and res == true
			end
			local hasWhitelist = false
			if type(opts.Keys) == "table" then
				for _ in ipairs(opts.Keys) do
					hasWhitelist = true
					break
				end
			end
			if opts.Key ~= nil then
				hasWhitelist = true
			end
			if not hasWhitelist then
				return opts.AllowAny == true
			end
			local ci = opts.CaseInsensitive ~= false
			local function norm(s)
				if ci then
					return string.lower(tostring(s))
				end
				return tostring(s)
			end
			local allowed = {}
			if type(opts.Keys) == "table" then
				for _, k in ipairs(opts.Keys) do
					allowed[norm(k)] = true
				end
			end
			if opts.Key ~= nil then
				allowed[norm(opts.Key)] = true
			end
			return allowed[norm(trimmed)] == true
		end

		local function finishOpen(usedKey)
			if opts.PrintCredits == true then
				print("GulleUI — CreateWindowAfterKey → CreateWindow. See GulleUILibrary.md.")
			end
			local w = Core.CreateWindow(winOpts)
			if not w then
				warn("[GulleUI] CreateWindowAfterKey: CreateWindow returned nil.")
				return nil
			end
			api.Window = w
			if type(opts.OnSuccess) == "function" then
				pcall(opts.OnSuccess, usedKey)
			end
			if type(opts.Build) == "function" then
				local okBuild, errBuild = pcall(opts.Build, w)
				if not okBuild then
					warn("[GulleUI] CreateWindowAfterKey Build failed: ", errBuild)
				end
			end
			return w
		end

		local function destroyKeyScreen()
			if screen.Parent then
				screen.Enabled = false
				screen:Destroy()
			end
		end

		local function runKeyExitAnimations(afterDone)
			local ti = TweenInfo.new(keyCloseDur, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
			if keyFadeRoot and keyFadeRoot:IsA("CanvasGroup") and animTok.KeyGateContentFadeIn ~= false then
				local tw = Utils.Tween(keyFadeRoot, ti, { GroupTransparency = 1 })
				task.spawn(function()
					tw.Completed:Wait()
					afterDone()
				end)
			else
				if keyFadeRoot and keyFadeRoot:IsA("CanvasGroup") then
					keyFadeRoot.GroupTransparency = 1
				end
				task.defer(afterDone)
			end
		end

		local function proceedValid(trimmed)
			if opened then
				return
			end
			opened = true
			setBusy(true)
			if closeBtn then
				closeBtn.Active = false
			end
			submitBtn.Active = false
			runKeyExitAnimations(function()
				destroyKeyScreen()
				if keyPauseBeforeHub > 0 then
					task.wait(keyPauseBeforeHub)
				end
				finishOpen(trimmed)
			end)
		end

		local function trySubmit()
			if opened then
				return
			end
			hideWrong()
			local trimmed = string.gsub(box.Text or "", "^%s*(.-)%s*$", "%1")
			if trimmed == "" then
				showWrong()
				return
			end
			if type(opts.KeyValidateAsync) == "function" then
				setBusy(true)
				local doneOnce = false
				local function done(ok, errMsg)
					if doneOnce then
						return
					end
					doneOnce = true
					setBusy(false)
					if ok == true then
						proceedValid(trimmed)
					else
						showWrong(type(errMsg) == "string" and errMsg or wrongDefault)
					end
				end
				local okCall, errCall = pcall(opts.KeyValidateAsync, trimmed, done)
				if not okCall then
					done(false, tostring(errCall))
				end
				return
			end
			if keyCheckSync(trimmed) then
				proceedValid(trimmed)
			else
				showWrong()
				if type(opts.OnFail) == "function" then
					pcall(opts.OnFail, trimmed)
				end
			end
		end

		submitBtn.MouseButton1Click:Connect(trySubmit)
		if closeBtn then
			closeBtn.MouseButton1Click:Connect(function()
				if opened or exiting then
					return
				end
				exiting = true
				setBusy(true)
				runKeyExitAnimations(function()
					destroyKeyScreen()
					if type(opts.OnCancel) == "function" then
						pcall(opts.OnCancel)
					elseif type(opts.OnDenied) == "function" then
						pcall(opts.OnDenied, "cancelled")
					end
				end)
			end)
		end

		if opts.SubmitOnEnter ~= false then
			box.FocusLost:Connect(function(enter)
				if enter and not opened then
					trySubmit()
				end
			end)
		end

		task.defer(function()
			if keyFadeRoot and keyFadeRoot:IsA("CanvasGroup") and animTok.KeyGateContentFadeIn ~= false then
				keyFadeRoot.GroupTransparency = 1
				Utils.Tween(
					keyFadeRoot,
					TweenInfo.new(keyOpenDur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
					{ GroupTransparency = 0 }
				)
			elseif keyFadeRoot and keyFadeRoot:IsA("CanvasGroup") then
				keyFadeRoot.GroupTransparency = 0
			end
			Services.NotificationService:Notify({
				Title = "UI loaded",
				Message = "Enter your key to continue.",
				Duration = 3.5,
				Type = "info",
			})
		end)

		return {
			Destroy = function()
				if not screen.Parent or opened or exiting then
					return
				end
				exiting = true
				setBusy(true)
				runKeyExitAnimations(function()
					destroyKeyScreen()
				end)
			end,
			Screen = screen,
		}
	end

	api.BlockyTheme = Library.BlockyTheme

