-- #region Library
function Library:Init()
	local api = {
		Services = Services,
		Theme = Services.ThemeService,
		Config = Services.ConfigService,
		Dependency = Services.DependencyService,
		Window = nil,
	}

	function api.NewWindow(_, opts)
		opts = opts or {}
		if opts.PrintCredits == true then
			print("GulleUI — single-file Roblox UI (flat layout). API: Create* + optional rolibwaita-style New* (see GulleUILibrary.md).")
		end
		local w = Core.CreateWindow({
			Name = opts.Name,
			Subtitle = opts.Subtitle,
			Theme = opts.Theme,
			ToggleUIKeybind = opts.Keybind or opts.ToggleUIKeybind,
			UseCoreGui = opts.UseCoreGui,
			LoadingTitle = opts.LoadingTitle,
			LoadingSubtitle = opts.LoadingSubtitle,
			ConfigurationSaving = opts.ConfigurationSaving,
			DeveloperUserIds = opts.DeveloperUserIds,
			SidebarRank = opts.SidebarRank,
			HideSidebarProfile = opts.HideSidebarProfile,
		})
		api.Window = w
		return w
	end

	function api.CreateWindow(_, opts)
		opts = opts or {}
		if opts.PrintCredits == true then
			print("GulleUI — single-file Roblox UI. See GulleUILibrary.md for API.")
		end
		local w = Core.CreateWindow(opts)
		api.Window = w
		return w
	end

	api.BlockyTheme = Library.BlockyTheme

	function api.Notify(_, data)
		Services.NotificationService:Notify(data)
	end

	function api.ModifyTheme(_, partial)
		Services.ThemeService:ModifyTheme(partial)
	end

	function api.LoadConfiguration(_)
		return api.Window and api.Window:LoadConfiguration() or false
	end

	function api.SaveConfiguration(_)
		return api.Window and api.Window:SaveConfiguration() or false
	end

	function api.SetFlag(_, f, v)
		Services.StateService:SetFlag(f, v)
	end

	function api.GetFlag(_, f)
		return Services.StateService:GetFlag(f)
	end

	return api
end

