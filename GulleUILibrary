function Services.ThemeService:_applyPresetTable(preset)
	if not preset then
		return
	end
	self.Current = Utils.DeepCopy(self._defaultColors)
	self.Tokens = Utils.DeepCopy(self._defaultTokens)
	if type(preset.Colors) == "table" then
		Utils.DeepMerge(self.Current, preset.Colors)
	end
	if type(preset.Tokens) == "table" then
		Utils.DeepMerge(self.Tokens, preset.Tokens)
	end
	for k, v in pairs(preset) do
		if k ~= "Colors" and k ~= "Tokens" and typeof(v) == "Color3" then
			self.Current[k] = v
		end
		if _tokenGroupKeys[k] and type(v) == "table" then
			self.Tokens[k] = self.Tokens[k] or {}
			Utils.DeepMerge(self.Tokens[k], v)
		end
	end
end

function Services.ThemeService:_mergeThemeTable(partial)
	if type(partial) ~= "table" then
		return
	end
	if type(partial.Colors) == "table" then
		Utils.DeepMerge(self.Current, partial.Colors)
	end
	if type(partial.Tokens) == "table" then
		Utils.DeepMerge(self.Tokens, partial.Tokens)
	end
	for k, v in pairs(partial) do
		if _isThemeMetaKey(k) then
			-- skip
		elseif k == "Colors" or k == "Tokens" then
			-- handled
		elseif _tokenGroupKeys[k] and type(v) == "table" then
			self.Tokens[k] = self.Tokens[k] or {}
			Utils.DeepMerge(self.Tokens[k], v)
		elseif typeof(v) == "Color3" then
			self.Current[k] = v
		elseif type(v) ~= "table" then
			self.Current[k] = v
		end
	end
end

function Services.ThemeService:ModifyTheme(partial)
	if type(partial) == "string" then
		local preset = self.Presets[partial]
		self:_applyPresetTable(preset or self.Presets.Default)
	elseif type(partial) == "table" then
		self:_mergeThemeTable(partial)
	end
	for _, fn in ipairs(self._windowCallbacks) do
		pcall(fn)
	end
	if self._apply then
		pcall(self._apply)
	end
end

function Services.ThemeService:GetColors()
	return Utils.DeepCopy(self.Current)
end

function Services.ThemeService:GetTokens()
	return Utils.DeepCopy(self.Tokens)
end

function Services.ThemeService:RegisterWindowTheme(fn)
	table.insert(self._windowCallbacks, fn)
	return function()
		for i, f in ipairs(self._windowCallbacks) do
			if f == fn then
				table.remove(self._windowCallbacks, i)
				break
			end
		end
	end
end

function Services.ThemeService:RegisterApply(fn)
	self._apply = fn
end
