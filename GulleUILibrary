-- #region Utils
function Utils.Clamp(n, min, max)
	return math.max(min, math.min(max, n))
end

function Utils.DeepCopy(t)
	if type(t) ~= "table" then
		return t
	end
	local c = {}
	for k, v in pairs(t) do
		c[k] = Utils.DeepCopy(v)
	end
	return c
end

local function _isThemeMetaKey(k)
	return k == "ApplyGlobally" or k == "Globally" or k == "Colors" or k == "Tokens"
end

function Utils.DeepMerge(target, source)
	if type(target) ~= "table" or type(source) ~= "table" then
		return target
	end
	for k, v in pairs(source) do
		if not _isThemeMetaKey(k) then
		if typeof(v) == "Color3" or typeof(v) == "EnumItem" or typeof(v) == "UDim" or typeof(v) == "UDim2" then
			target[k] = v
		elseif type(v) == "table" and type(target[k]) == "table" and not (v[1] and type(v[1]) == "number" and v[2] and type(v[2]) == "number" and v[3]) then
			Utils.DeepMerge(target[k], v)
		else
			target[k] = v
		end
		end
	end
	return target
end

function Utils.Create(class, props, children)
	local inst = Instance.new(class)
	for k, v in pairs(props or {}) do
		if k ~= "Children" then
			if type(k) == "string" and k:sub(1, 1) == "_" then
				-- skip internal
			else
				inst[k] = v
			end
		end
	end
	for _, ch in ipairs(children or props and props.Children or {}) do
		ch.Parent = inst
	end
	return inst
end

function Utils.Tween(inst, ti, props)
	local t = TweenService:Create(inst, ti, props)
	t:Play()
	return t
end

-- CanvasGroup enables GroupTransparency fade on the whole subtree (Roblox 2022+). Returns nil if unavailable.
function Utils.TryCreateCanvasGroup(props)
	local ok, cg = pcall(Instance.new, "CanvasGroup")
	if not ok or cg == nil then
		return nil
	end
	props = props or {}
	cg.Name = props.Name or "GulleCanvasFade"
	cg.BackgroundTransparency = 1
	cg.BorderSizePixel = 0
	cg.Size = props.Size or UDim2.fromScale(1, 1)
	cg.Position = props.Position or UDim2.fromScale(0, 0)
	cg.AnchorPoint = props.AnchorPoint or Vector2.new(0, 0)
	cg.GroupTransparency = props.GroupTransparency ~= nil and props.GroupTransparency or 1
	cg.Parent = props.Parent
	return cg
end

-- Ripple is drawn in a ScreenGui overlay so tweened Size does not affect AutomaticSize on row cards.
function Utils.Ripple(button, color, duration, screenPos)
	if not button or not button:IsDescendantOf(game) then
		return
	end
	duration = duration or 0.35
	local sg = button:FindFirstAncestorWhichIsA("ScreenGui")
	if not sg then
		return
	end
	local absPos = button.AbsolutePosition
	local absSize = button.AbsoluteSize
	local maxDim = math.max(absSize.X, absSize.Y, 1)
	local center
	if typeof(screenPos) == "Vector2" then
		center = screenPos
	else
		center = Vector2.new(absPos.X + absSize.X * 0.5, absPos.Y + absSize.Y * 0.5)
	end

	local layer = sg:FindFirstChild("_GulleRippleLayer")
	if not layer then
		-- 0×0: takes no space in layout; circles still draw (ClipsDescendants off) so they don't push the hub UI.
		layer = Utils.Create("Frame", {
			Name = "_GulleRippleLayer",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromOffset(0, 0),
			Position = UDim2.fromScale(0, 0),
			ZIndex = 9999,
			Active = false,
			Selectable = false,
			ClipsDescendants = false,
			Parent = sg,
		})
	end

	local circle = Utils.Create("Frame", {
		Name = "Ripple",
		BackgroundColor3 = color,
		BackgroundTransparency = 0.6,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(0, 0),
		Position = UDim2.fromOffset(center.X, center.Y),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ZIndex = 1,
		Parent = layer,
	})
	Utils.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = circle })
	local rippleSide = math.max(4, math.floor(maxDim * 0.52 + 0.5))
	Utils.Tween(circle, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(rippleSide, rippleSide),
		BackgroundTransparency = 1,
	})
	task.delay(duration, function()
		if circle and circle.Parent then
			circle:Destroy()
		end
	end)
end
