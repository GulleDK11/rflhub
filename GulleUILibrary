}

function Services.NotificationService:_ensureContainer(parent)
	if self._container and self._container.Parent then
		if self._stack and self._stack.Parent then
			return
		end
	else
		self._container = Utils.Create("Frame", {
			Name = "Notifications",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromScale(1, 1),
			Position = UDim2.fromScale(0, 0),
			ZIndex = 200,
			Active = false,
			Selectable = false,
			ClipsDescendants = false,
			Parent = parent,
		})
	end
	if not self._stack or not self._stack.Parent then
		local tw = (Services.ThemeService.Tokens.Notification or {}).Width or 320
		self._stack = Utils.Create("Frame", {
			Name = "ToastStack",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			AnchorPoint = Vector2.new(1, 1),
			Position = UDim2.new(1, -20, 1, -20),
			Size = UDim2.new(0, tw + 24, 1, -40),
			Parent = self._container,
		})
		Utils.Create("UIListLayout", {
			FillDirection = Enum.FillDirection.Vertical,
			Padding = UDim.new(0, 10),
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
			VerticalAlignment = Enum.VerticalAlignment.Bottom,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = self._stack,
		})
	end
end

function Services.NotificationService:_spawnToast(item)
	local theme = Services.ThemeService.Current
	local nt = Services.ThemeService.Tokens.Notification
	local slidePx = 44
	self._toastOrder = self._toastOrder + 1
	if self._stack then
		self._stack.Size = UDim2.new(0, nt.Width + 24, 1, -40)
	end
	local padY = nt.PaddingY or 10
	local padX = nt.PaddingX or 12
	local card = Utils.Create("Frame", {
		Name = "ToastCard",
		BackgroundColor3 = theme.Surface,
		BackgroundTransparency = 0,
		BorderSizePixel = 1,
		BorderColor3 = theme.Border,
		Size = UDim2.new(0, nt.Width, 0, 48),
		AutomaticSize = Enum.AutomaticSize.None,
		LayoutOrder = self._toastOrder,
		ClipsDescendants = true,
		Parent = self._stack or self._container,
	})
	Utils.Create("UICorner", { CornerRadius = UDim.new(0, nt.CornerRadius), Parent = card })
	local mover = Utils.Create("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 1, 0),
		Position = UDim2.new(0, slidePx, 0, 0),
		ClipsDescendants = true,
		Parent = card,
	})
	local pad = Utils.Create("UIPadding", {
		PaddingTop = UDim.new(0, padY),
		PaddingBottom = UDim.new(0, padY),
		PaddingLeft = UDim.new(0, padX),
		PaddingRight = UDim.new(0, padX),
		Parent = mover,
	})
	local inner = Utils.Create("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = mover,
	})
	local innerList = Utils.Create("UIListLayout", {
		FillDirection = Enum.FillDirection.Vertical,
		Padding = UDim.new(0, 6),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = inner,
	})
	local function refreshCardHeight()
		local colH = innerList.AbsoluteContentSize.Y
		local h = padY * 2 + colH
		card.Size = UDim2.new(0, nt.Width, 0, math.max(32, math.ceil(h)))
	end
	innerList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshCardHeight)
	local title = Utils.Create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamBold,
		TextSize = nt.TitleSize,
		TextColor3 = theme.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
		Text = item.Title or "Notice",
		LayoutOrder = 0,
		Parent = inner,
	})
	local body = Utils.Create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.Gotham,
		TextSize = nt.BodySize,
		TextColor3 = theme.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
		Text = item.Message or item.Content or "",
		LayoutOrder = 1,
		Parent = inner,
	})
	card.BackgroundTransparency = 1
	title.TextTransparency = 1
	body.TextTransparency = 1
	Utils.Tween(mover, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 0),
	})
	Utils.Tween(card, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0,
	})
	Utils.Tween(title, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { TextTransparency = 0 })
	Utils.Tween(body, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { TextTransparency = 0 })
	task.defer(refreshCardHeight)
	task.delay(item.Duration or 3.5, function()
		if not card.Parent then
			return
		end
		Utils.Tween(mover, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
			Position = UDim2.new(0, slidePx, 0, 0),
		})
		Utils.Tween(card, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
			BackgroundTransparency = 1,
		})
		Utils.Tween(title, TweenInfo.new(0.3), { TextTransparency = 1 })
		Utils.Tween(body, TweenInfo.new(0.3), { TextTransparency = 1 })
		task.delay(0.32, function()
			if card.Parent then
				card:Destroy()
			end
		end)
	end)
end

function Services.NotificationService:Notify(data)
	data = type(data) == "table" and data or { Title = "Notice", Message = tostring(data) }
	if not self._container or not self._container.Parent then
		return
	end
	self:_spawnToast(data)
end
