-- #region Core internal UI builders
function Core.GetColors(window)
	local C = Utils.DeepCopy(Services.ThemeService.Current)
	if window and window._themeOverride then
		local o = window._themeOverride
		if type(o.Colors) == "table" then
			Utils.DeepMerge(C, o.Colors)
		end
		local groups = Services.ThemeService.TokenGroupKeys
		for k, v in pairs(o) do
			if k ~= "Colors" and k ~= "Tokens" and (not groups or not groups[k]) and typeof(v) == "Color3" then
				C[k] = v
			end
		end
	end
	return C
end

function Core.GetTokens(window)
	local T = Utils.DeepCopy(Services.ThemeService.Tokens)
	if window and window._themeOverride then
		local o = window._themeOverride
		if type(o.Tokens) == "table" then
			Utils.DeepMerge(T, o.Tokens)
		end
		local groups = Services.ThemeService.TokenGroupKeys
		if groups then
			for k, v in pairs(o) do
				if groups[k] and type(v) == "table" then
					T[k] = T[k] or {}
					Utils.DeepMerge(T[k], v)
				end
			end
		end
	end
	return T
end

function Core.AddThemeRef(window, inst, propertyName, themeKey)
	if not inst then
		return
	end
	window._themeRefs = window._themeRefs or {}
	table.insert(window._themeRefs, { inst, propertyName, themeKey })
	local T = Core.GetColors(window)
	if T[themeKey] ~= nil then
		inst[propertyName] = T[themeKey]
	end
end

function Core.ApplyThemeRefs(window)
	local T = Core.GetColors(window)
	for _, r in ipairs(window._themeRefs or {}) do
		local inst, prop, key = r[1], r[2], r[3]
		if inst.Parent and T[key] ~= nil then
			inst[prop] = T[key]
		end
	end
end

function Core.CreateWindow(opts)
	opts = opts or {}
	local displayName = opts.Name or opts.Title or "GulleUI"
	local subtitle = opts.Subtitle or "Clean interface"
	local loadingTitle = opts.LoadingTitle or displayName
	local loadingSub = opts.LoadingSubtitle or subtitle

	local configSaving = opts.ConfigurationSaving or {}
	local configEnabled = configSaving.Enabled == true
	local configFolder = configSaving.FolderName or "GulleUI"
	local configFileName = configSaving.FileName or tostring(game.PlaceId)

	if configEnabled then
		Services.ConfigService:LoadFromPath(configFolder, configFileName)
	end

	local windowThemeOverride = nil
	if type(opts.Theme) == "string" then
		Services.ThemeService:ModifyTheme(opts.Theme)
	elseif type(opts.Theme) == "table" then
		if opts.Theme.ApplyGlobally or opts.Theme.Globally then
			Services.ThemeService:ModifyTheme(opts.Theme)
		else
			windowThemeOverride = opts.Theme
		end
	end

	local themeStub = { _themeOverride = windowThemeOverride }
	local colors = Core.GetColors(themeStub)
	local tok = Core.GetTokens(themeStub)

	local screen = Utils.Create("ScreenGui", {
		Name = displayName:gsub("%s+", "") .. "_GulleUI",
