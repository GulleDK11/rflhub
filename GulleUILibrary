--[[
	GulleUI — eksempelhub (alle kontroller + key-flow).

	Entry: UI:CreateWindowAfterKey — indbygget key-ScreenGui; gyldig nøgle her: demo
	Alternativ uden key-UI: UI:OpenAfterValidate({ Validate = function() return true end, Window = ..., Build = ... })

	Lokal fil: kommenter HttpGet ud og brug readfile (executor).
]]

-- local Library = loadstring(readfile("GulleUILibrary.lua"))()
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/GulleDK11/rflhub/refs/heads/main/GulleUILibrary"))()

-- Valgfrit: kun disse PlaceIds må åbne UI (hub/key). Udeladt = intet tjek.
-- local UI = Library:Init({ AllowedPlaceIds = { 1234567890, game.PlaceId } })
local UI = Library:Init()

UI:CreateWindowAfterKey({
	Keys = { "demo" },
	-- Async i stedet for Keys (kun én af dem bruges på submit):
	-- KeyValidateAsync = function(key, done)
	-- 	task.defer(function()
	-- 		done(tostring(key) == "demo")
	-- 	end)
	-- end,
	Title = "Gulle Test",
	Description = "Brug nøglen demo for at åbne hubben.",
	OnSuccess = function(key)
		print("[GulleUI example] Key OK:", key)
	end,
	OnCancel = function()
		warn("[GulleUI] Key lukket.")
	end,
	Window = {
		Name = "Gulle Test Hub",
		Subtitle = "",
		LoadingTitle = "Gulle Test Hub",
		LoadingSubtitle = "Loader…",
		ToggleUIKeybind = Enum.KeyCode.RightShift,
		ConfigurationSaving = {
			Enabled = true,
			FolderName = "",
			FileName = tostring(game.PlaceId),
		},
		Theme = Library.NeonTheme,
	},
	Build = function(Window)
-- Faner
local TabMain = Window:CreateTab("Main")
local TabVisuals = Window:CreateTab({ Name = "Visuals", Icon = "rbxassetid://7734051451" })
local TabConfig = Window:CreateTab("Config")

-- === Main: 2 kolonner × 2 sektioner (CreateSectionBundle) + divider i én sektion ===
local MainGrid = TabMain:CreateSectionBundle({
	Left = {
		{ Name = "Core", Description = "Label, toggle, knap — divider adskiller rækker i samme sektion." },
		{ Name = "Bevægelse", Description = "Slider og dropdown i egen sektion under Core." },
	},
	Right = {
		{ Name = "Input", Description = "Tekstfelter i egen boks." },
		{ Name = "Style & info", Description = "Farve, keybind og paragraph." },
	},
})
local SecCore = MainGrid.Left[1]
local SecMove = MainGrid.Left[2]
local SecIn = MainGrid.Right[1]
local SecStyle = MainGrid.Right[2]

SecCore:CreateLabel({ Text = "Labels bruges til korte overskrifter i sektionen." })

SecCore:CreateToggle({
	Name = "God Mode",
	Default = false,
	Flag = "god_mode",
	Callback = function(v)
		print("[Toggle] God Mode:", v)
	end,
})

SecCore:CreateDivider({})

SecCore:CreateButton({
	Name = "Ping (Notify)",
	Callback = function()
		Window:Notify({ Title = "Knap", Content = "Notify virker.", Duration = 3 })
	end,
})

SecMove:CreateSlider({
	Name = "Walk speed",
	Min = 16,
	Max = 100,
	Default = 16,
	Flag = "walk_speed",
	Increment = 1,
	Callback = function(v)
		print("[Slider]", v)
	end,
})

SecMove:CreateDropdown({
	Name = "Mode",
	Options = { "Legit", "Rage", "Safe" },
	Default = "Legit",
	Flag = "mode_dd",
	Callback = function(v)
		print("[Dropdown]", v)
	end,
})

SecIn:CreateInput({
	Name = "Config navn",
	Default = "min_config",
	Placeholder = "Skriv her…",
	Flag = "cfg_name",
	Callback = function(t)
		print("[Input]", t)
	end,
})

SecIn:CreateInput({
	Name = "Live tekst",
	Placeholder = "TextChanged",
	Flag = "live_txt",
	Trigger = "TextChanged",
	Callback = function(t)
		print("[Input TC]", t)
	end,
})

SecStyle:CreateColorPicker({
	Name = "Accent test",
	Default = Color3.fromRGB(59, 130, 246),
	Flag = "pick_col",
	Callback = function(c)
		print("[Color]", c)
	end,
})

SecStyle:CreateKeybind({
	Name = "Panic key",
	Default = Enum.KeyCode.P,
	Flag = "panic_kb",
	Callback = function(k)
		print("[Keybind]", k)
	end,
})

SecStyle:CreateParagraph({
	Content = "Paragraph: længere beskrivelse. Fire sektioner (2 venstre, 2 højre) — stadig CreateDivider inde i en sektion når du vil dele rækker.",
})

-- === Visuals: rolibwaita-style New* (split kolonner) ===
local SecVis = TabVisuals:CreateSection({ Name = "Visuals", Description = "Venstre: New* aliaser." })

SecVis:NewToggle({
	Name = "ESP",
	CurrentState = false,
	Flag = "esp_on",
	Callback = function(v)
		print("[NewToggle] ESP", v)
	end,
})

SecVis:NewSlider({
	Name = "ESP Distance",
	MinMax = { "50", "500" },
	Increment = 10,
	CurrentValue = 100,
	Flag = "esp_dist",
	Callback = function(v)
		print("[NewSlider]", v)
	end,
})

SecVis:NewDropdown({
	Name = "Box type",
	Choices = { "Corner", "Full", "None" },
	CurrentState = "Corner",
	Flag = "esp_box",
	Callback = function(v)
		print("[NewDropdown]", v)
	end,
})

local SecVisRight = TabVisuals:NewSection({
	Name = "Actions",
	Description = "Højre kolonne.",
	Column = "Right",
})

SecVisRight:NewTextBox({
	Name = "Filter",
	PlaceholderText = "Spillernavn…",
	Text = "",
	Trigger = "FocusLost",
	Callback = function(t)
		print("[NewTextBox]", t)
	end,
})

SecVisRight:NewButton({
	Name = "Test notify",
	Callback = function()
		Window:Notify({ Title = "Visuals", Message = "NewButton OK", Duration = 2 })
	end,
})

-- === Config ===
local SecCfg = TabConfig:CreateSection({ Name = "Configuration", Description = "Venstre: save/load." })

SecCfg:CreateButton({
	Name = "Save (til executor-mappe)",
	Callback = function()
		local ok = Window:SaveConfiguration()
		Window:Notify({
			Title = "Config",
			Message = ok and "Gemt som " .. tostring(game.PlaceId) .. ".json i executor-mappen." or "Kunne ikke gemme (writefile?).",
			Duration = 3,
		})
	end,
})

SecCfg:CreateButton({
	Name = "Load (fra executor-mappe)",
	Callback = function()
		local ok = Window:LoadConfiguration()
		Window:Notify({
			Title = "Config",
			Message = ok and "Indlæst fra executor-mappen." or "Ingen fil eller readfile fejlede.",
			Duration = 3,
		})
	end,
})

SecCfg:CreateButton({
	Name = "Kill script (luk UI)",
	Callback = function()
		pcall(function()
			Window:Destroy()
		end)
		pcall(function()
			local s = script
			if s and s.Destroy then
				s:Destroy()
			end
		end)
	end,
})

local SecCfgRight = TabConfig:CreateSection({ Name = "Demo", Column = "Right" })

SecCfgRight:CreateToggle({
	Name = "Demo flag (SetFlag)",
	Default = false,
	Flag = "demo_lib_flag",
	Callback = function(v)
		UI:SetFlag("demo_lib_flag", v)
		print("GetFlag:", UI:GetFlag("demo_lib_flag"))
	end,
})

print("GulleUI example hub åbnet — RightShift toggler UI. Sidebund: @", game.Players.LocalPlayer.Name)
	end,
})
