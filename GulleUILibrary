	function section:CreateDivider(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local mx = opts.MarginX or 0
		local thick = opts.Thickness or 1
		local trans = opts.Transparency
		if trans == nil then
			trans = 0.45
		end
		local marginY = opts.MarginY
		if marginY == nil then
			marginY = etok.Section.DividerMarginY
		end
		if marginY == nil then
			marginY = 10
		end
		marginY = math.max(0, math.floor(tonumber(marginY) or 0))

		local wrap = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = rowsHost,
		})
		if marginY > 0 then
			Utils.Create("UIPadding", {
				PaddingTop = UDim.new(0, marginY),
				PaddingBottom = UDim.new(0, marginY),
				Parent = wrap,
			})
		end
		local line = Utils.Create("Frame", {
			BackgroundColor3 = theme.Border,
			BackgroundTransparency = trans,
			BorderSizePixel = 0,
			Size = UDim2.new(1, -mx * 2, 0, thick),
			Position = UDim2.new(0, mx, 0, 0),
			Parent = wrap,
		})
		if win then
			Core.AddThemeRef(win, line, "BackgroundColor3", "Border")
		end
		return elementApi(wrap, {})
	end

