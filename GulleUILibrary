	function window:Destroy()
		if self._destroyed then
			return
		end
		self._destroyed = true
		self:_closeGulleDropdown()
		if self._unsubscribeTheme then
			self._unsubscribeTheme()
		end
		if self._autosaveThread then
			task.cancel(self._autosaveThread)
		end
		for i, w in ipairs(Services.ConfigService._autoWindows) do
			if w == self then
				table.remove(Services.ConfigService._autoWindows, i)
				break
			end
		end
		for _, c in ipairs(self._dragConns) do
			if type(c) == "function" then
				c()
			elseif c and c.Disconnect then
				c:Disconnect()
			end
		end
		local scr = self._screen
		local fadeRoot = self._windowFadeRoot
		local tt = Core.GetTokens({ _themeOverride = self._themeOverride })
		local anim = tt.Animation or {}
		local closeFadeDur = anim.WindowCloseFadeDuration or 0.28
		local function finishScreenDestroy()
			if self._acrylicModel and self._acrylicModel.Parent then
				self._acrylicModel.Transparency = 1
				self._acrylicModel:Destroy()
			end
			self._acrylicModel = nil
			if self._acrylicFolder and self._acrylicFolder.Parent then
				self._acrylicFolder:Destroy()
			end
			self._acrylicFolder = nil
			local fab = self._mobileFabGui
			if fab and fab.Parent then
				fab:Destroy()
			end
			self._mobileFabGui = nil
			if scr and scr.Parent then
				scr:Destroy()
			end
		end
		if
			fadeRoot
			and fadeRoot.Parent
			and fadeRoot:IsA("CanvasGroup")
			and anim.WindowContentFadeOut ~= false
		then
			Utils.Tween(
				fadeRoot,
				TweenInfo.new(closeFadeDur, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{ GroupTransparency = 1 }
			)
			task.delay(closeFadeDur, finishScreenDestroy)
		else
			finishScreenDestroy()
		end
	end

