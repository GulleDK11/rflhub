				})
			end

			local function fabViewport()
				local cam = workspace.CurrentCamera
				local vp = (cam and cam.ViewportSize) or Vector2.new(800, 600)
				local topInset = 0
				pcall(function()
					topInset = GuiService:GetGuiInset().Y
				end)
				return vp, topInset
			end
			local function placeFabTopCenter()
				if window._destroyed or not holder.Parent then
					return
				end
				local vp, topInset = fabViewport()
				local w = math.max(holder.AbsoluteSize.X, mobSize)
				local h = math.max(holder.AbsoluteSize.Y, mobSize)
				local minX, minY = margin, topInset + margin
				local maxX = math.max(minX, vp.X - margin - w)
				local maxY = math.max(minY, vp.Y - margin - h)
				local x = math.clamp((vp.X - w) / 2, minX, maxX)
				local y = math.clamp(topInset + margin, minY, maxY)
				holder.AnchorPoint = Vector2.new(0, 0)
				holder.Position = UDim2.fromOffset(x, y)
			end

			hit.Activated:Connect(function()
				if window._destroyed then
					return
				end
				screen.Enabled = true
			end)

			task.defer(placeFabTopCenter)

			local function syncMobileOpenVisibility()
				if window._destroyed or not holder.Parent then
					return
				end
				holder.Visible = not screen.Enabled
			end
			screen:GetPropertyChangedSignal("Enabled"):Connect(syncMobileOpenVisibility)
