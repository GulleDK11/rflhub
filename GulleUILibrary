-- #region ConfigService (Rayfield-style paths + autosave)
Services.ConfigService = {
	Profile = "default",
	Folder = "GulleUI",
	_autoWindows = {},
}

local function configFileBaseName(profile)
	return (profile or Services.ConfigService.Profile) .. ".json"
end

local function joinConfigPath(folder, fileBase)
	if folder == nil or folder == "" or folder == "." then
		return fileBase
	end
	return folder .. "/" .. fileBase
end

local function configPath(profile)
	return joinConfigPath(Services.ConfigService.Folder, configFileBaseName(profile))
end

function Services.ConfigService:_onFlagChanged()
	for _, w in ipairs(self._autoWindows) do
		if not w._destroyed and w._configEnabled and w._scheduleAutosave then
			w:_scheduleAutosave()
		end
	end
end

function Services.ConfigService:NormalizeLoadedValue(v)
	if type(v) == "table" and v.R and v.G and v.B then
		return { math.floor(v.R), math.floor(v.G), math.floor(v.B) }
	end
	return v
end

function Services.ConfigService:Save(profile)
	profile = profile or self.Profile
	local ok, json = pcall(function()
		return HttpService:JSONEncode(Services.StateService.Flags)
	end)
	if not ok then
		return false
	end
	if writefile then
		pcall(function()
			local folder = self.Folder
			if folder and folder ~= "" and folder ~= "." then
				if not isfolder or not isfolder(folder) then
					if makefolder then
						makefolder(folder)
					end
				end
			end
			writefile(configPath(profile), json)
		end)
		return true
	end
	return false
end

function Services.ConfigService:Load(profile)
	profile = profile or self.Profile
	if not readfile or not isfile or not isfile(configPath(profile)) then
		return false
	end
	local ok, json = pcall(function()
		return readfile(configPath(profile))
	end)
	if not ok or not json then
		return false
	end
	local ok2, data = pcall(function()
		return HttpService:JSONDecode(json)
	end)
	if not ok2 or type(data) ~= "table" then
		return false
	end
	for k, v in pairs(data) do
		Services.StateService:SetFlag(k, self:NormalizeLoadedValue(v))
	end
	return true
end

function Services.ConfigService:SetProfile(name)
	self.Profile = name or "default"
end

function Services.ConfigService:SaveToPath(folder, fileName)
	local fn = fileName ~= nil and tostring(fileName) or "config"
	local base = fn:match("%.json$") and fn or (fn .. ".json")
	local path = joinConfigPath(folder, base)
	local ok, json = pcall(function()
		return HttpService:JSONEncode(Services.StateService.Flags)
	end)
	if not ok or not writefile then
		return false
	end
	local ok = pcall(function()
		if folder and folder ~= "" and folder ~= "." then
			if isfolder and not isfolder(folder) and makefolder then
				makefolder(folder)
			end
		end
		writefile(path, json)
	end)
	return ok
end

function Services.ConfigService:LoadFromPath(folder, fileName)
	local fn = fileName ~= nil and tostring(fileName) or "config"
	local base = fn:match("%.json$") and fn or (fn .. ".json")
	local path = joinConfigPath(folder, base)
	if not readfile or not isfile or not isfile(path) then
		return false
	end
	local ok, json = pcall(function()
		return readfile(path)
	end)
	if not ok or not json then
		return false
	end
	local ok2, data = pcall(function()
		return HttpService:JSONDecode(json)
	end)
	if not ok2 or type(data) ~= "table" then
		return false
	end
	for k, v in pairs(data) do
		Services.StateService:SetFlag(k, self:NormalizeLoadedValue(v))
	end
	return true
end
