-- Place check + deny (must run before Core.CreateWindow — otherwise locals are nil on first call)
local function currentPlaceAllowed()
	local ids = Services._allowedPlaceIds
	if ids == nil then
		return true
	end
	if type(ids) ~= "table" then
		return true
	end
	local pid = game.PlaceId
	for _, id in ipairs(ids) do
		if tonumber(id) == pid then
			return true
		end
	end
	return false
end

local function placeDeniedToastGui(guiParent)
	local sg = Utils.Create("ScreenGui", {
		Name = "GulleUI_PlaceDenied",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 620,
		Parent = guiParent,
	})
	Services.NotificationService:_ensureContainer(sg)
	Services.NotificationService:Notify({
		Title = "GulleUI",
		Message = "Place not allowed.",
		Duration = 5,
		Type = "error",
	})
	task.wait()
	pcall(function()
		local s = script
		if s and typeof(s) == "Instance" and s.Destroy then
			s:Destroy()
		end
	end)
	error("GulleUI: Place not allowed.", 0)
end

-- #region ConfigService (Rayfield-style paths + autosave)
Services.ConfigService = {
	Profile = "default",
	Folder = "GulleUI",
	_autoWindows = {},
}

local function configFileBaseName(profile)
	return (profile or Services.ConfigService.Profile) .. ".json"
end

local function joinConfigPath(folder, fileBase)
	if folder == nil or folder == "" or folder == "." then
		return fileBase
	end
	return folder .. "/" .. fileBase
end

local function configPath(profile)
	return joinConfigPath(Services.ConfigService.Folder, configFileBaseName(profile))
end

function Services.ConfigService:_onFlagChanged()
	for _, w in ipairs(self._autoWindows) do
		if not w._destroyed and w._configEnabled and w._scheduleAutosave then
			w:_scheduleAutosave()
		end
	end
end

function Services.ConfigService:NormalizeLoadedValue(v)
	if type(v) == "table" and v.R and v.G and v.B then
		return { math.floor(v.R), math.floor(v.G), math.floor(v.B) }
	end
	return v
end

function Services.ConfigService:Save(profile)
	profile = profile or self.Profile
	local ok, json = pcall(function()
		return HttpService:JSONEncode(Services.StateService.Flags)
	end)
	if not ok then
		return false
	end
	if writefile then
		pcall(function()
			local folder = self.Folder
			if folder and folder ~= "" and folder ~= "." then
				if not isfolder or not isfolder(folder) then
					if makefolder then
						makefolder(folder)
					end
				end
			end
			writefile(configPath(profile), json)
		end)
		return true
	end
	return false
end

function Services.ConfigService:Load(profile)
	profile = profile or self.Profile
	if not readfile or not isfile or not isfile(configPath(profile)) then
		return false
	end
	local ok, json = pcall(function()
		return readfile(configPath(profile))
	end)
	if not ok or not json then
		return false
	end
	local ok2, data = pcall(function()
		return HttpService:JSONDecode(json)
	end)
	if not ok2 or type(data) ~= "table" then
		return false
	end
	for k, v in pairs(data) do
		Services.StateService:SetFlag(k, self:NormalizeLoadedValue(v))
	end
	return true
end

function Services.ConfigService:SetProfile(name)
	self.Profile = name or "default"
end

function Services.ConfigService:SaveToPath(folder, fileName)
	local fn = fileName ~= nil and tostring(fileName) or "config"
	local base = fn:match("%.json$") and fn or (fn .. ".json")
	local path = joinConfigPath(folder, base)
	local ok, json = pcall(function()
		return HttpService:JSONEncode(Services.StateService.Flags)
	end)
	if not ok or not writefile then
		return false
	end
	local ok = pcall(function()
		if folder and folder ~= "" and folder ~= "." then
			if isfolder and not isfolder(folder) and makefolder then
				makefolder(folder)
			end
		end
		writefile(path, json)
	end)
	return ok
end

function Services.ConfigService:LoadFromPath(folder, fileName)
	local fn = fileName ~= nil and tostring(fileName) or "config"
	local base = fn:match("%.json$") and fn or (fn .. ".json")
	local path = joinConfigPath(folder, base)
	if not readfile or not isfile or not isfile(path) then
		return false
	end
	local ok, json = pcall(function()
		return readfile(path)
	end)
	if not ok or not json then
		return false
	end
	local ok2, data = pcall(function()
		return HttpService:JSONDecode(json)
	end)
	if not ok2 or type(data) ~= "table" then
		return false
	end
	for k, v in pairs(data) do
		Services.StateService:SetFlag(k, self:NormalizeLoadedValue(v))
	end
	return true
end
-- #endregion

-- #region DependencyService
Services.DependencyService = {
	_links = {},
}

function Services.DependencyService:Link(flagA, flagB, mapFn)
	self._links[flagA] = self._links[flagA] or {}
	table.insert(self._links[flagA], { other = flagB, map = mapFn })
	Services.StateService:OnFlagChanged(flagA, function(v)
		for _, L in ipairs(self._links[flagA]) do
			local nv = L.map and L.map(v) or v
			Services.StateService:SetFlag(L.other, nv)
		end
	end)
end

function Services.DependencyService:RegisterDependency(flagA, flagB, mapFn)
	self:Link(flagA, flagB, mapFn)
end

function Services.DependencyService:Watch(flag, callback)
	Services.StateService:OnFlagChanged(flag, callback)
end

function Services.DependencyService:When(flag, predicate, callback)
	Services.StateService:OnFlagChanged(flag, function(v, old)
		if predicate(v, old) then
			callback(v, old)
		end
	end)
end

function Services.DependencyService:BindElements(sourceFlag, targetFlag, mapper)
	self:Link(sourceFlag, targetFlag, mapper)
end
-- #endregion

-- #region Core internal UI builders
function Core.GetColors(window)
	local C = Utils.DeepCopy(Services.ThemeService.Current)
	if window and window._themeOverride then
		local o = window._themeOverride
		if type(o.Colors) == "table" then
			Utils.DeepMerge(C, o.Colors)
		end
		local groups = Services.ThemeService.TokenGroupKeys
		for k, v in pairs(o) do
			if k ~= "Colors" and k ~= "Tokens" and (not groups or not groups[k]) and typeof(v) == "Color3" then
				C[k] = v
			end
		end
	end
	return C
end

function Core.GetTokens(window)
	local T = Utils.DeepCopy(Services.ThemeService.Tokens)
	if window and window._themeOverride then
		local o = window._themeOverride
		if type(o.Tokens) == "table" then
			Utils.DeepMerge(T, o.Tokens)
		end
		local groups = Services.ThemeService.TokenGroupKeys
		if groups then
			for k, v in pairs(o) do
				if groups[k] and type(v) == "table" then
					T[k] = T[k] or {}
					Utils.DeepMerge(T[k], v)
				end
			end
		end
	end
	return T
end

function Core.AddThemeRef(window, inst, propertyName, themeKey)
	if not inst then
		return
	end
	window._themeRefs = window._themeRefs or {}
	table.insert(window._themeRefs, { inst, propertyName, themeKey })
	local T = Core.GetColors(window)
	if T[themeKey] ~= nil then
		inst[propertyName] = T[themeKey]
	end
end

function Core.ApplyThemeRefs(window)
	local T = Core.GetColors(window)
	for _, r in ipairs(window._themeRefs or {}) do
		local inst, prop, key = r[1], r[2], r[3]
		if inst.Parent and T[key] ~= nil then
			inst[prop] = T[key]
		end
	end
end

function Core.CreateWindow(opts)
