				local twCt = t._tabContentTween
				if twCt then
					pcall(function()
						twCt:Cancel()
					end)
					t._tabContentTween = nil
				end
				if t._tabPageFade then
					t._tabPageFade.GroupTransparency = 1
				end
				t._button.BackgroundTransparency = 0
				window:_tweenSidebarTab(t._button, t._label, th.SurfaceMuted, th.TabInactive)
			end
			page.CanvasPosition = Vector2.zero
			page.Visible = true
			window._activeTab = tabObj
			btn.BackgroundTransparency = 0
			window:_tweenSidebarTab(btn, tabLbl, th.SurfaceHover, th.Text)

			if tabPageFade and ta.ContentFadeOn then
				tabPageFade.GroupTransparency = 1
				task.defer(function()
					if window._activeTab ~= tabObj or not page.Parent then
						return
					end
					local twFade = Utils.Tween(
						tabPageFade,
						TweenInfo.new(ta.ContentFadeDur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{ GroupTransparency = 0 }
					)
					tabObj._tabContentTween = twFade
					twFade.Completed:Connect(function()
						if tabObj._tabContentTween == twFade then
							tabObj._tabContentTween = nil
						end
					end)
				end)
			elseif tabPageFade then
				tabPageFade.GroupTransparency = 0
			end
		end

		btn.MouseButton1Click:Connect(selectTab)

		btn.MouseEnter:Connect(function()
			if window._activeTab ~= tabObj then
				local th = Core.GetColors(window)
				window:_tweenSidebarTab(btn, tabLbl, th.SurfaceHover, th.TabInactive)
			end
		end)
		btn.MouseLeave:Connect(function()
			if window._activeTab ~= tabObj then
				local th = Core.GetColors(window)
				window:_tweenSidebarTab(btn, tabLbl, th.SurfaceMuted, th.TabInactive)
			end
		end)

		table.insert(window._tabs, tabObj)
		if #window._tabs == 1 then
			selectTab()
		end

	return tabObj
end

	-- Toasts must work before the hub exists (e.g. key gate / place denied); reparent container if parent changed.
	do
		local notifyParent = windowFadeRoot or screen
		local c = Services.NotificationService._container
		if c and c.Parent and c.Parent ~= notifyParent then
			c.Parent = notifyParent
		end
	end
	Services.NotificationService:_ensureContainer(windowFadeRoot or screen)

	if configEnabled then
		table.insert(Services.ConfigService._autoWindows, window)
	end

	task.defer(function()
		local animTok = tok.Animation or {}
		local openDur = animTok.WindowOpenDuration or 0.32
		if windowFadeRoot and windowFadeRoot:IsA("CanvasGroup") and animTok.WindowContentFadeIn ~= false then
			windowFadeRoot.GroupTransparency = 1
			local twWinIn = Utils.Tween(
				windowFadeRoot,
				TweenInfo.new(openDur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{ GroupTransparency = 0 }
			)
			task.spawn(function()
				pcall(function()
					twWinIn.Completed:Wait()
				end)
				-- Detach from CanvasGroup right after intro fade for crisp text/UI.
				if
					animTok.WindowCanvasDetachAfterOpen ~= false
					and windowFadeRoot
					and windowFadeRoot.Parent
					and main.Parent == windowFadeRoot
				then
					main.Parent = screen
					local nc = Services.NotificationService._container
					if nc and nc.Parent == windowFadeRoot then
						nc.Parent = screen
					end
					pcall(function()
						windowFadeRoot:Destroy()
					end)
					window._windowFadeRoot = nil
				end
			end)
		elseif windowFadeRoot and windowFadeRoot:IsA("CanvasGroup") then
			windowFadeRoot.GroupTransparency = 0
		end
		if mainUIScale and mainUIScale.Scale < 0.999 then
			Utils.Tween(
				mainUIScale,
				TweenInfo.new(openDur, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
				{ Scale = animTok.WindowOpenScale or 1 }
			)
		end
		local barDur = animTok.LoadingBarDuration or 1.25
		local loadingMin = tonumber(animTok.LoadingScreenMinDuration) or 2
		local loadFadeDur = tonumber(animTok.LoadingFadeOutDuration) or 0.42
		Utils.Tween(
			loadBarFill,
			TweenInfo.new(barDur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Size = UDim2.new(1, 0, 1, 0) }
		)
		local hold = math.max(openDur, barDur, loadingMin, 0.2)
		task.wait(hold)
		if loadingFade and loadingFade:IsA("CanvasGroup") then
			local tw = Utils.Tween(
				loadingFade,
				TweenInfo.new(loadFadeDur, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{ GroupTransparency = 1 }
			)
			task.spawn(function()
				pcall(function()
					tw.Completed:Wait()
				end)
				if loading.Parent then
					loading.Visible = false
				end
			end)
		else
			local ti = TweenInfo.new(loadFadeDur, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
			Utils.Tween(loadingBg, ti, { BackgroundTransparency = 1 })
			Utils.Tween(loadTitle, ti, { TextTransparency = 1 })
			Utils.Tween(loadSub, ti, { TextTransparency = 1 })
			Utils.Tween(loadBarBg, ti, { BackgroundTransparency = 1 })
			Utils.Tween(loadBarFill, ti, { BackgroundTransparency = 1 })
			if logoLoadingInst then
				Utils.Tween(logoLoadingInst, ti, { ImageTransparency = 1 })
			end
			task.delay(loadFadeDur, function()
				if loading.Parent then
					loading.Visible = false
				end
			end)
		end
		-- CanvasGroup rasterizes the whole window → often blurry text, worse on resize. Move `main` to ScreenGui after intro.
		if
			animTok.WindowCanvasDetachAfterOpen ~= false
			and windowFadeRoot
			and windowFadeRoot.Parent
			and main.Parent == windowFadeRoot
		then
			main.Parent = screen
			local nc = Services.NotificationService._container
			if nc and nc.Parent == windowFadeRoot then
				nc.Parent = screen
			end
			pcall(function()
				windowFadeRoot:Destroy()
			end)
			window._windowFadeRoot = nil
		end
	end)

	table.insert(window._tabThemeHooks, function()
		window:_syncTabStyles()
	end)

	searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		window:_applyTabSearch(searchBox.Text)
	end)

	return window
end
