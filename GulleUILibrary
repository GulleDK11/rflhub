function Services.NotificationService:_spawnToast(item)
	local theme = Services.ThemeService.Current
	local nt = Services.ThemeService.Tokens.Notification
	local function notifyTextColors()
		local raw = tostring(item.Type or item.Level or item.Variant or item.NotifyType or "normal")
		local k = string.lower((raw:gsub("^%s+", ""):gsub("%s+$", "")))
		local function c3(x, fb)
			return (typeof(x) == "Color3" and x) or fb
		end
		local fbErr = Color3.fromRGB(248, 113, 113)
		local fbWarn = Color3.fromRGB(251, 191, 36)
		local fbInfo = Color3.fromRGB(96, 165, 250)
		local fbOk = Color3.fromRGB(52, 211, 153)
		local fbAcc = Color3.fromRGB(234, 118, 42)
		local fbDim = Color3.fromRGB(148, 146, 138)
		if k == "error" or k == "danger" or k == "fail" or k == "failed" then
			return c3(theme.Error, fbErr), c3(theme.TextDim, fbDim)
		elseif k == "warning" or k == "warn" or k == "advarsel" then
			return c3(theme.Warning, fbWarn), c3(theme.TextDim, fbDim)
		elseif k == "info" or k == "information" then
			return c3(theme.Info, fbInfo), c3(theme.TextDim, fbDim)
		elseif k == "success" or k == "ok" then
			return c3(theme.Success, fbOk), c3(theme.TextDim, fbDim)
		else
			return c3(theme.Accent, fbAcc), c3(theme.TextDim, fbDim)
		end
	end
	local titleC, bodyC = notifyTextColors()
	local function surfaceFallback()
		return (typeof(theme.Surface) == "Color3" and theme.Surface) or Color3.fromRGB(30, 30, 34)
	end
	local winCorner = (Services.ThemeService.Tokens.Window or {}).CornerRadius
	local cornerR = math.max(0, math.floor(tonumber(nt.CornerRadius) or tonumber(winCorner) or 6))
	local frameStrokeThick = math.clamp(tonumber(nt.FrameStrokeThickness) or 1, 0, 2.5)
	local frameStrokeT = math.clamp(tonumber(nt.FrameStrokeTransparency) or 0.62, 0, 0.95)
	local borderNeutral = (typeof(theme.Border) == "Color3" and theme.Border) or Color3.fromRGB(48, 46, 44)
	self._toastOrder = self._toastOrder + 1
	if self._stack then
		self._stack.Size = UDim2.new(0, nt.Width + 24, 1, -40)
	end
	local padY = nt.PaddingY or 10
	local padX = nt.PaddingX or 12
	local card = Utils.Create("Frame", {
		Name = "ToastCard",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(0, nt.Width, 0, 48),
		AutomaticSize = Enum.AutomaticSize.None,
		LayoutOrder = self._toastOrder,
		ClipsDescendants = true,
		Parent = self._stack or self._container,
	})
	Utils.Create("UICorner", { CornerRadius = UDim.new(0, cornerR), Parent = card })
	local toastFade = Utils.TryCreateCanvasGroup({
		Name = "ToastFade",
		GroupTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Position = UDim2.fromScale(0, 0),
		Parent = card,
	})
	local function attachToastChrome(parentFrame)
		local chrome = Utils.Create("Frame", {
			Name = "ToastChrome",
			BackgroundColor3 = surfaceFallback(),
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			Size = UDim2.fromScale(1, 1),
			Position = UDim2.fromScale(0, 0),
			ZIndex = 1,
			Parent = parentFrame,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, cornerR), Parent = chrome })
		if frameStrokeThick > 0.05 then
			local stroke = Instance.new("UIStroke")
			stroke.Name = "ToastFrameStroke"
			stroke.Color = borderNeutral
			stroke.Thickness = frameStrokeThick
			stroke.Transparency = frameStrokeT
			stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
			pcall(function()
				stroke.LineJoinMode = Enum.LineJoinMode.Round
			end)
			stroke.Parent = chrome
		end
		return chrome
	end

	if toastFade then
		attachToastChrome(toastFade)
	else
		card.BackgroundTransparency = 1
		card.BorderSizePixel = 0
		attachToastChrome(card)
	end
	local contentRoot = toastFade or card
	local mover = Utils.Create("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 1, 0),
		Position = UDim2.new(0, 0, 0, 0),
		ZIndex = 4,
		ClipsDescendants = true,
		Parent = contentRoot,
	})
	local pad = Utils.Create("UIPadding", {
		PaddingTop = UDim.new(0, padY),
		PaddingBottom = UDim.new(0, padY),
		PaddingLeft = UDim.new(0, padX),
		PaddingRight = UDim.new(0, padX),
		Parent = mover,
	})
	local inner = Utils.Create("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = mover,
	})
	local innerList = Utils.Create("UIListLayout", {
		FillDirection = Enum.FillDirection.Vertical,
		Padding = UDim.new(0, 6),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = inner,
	})
	local function refreshCardHeight()
		local colH = innerList.AbsoluteContentSize.Y
		local h = padY * 2 + colH
		card.Size = UDim2.new(0, nt.Width, 0, math.max(32, math.ceil(h)))
	end
	innerList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshCardHeight)
	local title = Utils.Create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamBold,
		TextSize = nt.TitleSize,
		TextColor3 = titleC,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
		Text = item.Title or "Notice",
		LayoutOrder = 0,
		Parent = inner,
	})
	local body = Utils.Create("TextLabel", {
		BackgroundTransparency = 1,
		Font = Enum.Font.Gotham,
		TextSize = nt.BodySize,
		TextColor3 = bodyC,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
		Text = item.Message or item.Content or "",
		LayoutOrder = 1,
		Parent = inner,
	})
	task.defer(refreshCardHeight)
	local fadeIn = nt.FadeInDuration or 0.4
	if toastFade then
		Utils.Tween(
			toastFade,
			TweenInfo.new(fadeIn, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ GroupTransparency = 0 }
		)
	end
	task.delay(item.Duration or 3.5, function()
		if not card.Parent then
			return
		end
		local function removeCard()
			if card.Parent then
				card:Destroy()
			end
		end
		if toastFade then
			local fadeOut = nt.FadeOutDuration or 0.35
			local tw = Utils.Tween(
				toastFade,
				TweenInfo.new(fadeOut, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{ GroupTransparency = 1 }
			)
			task.spawn(function()
				tw.Completed:Wait()
				removeCard()
			end)
		else
			removeCard()
		end
	end)
end

function Services.NotificationService:Notify(data)
	data = type(data) == "table" and data or { Title = "Notice", Message = tostring(data) }
	if not self._container or not self._container.Parent then
		return
	end
	self:_spawnToast(data)
end
