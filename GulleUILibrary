local function getGuiParent()
	if gethui and type(gethui) == "function" then
		return gethui()
	end
	return LocalPlayer:WaitForChild("PlayerGui")
end

local function resolveGuiParent(opts)
	if type(opts) == "table" and opts.UseCoreGui == false then
		return LocalPlayer:WaitForChild("PlayerGui")
	end
	return getGuiParent()
end
