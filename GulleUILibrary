				select(1, ElemCtx(win)).Accent,
				0.4,
				Vector2.new(input.Position.X, input.Position.Y)
			)
		end)
		btn.MouseButton1Click:Connect(function()
			if opts.Callback then
				task.spawn(opts.Callback)
			end
		end)
		btn.MouseEnter:Connect(function()
			local th = select(1, ElemCtx(win))
			Utils.Tween(btn, TweenInfo.new(0.18, Enum.EasingStyle.Quad), { BackgroundColor3 = th.Accent })
		end)
		btn.MouseLeave:Connect(function()
			local th = select(1, ElemCtx(win))
			Utils.Tween(btn, TweenInfo.new(0.18, Enum.EasingStyle.Quad), { BackgroundColor3 = th.Surface })
		end)

		return elementApi(card, {
