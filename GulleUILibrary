				local want = norm(trimmed)
				for _, k in ipairs(keyOpts.Keys) do
					if norm(k) == want then
						ok = true
						break
					end
				end
			elseif keyOpts.Key ~= nil then
				ok = norm(keyOpts.Key) == norm(trimmed)
			else
				keyGateShowError("Key: set Keys, Key, or Validate.")
				return
			end

			if not ok then
				keyGateShowError(keyOpts.WrongText or keyOpts.InvalidText or "Invalid key.")
				if type(keyOpts.OnFail) == "function" then
					pcall(keyOpts.OnFail, trimmed)
				end
				return
			end

			busy = true
			window._keyValidated = true
			if configEnabled then
				Services.ConfigService:LoadFromPath(configFolder, configFileName)
			end
			registerAutosaveOnce()
			if type(keyOpts.OnSuccess) == "function" then
				pcall(keyOpts.OnSuccess, trimmed)
			end
			dim:Destroy()
			mainStroke.Transparency = strokeTransBefore
			resizeGrip.Visible = true
			if keyShrinkOn then
				main.Size = savedMainSize
			end
			resetLoadingLayerForReveal()
			beginStartupLoadingAnimation()
		end

		submitBtn.MouseButton1Click:Connect(trySubmit)
		box.FocusLost:Connect(function(enter)
			if enter and keyOpts.SubmitOnEnter ~= false then
				trySubmit()
			end
		end)
		if closeKeyBtn then
			closeKeyBtn.MouseButton1Click:Connect(function()
				screen.Enabled = false
			end)
		end
	else
		registerAutosaveOnce()
		beginStartupLoadingAnimation()
	end

	table.insert(window._tabThemeHooks, function()
		window:_syncTabStyles()
	end)

	searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		window:_applyTabSearch(searchBox.Text)
	end)

	return window
end
