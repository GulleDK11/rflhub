	-- rolibwaita-style aliases (see GulleUILibrary.md)
	function section:NewButton(opts)
		return self:CreateButton(opts)
	end

	function section:NewToggle(opts)
		opts = opts or {}
		local o = Utils.DeepCopy(opts)
		if opts.CurrentState ~= nil then
			o.Default = opts.CurrentState
		end
		return self:CreateToggle(o)
	end

	function section:NewTextBox(opts)
		opts = opts or {}
		return self:CreateInput({
			Name = opts.Name,
			Placeholder = opts.PlaceholderText,
			Default = opts.Text,
			Flag = opts.Flag,
			Trigger = opts.Trigger or "FocusLost",
			Callback = opts.Callback,
		})
	end

	function section:NewDropdown(opts)
		opts = opts or {}
		return self:CreateDropdown({
			Name = opts.Name,
			Options = opts.Choices or opts.Options,
			Default = opts.CurrentState,
			Flag = opts.Flag,
			Callback = opts.Callback,
		})
	end

	function section:NewSlider(opts)
		opts = opts or {}
		local mm = opts.MinMax or { "0", "100" }
		local minv = tonumber(mm[1]) or 0
		local maxv = tonumber(mm[2]) or 100
		local inc = opts.Increment
		return self:CreateSlider({
			Name = opts.Name,
			Flag = opts.Flag,
			Min = minv,
			Max = maxv,
			Default = opts.CurrentValue,
			Increment = type(inc) == "number" and inc > 0 and inc or nil,
			Callback = opts.Callback,
		})
	end

	function section:NewDivider(opts)
		return self:CreateDivider(opts)
	end

	return section
end
