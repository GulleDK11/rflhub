	local subtitle = opts.Subtitle ~= nil and opts.Subtitle or ""
	local loadingTitle = opts.LoadingTitle or displayName
	local loadingSub = opts.LoadingSubtitle or subtitle

	local configSaving = opts.ConfigurationSaving or {}
	local configEnabled = configSaving.Enabled == true
	local configFolder = (configSaving.FolderName ~= nil) and configSaving.FolderName or "GulleUI"
	local configFileName = configSaving.FileName or tostring(game.PlaceId)

	if configEnabled then
		Services.ConfigService:LoadFromPath(configFolder, configFileName)
	end

	local developerUserIds = {}
	for _, id in ipairs(_defaultDeveloperUserIds) do
		table.insert(developerUserIds, id)
	end
	if type(opts.DeveloperUserIds) == "table" then
		for _, id in ipairs(opts.DeveloperUserIds) do
			local n = tonumber(id)
			if n and not table.find(developerUserIds, n) then
				table.insert(developerUserIds, n)
			end
		end
	end

	local function windowSidebarRankLabel()
		if type(opts.SidebarRank) == "string" and opts.SidebarRank ~= "" then
			return opts.SidebarRank
		end
		if table.find(developerUserIds, LocalPlayer.UserId) then
			return "Developer"
		end
		if game.CreatorType == Enum.CreatorType.User and LocalPlayer.UserId == game.CreatorId then
			return "Developer"
		end
		return "User"
	end

	local windowThemeOverride = nil
	if type(opts.Theme) == "table" then
		if opts.Theme.ApplyGlobally or opts.Theme.Globally then
			Services.ThemeService:_mergeThemeTable(opts.Theme)
		else
			windowThemeOverride = opts.Theme
		end
	end

	local themeStub = { _themeOverride = windowThemeOverride }
	local colors = Core.GetColors(themeStub)
	local tok = Core.GetTokens(themeStub)

	local function normalizeLogoAsset(raw)
		if raw == nil then
			return nil
		end
		if type(raw) == "number" and raw > 0 then
			return "rbxassetid://" .. tostring(math.floor(raw))
		end
		if type(raw) ~= "string" then
			return nil
		end
		local s = tostring(raw):gsub("^%s+", ""):gsub("%s+$", "")
		if s == "" then
			return nil
		end
		local lower = string.lower(s)
		if
			string.sub(lower, 1, 14) == "rbxassetid://"
			or string.sub(lower, 1, 12) == "rbxasset://"
			or string.sub(lower, 1, 11) == "rbxthumb://"
			or string.sub(lower, 1, 7) == "http://"
			or string.sub(lower, 1, 8) == "https://"
		then
			return s
		end
		if s:match("^%d+$") then
			return "rbxassetid://" .. s
		end
		return s
	end
