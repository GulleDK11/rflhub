	function section:CreateSlider(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local flag = opts.Flag
		local minv = opts.Min or 0
		local maxv = opts.Max or 100
		local def = opts.Default or minv
		if flag then
			Services.StateService:SetFlag(flag, Services.StateService:GetFlag(flag) ~= nil and Services.StateService:GetFlag(flag) or def)
		end
		local value = flag and Services.StateService:GetFlag(flag) or def
		value = Utils.Clamp(tonumber(value) or def, minv, maxv)

		local card = createControlRowCard(rowsHost, theme, etok, win)
		local wrap = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, etok.Control.SliderBlockHeight),
			Parent = card,
		})
		local top = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 16),
			Parent = wrap,
		})
		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(0.65, 0, 1, 0),
			Text = opts.Name or "Slider",
			Parent = top,
		})
		local valLabel = Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.GothamMedium,
			TextSize = etok.Control.SecondaryTextSize,
			TextColor3 = theme.TextDim,
			TextXAlignment = Enum.TextXAlignment.Right,
			Size = UDim2.new(0.35, 0, 1, 0),
			Position = UDim2.new(0.65, 0, 0, 0),
			Text = tostring(value),
			Parent = top,
		})

		local tr = etok.Control.DefaultRadius
		local thk = etok.Control.SliderTrackThickness
		local track = Utils.Create("Frame", {
			BackgroundColor3 = theme.Surface,
			Position = UDim2.fromOffset(0, 19),
			Size = UDim2.new(1, 0, 0, thk),
			BorderSizePixel = 0,
			Parent = wrap,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, tr), Parent = track })
		local fill = Utils.Create("Frame", {
			BackgroundColor3 = theme.Accent,
			Size = UDim2.new((value - minv) / (maxv - minv), 0, 1, 0),
			BorderSizePixel = 0,
			Parent = track,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, tr), Parent = fill })

		local dragging = false
		local function setFromX(x)
			local rel = Utils.Clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			local nv = minv + rel * (maxv - minv)
			local inc = opts.Increment
			if type(inc) == "number" and inc > 0 then
				nv = minv + math.floor((nv - minv) / inc + 0.5) * inc
			end
			if opts.Rounding then
				nv = math.floor(nv + 0.5)
			end
			value = Utils.Clamp(nv, minv, maxv)
			fill.Size = UDim2.new((value - minv) / (maxv - minv), 0, 1, 0)
			valLabel.Text = tostring(value)
			if flag then
				Services.StateService:SetFlag(flag, value)
			end
			if opts.Callback then
				task.spawn(opts.Callback, value)
			end
		end

		local inputBegan = track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				setFromX(input.Position.X)
			end
		end)
		local inputEnded = UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
		local inputChanged = UserInputService.InputChanged:Connect(function(input)
			if
				dragging
				and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch)
			then
				setFromX(input.Position.X)
			end
		end)

		if flag then
			Services.StateService:OnFlagChanged(flag, function(v)
				local n = tonumber(v)
				if n and math.abs(n - value) > 1e-5 then
					value = Utils.Clamp(n, minv, maxv)
					fill.Size = UDim2.new((value - minv) / (maxv - minv), 0, 1, 0)
					valLabel.Text = tostring(value)
				end
			end)
		end

		return elementApi(card, {
			Set = function(_, v)
				value = Utils.Clamp(tonumber(v) or value, minv, maxv)
				fill.Size = UDim2.new((value - minv) / (maxv - minv), 0, 1, 0)
				valLabel.Text = tostring(value)
				if flag then
					Services.StateService:SetFlag(flag, value)
				end
			end,
			Get = function()
				return value
			end,
		})
	end

	function section:CreateDropdown(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local flag = opts.Flag
		local options = opts.Options or {}
		local def = opts.Default or options[1] or ""
		if flag then
			Services.StateService:SetFlag(flag, Services.StateService:GetFlag(flag) ~= nil and Services.StateService:GetFlag(flag) or def)
		end
		local current = flag and Services.StateService:GetFlag(flag) or def

		local function mixRgb(a, b, k)
			return Color3.new(a.R + (b.R - a.R) * k, a.G + (b.G - a.G) * k, a.B + (b.B - a.B) * k)
		end

		local card = createControlRowCard(rowsHost, theme, etok, win)
		local wrap = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = card,
		})
		Utils.Create("UIListLayout", {
			Padding = UDim.new(0, etok.Control.InnerStackPadding or 2),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = wrap,
		})
		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1, 0, 0, 16),
			Text = opts.Name or "Dropdown",
			LayoutOrder = 0,
			Parent = wrap,
		})
		local dr = etok.Control.DefaultRadius
		local rowH = etok.Control.ToggleRowHeight
		local triggerH = etok.Control.DropdownRowOpen or 30
		local triggerBg = (typeof(theme.BackgroundElevated) == "Color3" and theme.BackgroundElevated) or theme.Surface
		local popupBg = (typeof(theme.BackgroundElevated) == "Color3" and theme.BackgroundElevated) or theme.Surface

		local openBtn = Utils.Create("TextButton", {
			BackgroundColor3 = triggerBg,
			Size = UDim2.new(1, 0, 0, triggerH),
			LayoutOrder = 1,
			Text = "",
			AutoButtonColor = false,
			Parent = wrap,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = openBtn })
		local triggerStroke = Utils.Create("UIStroke", {
			Color = theme.Border,
			Thickness = 1,
			Transparency = 0.55,
			ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
			Parent = openBtn,
		})
		Utils.Create("UIPadding", {
			PaddingLeft = UDim.new(0, 10),
			PaddingRight = UDim.new(0, 8),
			Parent = openBtn,
		})
		local triggerRow = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			Parent = openBtn,
		})
		Utils.Create("UIListLayout", {
			FillDirection = Enum.FillDirection.Horizontal,
			HorizontalAlignment = Enum.HorizontalAlignment.Left,
			VerticalAlignment = Enum.VerticalAlignment.Center,
			Padding = UDim.new(0, 6),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = triggerRow,
		})
		local valueLbl = Utils.Create("TextLabel", {
			Name = "DropdownValue",
			BackgroundTransparency = 1,
			Font = Enum.Font.GothamSemibold,
			TextSize = etok.Control.SecondaryTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,
			Size = UDim2.new(1, -22, 1, 0),
			Text = tostring(current),
			LayoutOrder = 0,
			Active = false,
			Selectable = false,
			Parent = triggerRow,
		})
		local chevron = Utils.Create("TextLabel", {
			Name = "DropdownChevron",
			BackgroundTransparency = 1,
			Font = Enum.Font.GothamBold,
			TextSize = 11,
			TextColor3 = theme.TextDim,
			Text = "▼",
			Size = UDim2.fromOffset(18, 18),
			LayoutOrder = 1,
			Active = false,
			Selectable = false,
			Parent = triggerRow,
		})

		local listFrame = Utils.Create("Frame", {
			BackgroundColor3 = popupBg,
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 0),
			Visible = false,
			AutomaticSize = Enum.AutomaticSize.Y,
			ClipsDescendants = true,
			ZIndex = 5,
			LayoutOrder = 2,
			Parent = wrap,
		})
		local dropdownMount = win and win._dropdownMount
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = listFrame })
		Utils.Create("UIStroke", {
			Color = theme.Border,
			Thickness = 1,
			Transparency = 0.35,
			ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
			Parent = listFrame,
		})
		Utils.Create("UIPadding", {
			PaddingTop = UDim.new(0, 5),
			PaddingBottom = UDim.new(0, 5),
			PaddingLeft = UDim.new(0, 5),
			PaddingRight = UDim.new(0, 5),
			Parent = listFrame,
		})
		local listPad = etok.Control.DropdownListPadding or 3
		Utils.Create("UIListLayout", {
			Padding = UDim.new(0, listPad),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = listFrame,
		})

		local open = false
		local function setTriggerOpenVisual(isOpen)
			chevron.Text = isOpen and "▲" or "▼"
			chevron.TextColor3 = isOpen and theme.Accent or theme.TextDim
			triggerStroke.Color = isOpen and theme.Accent or theme.Border
			triggerStroke.Transparency = isOpen and 0.22 or 0.55
			openBtn.BackgroundColor3 = isOpen and mixRgb(triggerBg, theme.Accent, 0.08) or triggerBg
		end
		local function syncDropdownListGeometry()
			if not open or not dropdownMount or listFrame.Parent ~= dropdownMount then
				return
			end
			local ap = openBtn.AbsolutePosition
			local asz = openBtn.AbsoluteSize
			local mp = dropdownMount.AbsolutePosition
			local w = math.max(math.floor(asz.X), 80)
			listFrame.Position = UDim2.fromOffset(math.floor(ap.X - mp.X), math.floor(ap.Y - mp.Y + asz.Y + 3))
			listFrame.Size = UDim2.fromOffset(w, 0)
		end
		local function closeDropdownUI()
			open = false
			setTriggerOpenVisual(false)
			if win._dropdownRenderConn then
				win._dropdownRenderConn:Disconnect()
				win._dropdownRenderConn = nil
			end
			if win._dropdownClose == closeDropdownUI then
				win._dropdownClose = nil
			end
			listFrame.Visible = false
			listFrame.BackgroundTransparency = 1
			listFrame.ZIndex = 5
			listFrame.Parent = wrap
			listFrame.Position = UDim2.fromScale(0, 0)
			listFrame.Size = UDim2.new(1, 0, 0, 0)
			listFrame.LayoutOrder = 2
		end
		local function rebuild()
			for _, c in ipairs(listFrame:GetChildren()) do
				if c:IsA("TextButton") then
					c:Destroy()
				end
			end
			local innerR = math.max(2, dr - 1)
			for _, opt in ipairs(options) do
				local optStr = tostring(opt)
				local isSel = optStr == tostring(current)
				local idleBg = isSel and mixRgb(theme.Surface, theme.Accent, 0.14) or theme.Surface
				local b = Utils.Create("TextButton", {
					BackgroundColor3 = idleBg,
					Text = "",
					AutoButtonColor = false,
					Size = UDim2.new(1, 0, 0, rowH),
					ZIndex = 6,
					Parent = listFrame,
				})
				Utils.Create("UICorner", { CornerRadius = UDim.new(0, innerR), Parent = b })
				local rowInner = Utils.Create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 1, 0),
					ZIndex = 3,
					Parent = b,
				})
				Utils.Create("UIPadding", {
					PaddingLeft = UDim.new(0, 6),
					PaddingRight = UDim.new(0, 8),
					Parent = rowInner,
				})
				Utils.Create("UIListLayout", {
					FillDirection = Enum.FillDirection.Horizontal,
					VerticalAlignment = Enum.VerticalAlignment.Center,
					Padding = UDim.new(0, 6),
					Parent = rowInner,
				})
				Utils.Create("TextLabel", {
					BackgroundTransparency = 1,
					Font = Enum.Font.GothamBold,
					TextSize = 13,
					TextColor3 = theme.Accent,
					Text = "✓",
					TextTransparency = isSel and 0 or 1,
					Size = UDim2.fromOffset(14, rowH),
					Active = false,
					Selectable = false,
					Parent = rowInner,
				})
				Utils.Create("TextLabel", {
					BackgroundTransparency = 1,
					Font = isSel and Enum.Font.GothamSemibold or Enum.Font.Gotham,
					TextSize = etok.Control.SecondaryTextSize,
					TextColor3 = isSel and theme.Text or theme.TextDim,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextTruncate = Enum.TextTruncate.AtEnd,
					Size = UDim2.new(1, -20, 1, 0),
					Text = optStr,
					Active = false,
					Selectable = false,
					Parent = rowInner,
				})
				b.MouseEnter:Connect(function()
					if isSel then
						Utils.Tween(
							b,
							TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
							{ BackgroundColor3 = mixRgb(theme.Surface, theme.Accent, 0.22) }
						)
					else
						Utils.Tween(
							b,
							TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
							{ BackgroundColor3 = theme.SurfaceHover }
						)
					end
				end)
				b.MouseLeave:Connect(function()
					Utils.Tween(b, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						BackgroundColor3 = idleBg,
					})
				end)
				b.MouseButton1Click:Connect(function()
					current = opt
					valueLbl.Text = optStr
					if flag then
						Services.StateService:SetFlag(flag, current)
					end
					closeDropdownUI()
					rebuild()
					if opts.Callback then
						task.spawn(opts.Callback, current)
					end
				end)
			end
		end
		rebuild()

		openBtn.MouseEnter:Connect(function()
			if not open then
				Utils.Tween(openBtn, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundColor3 = theme.SurfaceHover,
				})
			end
		end)
		openBtn.MouseLeave:Connect(function()
			if not open then
				Utils.Tween(openBtn, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundColor3 = triggerBg,
				})
			end
		end)

		openBtn.MouseButton1Click:Connect(function()
			if open then
				closeDropdownUI()
				return
			end
			if dropdownMount then
				win:_closeGulleDropdown()
				open = true
				setTriggerOpenVisual(true)
				win._dropdownClose = closeDropdownUI
				listFrame.Parent = dropdownMount
				listFrame.LayoutOrder = 0
				listFrame.ZIndex = 50
				listFrame.Visible = true
				listFrame.BackgroundTransparency = 0
				syncDropdownListGeometry()
				win._dropdownRenderConn = RunService.Heartbeat:Connect(syncDropdownListGeometry)
			else
				open = true
				setTriggerOpenVisual(true)
				listFrame.Visible = true
				listFrame.Size = UDim2.new(1, 0, 0, 0)
				listFrame.BackgroundTransparency = 0
			end
		end)

		if flag then
			Services.StateService:OnFlagChanged(flag, function(v)
				if v ~= current then
					current = v
					valueLbl.Text = tostring(current)
					rebuild()
				end
			end)
		end

		return elementApi(card, {
			Refresh = function(_, newOpts)
				options = newOpts or options
				rebuild()
			end,
			Set = function(_, v)
				current = v
				valueLbl.Text = tostring(current)
				if flag then
					Services.StateService:SetFlag(flag, current)
				end
				rebuild()
			end,
			Get = function()
				return current
			end,
		})
	end

	function section:CreateInput(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local flag = opts.Flag
		local def = opts.Default or ""
		if flag then
			Services.StateService:SetFlag(flag, Services.StateService:GetFlag(flag) ~= nil and Services.StateService:GetFlag(flag) or def)
		end

		local card = createControlRowCard(rowsHost, theme, etok, win)
		local wrap = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, etok.Control.InputRowHeight),
			Parent = card,
		})
		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1, 0, 0, 16),
			Text = opts.Name or "Input",
			Parent = wrap,
		})
		local box = Utils.Create("TextBox", {
			BackgroundColor3 = theme.BackgroundElevated,
			Position = UDim2.fromOffset(0, 18),
			Size = UDim2.new(1, 0, 0, etok.Control.InputHeight),
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			Text = tostring(flag and Services.StateService:GetFlag(flag) or def),
			PlaceholderText = opts.Placeholder or "",
			PlaceholderColor3 = theme.TextDim,
			ClearTextOnFocus = false,
			Parent = wrap,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, etok.Control.DefaultRadius), Parent = box })
		Utils.Create("UIStroke", { Color = theme.Border, Thickness = 1, Transparency = 0.55, Parent = box })
		Utils.Create("UIPadding", {
			PaddingLeft = UDim.new(0, 10),
			PaddingRight = UDim.new(0, 10),
			Parent = box,
		})

		local trigger = opts.Trigger or "FocusLost"
		if trigger == "TextChanged" then
			box:GetPropertyChangedSignal("Text"):Connect(function()
				local t = box.Text
				if flag then
					Services.StateService:SetFlag(flag, t)
				end
				if opts.Callback then
					task.spawn(opts.Callback, t)
				end
			end)
		else
			box.FocusLost:Connect(function()
				local t = box.Text
				if flag then
					Services.StateService:SetFlag(flag, t)
				end
				if opts.Callback then
					task.spawn(opts.Callback, t)
				end
			end)
		end

		if flag then
			Services.StateService:OnFlagChanged(flag, function(v)
				if tostring(v) ~= box.Text then
					box.Text = tostring(v)
				end
			end)
		end

		return elementApi(card, {
			Set = function(_, text)
				box.Text = tostring(text)
				if flag then
					Services.StateService:SetFlag(flag, box.Text)
				end
			end,
			Get = function()
				return box.Text
			end,
		})
	end

	function section:CreateColorPicker(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local flag = opts.Flag
		local def = opts.Default or Color3.fromRGB(255, 255, 255)
		if flag then
			local existing = Services.StateService:GetFlag(flag)
			if existing == nil then
				Services.StateService:SetFlag(flag, {
					math.floor(def.R * 255),
					math.floor(def.G * 255),
					math.floor(def.B * 255),
				})
			end
		end
		local function getColor()
			if flag then
				local c = Services.StateService:GetFlag(flag)
				if type(c) == "table" and c[1] then
					return Color3.fromRGB(c[1], c[2], c[3])
				end
			end
			return def
		end
		local col = getColor()

		local card = createControlRowCard(rowsHost, theme, etok, win)
		local wrap = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Parent = card,
		})
		Utils.Create("UIListLayout", {
			Padding = UDim.new(0, etok.Control.InnerStackPadding or 2),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = wrap,
		})
		local row = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, etok.Control.ToggleRowHeight),
			LayoutOrder = 0,
			Parent = wrap,
		})
		local dr = etok.Control.DefaultRadius
		local thk = etok.Control.SliderTrackThickness
		local chRowH = etok.Control.ColorChannelRowHeight or 22
		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1, -40, 1, 0),
			Text = opts.Name or "Color",
			Parent = row,
		})
		local preview = Utils.Create("Frame", {
			Size = UDim2.fromOffset(28, 28),
			Position = UDim2.new(1, -28, 0.5, -14),
			BackgroundColor3 = col,
			BorderSizePixel = 0,
			Parent = row,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = preview })
		Utils.Create("UIStroke", { Color = theme.Border, Parent = preview })

		local sliders = { "R", "G", "B" }
		local vals = { math.floor(col.R * 255), math.floor(col.G * 255), math.floor(col.B * 255) }
		local fills = {}

		local function push()
			local c = Color3.fromRGB(vals[1], vals[2], vals[3])
			preview.BackgroundColor3 = c
			if flag then
				Services.StateService:SetFlag(flag, { vals[1], vals[2], vals[3] })
			end
			if opts.Callback then
				task.spawn(opts.Callback, c)
			end
		end

		for i, label in ipairs(sliders) do
			local sw = Utils.Create("Frame", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, chRowH),
				LayoutOrder = i,
				Parent = wrap,
			})
			Utils.Create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(0, 24, 1, 0),
				Font = Enum.Font.GothamBold,
				TextSize = etok.Control.SecondaryTextSize,
				TextColor3 = theme.TextDim,
				Text = label,
				Parent = sw,
			})
			local track = Utils.Create("Frame", {
				BackgroundColor3 = theme.Surface,
				Position = UDim2.fromOffset(28, math.max(0, math.floor((chRowH - thk) / 2))),
				Size = UDim2.new(1, -28, 0, thk),
				BorderSizePixel = 0,
				Parent = sw,
			})
			Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = track })
			local fill = Utils.Create("Frame", {
				BackgroundColor3 = theme.Accent,
				Size = UDim2.new(vals[i] / 255, 0, 1, 0),
				BorderSizePixel = 0,
				Parent = track,
			})
			fills[i] = fill
			Utils.Create("UICorner", { CornerRadius = UDim.new(0, dr), Parent = fill })
			local drag = false
			track.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					drag = true
					local rel = Utils.Clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
					vals[i] = math.floor(rel * 255)
					fill.Size = UDim2.new(rel, 0, 1, 0)
					push()
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					drag = false
				end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if
					drag
					and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch)
				then
					local rel = Utils.Clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
					vals[i] = math.floor(rel * 255)
					fill.Size = UDim2.new(rel, 0, 1, 0)
					push()
				end
			end)
		end

		if flag then
			Services.StateService:OnFlagChanged(flag, function(v)
				if type(v) == "table" and v[1] and v[2] and v[3] then
					vals[1], vals[2], vals[3] = v[1], v[2], v[3]
					for j = 1, 3 do
						if fills[j] then
							fills[j].Size = UDim2.new(vals[j] / 255, 0, 1, 0)
						end
					end
					preview.BackgroundColor3 = Color3.fromRGB(vals[1], vals[2], vals[3])
				end
			end)
		end

		return elementApi(card, {
			Get = getColor,
			Set = function(_, c)
				if typeof(c) == "Color3" then
					vals[1] = math.floor(c.R * 255)
					vals[2] = math.floor(c.G * 255)
					vals[3] = math.floor(c.B * 255)
				elseif type(c) == "table" and c[1] then
					vals[1], vals[2], vals[3] = c[1], c[2], c[3]
				end
				for j = 1, 3 do
					if fills[j] then
						fills[j].Size = UDim2.new(vals[j] / 255, 0, 1, 0)
					end
				end
				push()
			end,
		})
	end

	function section:CreateKeybind(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local flag = opts.Flag
		local def = opts.Default or Enum.KeyCode.Unknown
		local key = def
		if flag then
			local stored = Services.StateService:GetFlag(flag)
			if stored == nil then
				Services.StateService:SetFlag(flag, tostring(def.Name))
			else
				key = Enum.KeyCode[stored] or def
			end
		end

		local card = createControlRowCard(rowsHost, theme, etok, win)
		local row = Utils.Create("Frame", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, etok.Control.KeybindRowHeight + 2),
			Parent = card,
		})
		Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
			Font = Enum.Font.Gotham,
			TextSize = etok.Control.LabelTextSize,
			TextColor3 = theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1, -120, 1, 0),
			Text = opts.Name or "Keybind",
			Parent = row,
		})
		local bindBtn = Utils.Create("TextButton", {
			BackgroundColor3 = theme.Surface,
			Size = UDim2.fromOffset(112, etok.Control.KeybindRowHeight),
			Position = UDim2.new(1, -112, 0.5, 0),
			AnchorPoint = Vector2.new(0, 0.5),
			Font = Enum.Font.GothamMedium,
			TextSize = etok.Control.SecondaryTextSize,
			TextColor3 = theme.Text,
			Text = key.Name ~= "Unknown" and key.Name or "…",
			AutoButtonColor = false,
			Parent = row,
		})
		Utils.Create("UICorner", { CornerRadius = UDim.new(0, etok.Control.DefaultRadius), Parent = bindBtn })
		Utils.Create("UIStroke", { Color = theme.Border, Thickness = 1, Transparency = 0.55, Parent = bindBtn })

		local bindId = "gulle_kb_" .. tostring(_keybindSeq)
		_keybindSeq = _keybindSeq + 1

		local function applyBinding()
			Services.KeybindService:Unbind(bindId)
			if opts.Callback and key and key ~= Enum.KeyCode.Unknown then
				Services.KeybindService:Bind(bindId, key, function()
					task.spawn(opts.Callback, key)
				end)
			end
		end
		applyBinding()

		local conn
		bindBtn.MouseButton1Click:Connect(function()
			bindBtn.Text = "…"
			if conn then
				conn:Disconnect()
			end
			Services.KeybindService:Unbind(bindId)
			conn = UserInputService.InputBegan:Connect(function(input, gp)
				if gp then
					return
				end
				if input.UserInputType == Enum.UserInputType.Keyboard then
					key = input.KeyCode
					bindBtn.Text = key.Name ~= "Unknown" and key.Name or "…"
					conn:Disconnect()
					conn = nil
					if flag then
						Services.StateService:SetFlag(flag, key.Name)
					end
					applyBinding()
					if opts.Callback then
						task.spawn(opts.Callback, key)
					end
				end
			end)
		end)

		return elementApi(card, {
			Set = function(_, kc)
				if typeof(kc) == "EnumItem" and kc.EnumType == Enum.KeyCode then
					key = kc
					bindBtn.Text = key.Name ~= "Unknown" and key.Name or "…"
					if flag then
						Services.StateService:SetFlag(flag, key.Name)
					end
					applyBinding()
				end
			end,
			Get = function()
				return key
			end,
		})
	end

	function section:CreateLabel(opts)
		opts = opts or {}
		local theme, etok = ElemCtx(win)
		local lbl = Utils.Create("TextLabel", {
			BackgroundTransparency = 1,
