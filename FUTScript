local function resolveOwnerFromValue(value)
    if value == nil then
        return nil
    end
    if typeof(value) == "Instance" and value:IsA("Player") then
        return value
    end
    if type(value) == "number" then
        return Players:GetPlayerByUserId(value)
    end
    return nil
end

ballOwnedByPlayer = function(ball)
    if not ball or typeof(ball) ~= "Instance" then
        return false
    end

    local okAttr, attr = pcall(function()
        return ball:GetAttribute("networkOwner")
    end)
    if okAttr and attr ~= nil then
        if attr == player.UserId then
            return true
        end
        local owner = resolveOwnerFromValue(attr)
        if owner then
            return owner == player
        end
    end

    local ownerValue = ball:FindFirstChild("NetworkOwner")
    if ownerValue and ownerValue:IsA("ValueBase") then
        local owner = resolveOwnerFromValue(ownerValue.Value)
        if owner then
            return owner == player
        end
        return ownerValue.Value == player or ownerValue.Value == player.UserId
    end

    if type(isnetworkowner) == "function" then
        local okOwner, owned = pcall(isnetworkowner, ball)
        if okOwner and owned then
            return true
        end
    end

    if ball.Parent == player.Character then
        return true
    end

    return false
end

isNetworkOwnerPart = function(part)
    if type(isnetworkowner) == "function" then
        local ok, res = pcall(isnetworkowner, part)
        if ok then return res end
    end
    return ballOwnedByPlayer(part)
end

hasNetworkOwnership = function(ball)
    if not ball then
        return false
    end

    if type(isnetworkowner) == "function" then
        local okOwner, owned = pcall(isnetworkowner, ball)
        if okOwner and owned then
            return true
        end
    end

    local okAttr, attr = pcall(function()
        return ball:GetAttribute("networkOwner")
    end)
    if okAttr and attr == player.UserId then
        return true
    end

    return ballOwnedByPlayer(ball)
end

isValidTrajectoryBall = function(ball, velocity)
    if not ball or not ball:IsA("BasePart") then return false end
    if ball:FindFirstChild("SAVE") then return false end
    if ball:FindFirstChild("catched") then return false end
    if ball.Material == Enum.Material.Sand then return false end
    if ball:FindFirstChild("Motor6D") then return false end
    if ball:FindFirstChild("OriginalSize") then return false end
    if ball.Parent and ball.Parent:FindFirstChild("UpperTorso") then return false end

    local motionVel = velocity
    if motionVel.Magnitude < config.dribbleSpeedThreshold then
        motionVel = getBallMotionVelocity(ball)
    end

    if isActiveShotBall(ball) or isForcePredictBall(ball) then
        return motionVel.Magnitude >= config.dribbleSpeedThreshold and motionVel ~= CONST.FREEKICK_GATE
    end

    if ball:FindFirstChild("ReactDecline") then return false end
    if motionVel.Magnitude < config.dribbleSpeedThreshold then return false end
    if motionVel == CONST.FREEKICK_GATE then return false end
    return true
end

