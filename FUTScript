--##AUTO GOAL##

local function resolveAutoGoalZone()
    if type(mods.autoGoalZone) == "string" and table.find(AUTO_GOAL_ZONES, mods.autoGoalZone) then
        return mods.autoGoalZone
    end

    if type(mods.autoGoalZone) == "number" then
        local idx = math.clamp(math.floor(mods.autoGoalZone + 0.5), 1, #AUTO_GOAL_ZONES)
        return AUTO_GOAL_ZONES[idx]
    end

    return "random_bins"
end

local function jitterGoalTarget(pos, horizontal, vertical)
    return pos + Vector3.new(
        (math.random() - 0.5) * horizontal * 2,
        (math.random() - 0.5) * vertical,
        (math.random() - 0.5) * horizontal * 2
    )
end

local function getAutoGoalTarget(netModel, zone)
    local collide = getNetCollide(netModel)
    if collide then
        if zone == "random_bins" then
            zone = ({ "top_left", "top_right", "top_center" })[math.random(1, 3)]
        end

        if zone == "top_left" then
            return getTopCornerFromCollide(collide, "L")
        elseif zone == "top_right" then
            return getTopCornerFromCollide(collide, "R")
        elseif zone == "top_center" then
            return getCrossbarTarget(collide)
        elseif zone == "random_box" then
            return jitterGoalTarget(
                collide.Position + Vector3.new(0, collide.Size.Y * 0.2, 0),
                mods.autoGoalSpread,
                mods.autoGoalSpread
            )
        end
    end

    local bounds = netBounds[netModel]
    if not bounds then return nil end

    local minV, maxV = bounds.min, bounds.max
    local margin = 1.25
    local spread = mods.autoGoalSpread

    local lowX, highX = minV.X + margin, maxV.X - margin
    local lowZ, highZ = minV.Z + margin, maxV.Z - margin
    local topY = maxV.Y - margin
    local midX = (minV.X + maxV.X) * 0.5
    local midZ = (minV.Z + maxV.Z) * 0.5

    if zone == "random_bins" then
        zone = ({ "top_left", "top_right", "top_center" })[math.random(1, 3)]
    end

    if zone == "top_left" then
        return jitterGoalTarget(Vector3.new(lowX, topY, midZ), spread, spread * 0.5)
    elseif zone == "top_right" then
        return jitterGoalTarget(Vector3.new(highX, topY, midZ), spread, spread * 0.5)
    elseif zone == "top_center" then
        return jitterGoalTarget(Vector3.new(midX, topY, midZ), spread * 0.6, spread * 0.35)
    elseif zone == "random_box" then
        local upperY = minV.Y + (maxV.Y - minV.Y) * 0.5
        return Vector3.new(
            lowX + math.random() * math.max(0.1, highX - lowX),
            upperY + math.random() * math.max(0.1, topY - upperY),
            lowZ + math.random() * math.max(0.1, highZ - lowZ)
        )
    end

    return jitterGoalTarget(Vector3.new(midX, topY, midZ), spread, spread * 0.5)
end

local function getAutoGoalPreviewTarget()
    if next(netBounds) == nil then
        refreshNetParts()
    end

    local net = resolveAutoGoalNet(getAutoGoalPreviewFromPos(), Vector3.new(0, 0, -1))
    if not net then
        return nil
    end

    local zone = resolveAutoGoalZone()
    if zone == "random_bins" then
        zone = "top_center"
    end

    return getAutoGoalTarget(net, zone)
end

local function canModifyShot(ball, constraint)
    if constraint and constraint.Name == "ShootVelocity" then
        local character = player.Character
        if character and (character:FindFirstChild("Shoot") or character:FindFirstChild("Pass")) then
            return true
        end
    end

    if not ball or typeof(ball) ~= "Instance" or not ball:IsA("BasePart") then
        return constraint ~= nil and constraint.Name == "ShootVelocity"
    end

    if ball.Parent == Engine or ball.Parent == player.Character then
        local character = player.Character
        if character then
            if character:FindFirstChild("Shoot") or character:FindFirstChild("Pass") then
                return true
            end
            if character:FindFirstChild("Ball") == ball then
                return true
            end
        end
    end

    local ok, allowed = pcall(function()
        return ballOwnedByPlayer(ball) or isNetworkOwnerPart(ball)
    end)
    return ok and allowed == true
end

local function getGoalNet(fromPos, velocity)
    if next(netBounds) == nil then
        refreshNetParts()
    end

    local teamSide = resolveAutoGoalTeam()
    local preferred = getNetModelByTeam(teamSide)
    if preferred then
        return preferred
    end

    local pitch = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Pitch")
    local netsFolder = pitch and pitch:FindFirstChild("Nets")
    if not netsFolder then return nil end

    local candidates = {}
    for _, name in { "EfNeth", "EfNeta" } do
        local net = netsFolder:FindFirstChild(name)
        if net and netBounds[net] then
            table.insert(candidates, net)
        end
    end

    if #candidates == 0 then
        refreshNetParts()
        for _, name in { "EfNeth", "EfNeta" } do
            local net = netsFolder:FindFirstChild(name)
            if net and netBounds[net] then
                table.insert(candidates, net)
            end
        end
    end

    if #candidates == 0 then return nil end
    if #candidates == 1 then return candidates[1] end

    local velDir = velocity.Magnitude > 1 and velocity.Unit or nil
    local best, bestScore = candidates[1], -math.huge

    for _, net in candidates do
        local center = netBounds[net].center
        local toNet = center - fromPos
        local score = velDir and velDir:Dot(toNet.Unit) or toNet.Magnitude
        if score > bestScore then
            bestScore = score
            best = net
        end
    end

    return best
end

local function getAutoGoalShotTarget(ball, velocity)
    local existing = autoGoalState.paths[ball]
    if existing and existing.target then
        return existing.target
    end

    local net = resolveAutoGoalNet(ball.Position, velocity)
    if not net then
        return nil
    end

    if autoGoalState.lockedTarget and autoGoalState.lockedNet == net then
        return autoGoalState.lockedTarget
    end

    return getAutoGoalTarget(net, resolveAutoGoalZone())
end

local function lockAutoGoalShotTarget(ball, target, velocity)
    autoGoalState.lockedTarget = target
    autoGoalState.lockedNet = resolveAutoGoalNet(ball.Position, velocity)
end

--##SHOT TAMPER##
local function safeRemoveBallForce(force)
    if not force or not force.Parent then
        return
    end

    pcall(function()
        if force:IsA("BodyForce") then
            force.Force = Vector3.zero
        elseif force:IsA("VectorForce") then
            force.Force = Vector3.zero
        end
    end)

    task.defer(function()
        pcall(function()
            if force.Parent then
                force:Destroy()
            end
        end)
    end)
end

local function stripNamedForces(ball, names)
    for _, name in names do
        local force = ball:FindFirstChild(name)
        if force then
            safeRemoveBallForce(force)
        end
    end
end

local function shouldStripForceChild(child)
    return child.Name == "CurveForce" or child.Name == "RisingForce" or child.Name == "BodyForce"
end

local function shouldStripAutoGoalForceChild(child)
    if mods.knuckleShotsEnabled then
        return child.Name == "CurveForce" or child.Name == "RisingForce"
    end
    return child.Name == "RisingForce" or child.Name == "BodyForce"
end

local function getKnuckleAxes()
    local character = player.Character
    if not character then
        return Vector3.xAxis, Vector3.yAxis
    end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then
        return Vector3.xAxis, Vector3.yAxis
    end

    return root.CFrame.RightVector, root.CFrame.UpVector
end

local function getKnucklePowerScale()
    return math.clamp(mods.knucklePulsePower, 0.3, 3)
end

local function getKnuckleSpinScale()
    return math.clamp(mods.knuckleSpinPower, 0.2, 3)
end

local function getKnuckleSpinVector()
    return CONST.KNUCKLE_SPIN * getKnuckleSpinScale()
end

local function getKnucklePulseMagnitude(minBase, maxBase)
    local power = getKnucklePowerScale()
    return math.random(
        math.floor(minBase * power),
        math.floor(maxBase * power)
    )
end

local function getKnucklePulseDuration()
    local power = getKnucklePowerScale()
    return CONST.KNUCKLE_PULSE_DURATION * math.clamp(0.8 + power * 0.2, 0.8, 1.6)
end

local function stripCurveForceForKnuckle(ball)
    if not ball or not ball.Parent then
        return
    end

    local curve = ball:FindFirstChild("CurveForce")
    if curve then
        safeRemoveBallForce(curve)
    end
end

local function applyKnuckleSpin(ball)
    if not ball or not ball.Parent then
        return
    end

    stripCurveForceForKnuckle(ball)

    local spin = ball:FindFirstChild("SpinForce")
    if spin and spin:IsA("BodyAngularVelocity") then
        spin.AngularVelocity = getKnuckleSpinVector()
    end
end

local function createKnucklePulse(ball, direction, magnitude)
    if not ball or not ball.Parent or direction.Magnitude < 0.01 then
        return
    end

    local force = Instance.new("BodyForce")
    force.Name = "FUT_KnucklePulse"
    force.Force = direction.Unit * magnitude
    force.Parent = ball
    Debris:AddItem(force, getKnucklePulseDuration())
end

local function isKnuckleShotAborted(ball)
    return not ball
        or not ball.Parent
        or ball:FindFirstChild("no")
        or not knuckleShotState.active[ball]
end

local function stopKnuckleShot(ball)
    knuckleShotState.active[ball] = nil
end

local function runGameKnucklePulses(ball)
    local right, up = getKnuckleAxes()
    local gap = math.clamp(mods.knucklePulseGap, 0.15, 0.7)
    local power = getKnucklePowerScale()

    if math.random(1, 2) == 1 then
        createKnucklePulse(ball, right, getKnucklePulseMagnitude(90, 100))
        task.wait(gap)
        if isKnuckleShotAborted(ball) then
            return
        end

        createKnucklePulse(ball, right, -getKnucklePulseMagnitude(90, 100))
        task.wait(gap)
        if isKnuckleShotAborted(ball) then
            return
        end

        createKnucklePulse(ball, right, getKnucklePulseMagnitude(90, 100))
        if power >= 2 then
            task.wait(gap)
            if isKnuckleShotAborted(ball) then
                return
            end
            createKnucklePulse(ball, up, -getKnucklePulseMagnitude(70, 95))
        end
        return
    end

    createKnucklePulse(ball, right, -getKnucklePulseMagnitude(80, 100))
    task.wait(gap)
    if isKnuckleShotAborted(ball) then
        return
    end

    createKnucklePulse(ball, right, getKnucklePulseMagnitude(80, 100))
    task.wait(gap)
    if isKnuckleShotAborted(ball) then
        return
    end

    createKnucklePulse(ball, up, -getKnucklePulseMagnitude(80, 100))
    if power >= 2.5 then
        task.wait(gap)
        if isKnuckleShotAborted(ball) then
            return
        end
        createKnucklePulse(ball, right, getKnucklePulseMagnitude(75, 95))
    end
end

local function beginGameKnuckleShot(ball)
    if not mods.knuckleShotsEnabled or not ball or not ball.Parent then
        return
    end

    local existing = knuckleShotState.active[ball]
    if existing and tick() - (existing.startedAt or 0) < 0.35 then
        return
    end

    knuckleShotState.active[ball] = { startedAt = tick() }
    applyKnuckleSpin(ball)

    task.spawn(function()
        task.wait(math.clamp(mods.knucklePulseDelay, 0.15, 0.8))
        if isKnuckleShotAborted(ball) then
            stopKnuckleShot(ball)
            return
        end

        runGameKnucklePulses(ball)
        task.delay(getKnucklePulseDuration() + 0.05, function()
            stopKnuckleShot(ball)
        end)
    end)
end

local function bindKnuckleShotWatcher(ball)
    if knuckleShotState.watched[ball] then
        return
    end

    knuckleShotState.watched[ball] = true
    trackConnection(ball.ChildAdded:Connect(function(child)
        if not mods.knuckleShotsEnabled or not isScriptAlive() then
            return
        end

        if child.Name == "CurveForce" then
            task.defer(function()
                if child.Parent and mods.knuckleShotsEnabled then
                    safeRemoveBallForce(child)
                end
            end)
        elseif child.Name == "SpinForce" and child:IsA("BodyAngularVelocity") then
            child.AngularVelocity = getKnuckleSpinVector()
        end
    end))
end

local function applyKnuckleShotMods(ball, isShootVelocity)
    if not mods.knuckleShotsEnabled or not isShootVelocity then
        return
    end

    bindKnuckleShotWatcher(ball)
    beginGameKnuckleShot(ball)
end

local function applyAutoGoalShotPhysics(ball, state)
    if not ball or not ball.Parent then
        return
    end

    if mods.knuckleShotsEnabled then
        stripCurveForceForKnuckle(ball)
        local rising = ball:FindFirstChild("RisingForce")
        if rising then
            safeRemoveBallForce(rising)
        end

        local spin = ball:FindFirstChild("SpinForce")
        if spin and spin:IsA("BodyAngularVelocity") then
            spin.AngularVelocity = getKnuckleSpinVector()
        end
        return
    end

    local rising = ball:FindFirstChild("RisingForce")
    if rising then
        safeRemoveBallForce(rising)
    end

    for _, child in ball:GetChildren() do
        if child.Name == "BodyForce" and child:IsA("BodyForce") then
            safeRemoveBallForce(child)
        end
    end

    local curve = ball:FindFirstChild("CurveForce")
    if curve then
        safeRemoveBallForce(curve)
    end

    local curveSide = state and state.curveSide or 1
    local spin = ball:FindFirstChild("SpinForce")
    if spin and spin:IsA("BodyAngularVelocity") then
        spin.AngularVelocity = Vector3.new(0, CONST.FINESSE_SPIN.Y * 0.5, CONST.FINESSE_SPIN.Z * 0.5 * curveSide)
    end
end

local function stripShotCurve(ball)
    stripNamedForces(ball, CONST.STRIP_FORCE_NAMES)

    local spin = ball:FindFirstChild("SpinForce")
    if spin and spin:IsA("BodyAngularVelocity") then
        spin.AngularVelocity = Vector3.new(0, 0.4, 0)
    end
end

local function isAutoGoalControlledBall(ball)
    return autoGoalState.paths[ball] ~= nil or autoGoalState.claimed[ball] == true
end

local function claimAutoGoalBall(ball)
    if not ball then
        return
    end
    autoGoalState.claimed[ball] = true
end

local function releaseAutoGoalBall(ball)
    if ball then
        autoGoalState.claimed[ball] = nil
    end
end

local function setBallVelocity(ball, constraint, velocity)
    if constraint and constraint.Parent then
        setConstraintVelocity(constraint, velocity)
    end
    if ball and ball.Parent then
        ball.AssemblyLinearVelocity = velocity
    end
end

local function quadraticBezier(t, p0, p1, p2)
    local inv = 1 - t
    return inv * inv * p0 + 2 * inv * t * p1 + t * t * p2
end

local function buildAutoGoalPath(ballPos, targetPos)
    local delta = targetPos - ballPos
    if delta.Magnitude < 1 then
        return ballPos, ballPos, targetPos, {
            outside = false,
            flatDist = 0,
            curve = 0,
            curveSide = 1,
            pathTime = mods.autoGoalPathTime,
        }
    end

    local foot = getCurrentFoot()
    local side = foot == "L" and -1 or 1
    local curvePower = mods.autoGoalCurve * side
    local flat = Vector3.new(delta.X, 0, delta.Z)
    local flatDist = flat.Magnitude

    local curveDir
    if flatDist > 0.1 then
        curveDir = delta.Unit:Cross(Vector3.yAxis).Unit
    else
        curveDir = Vector3.xAxis * side
    end

    local control = (targetPos + ballPos) * 0.5
        + curveDir * curvePower
        + Vector3.new(0, math.abs(curvePower), 0)

    return ballPos, control, targetPos, {
        outside = not isInsidePitchBoxAt(ballPos),
        flatDist = flatDist,
        curve = curvePower,
        curveSide = side,
        pathTime = mods.autoGoalPathTime,
    }
end

local function resolveBiggieAutoGoalSpeed(p0, p1, p2, pathTime, fallbackSpeed)
    local steps = math.max(math.ceil(pathTime / 0.01), 1)
    local stepTime = pathTime / steps
    local pos0 = quadraticBezier(0, p0, p1, p2)
    local pos1 = quadraticBezier(1 / steps, p0, p1, p2)
    local segmentSpeed = (pos1 - pos0).Magnitude / math.max(stepTime, 0.001)
    return math.clamp(
        math.max(segmentSpeed, fallbackSpeed * 0.9),
        config.shotSpeedThreshold,
        700
    )
end

local function resolveAutoGoalSpeed(baseSpeed, p0, p1, p2, pathTime)
    return resolveBiggieAutoGoalSpeed(p0, p1, p2, pathTime, math.max(baseSpeed, config.shotSpeedThreshold))
end

local function bindAutoGoalForceStripper(ball, state)
    if state.forceConn then
        return
    end

    state.forceConn = ball.ChildAdded:Connect(function(child)
        if not autoGoalState.paths[ball] then
            return
        end
        if child.Name == "SpinForce" and child:IsA("BodyAngularVelocity") then
            if mods.knuckleShotsEnabled then
                child.AngularVelocity = getKnuckleSpinVector()
            else
                local curveSide = state.curveSide or 1
                child.AngularVelocity = Vector3.new(0, CONST.FINESSE_SPIN.Y * 0.5, CONST.FINESSE_SPIN.Z * 0.5 * curveSide)
            end
            return
        end
        if child.Name == "CurveForce" then
            safeRemoveBallForce(child)
            return
        end
        if not shouldStripAutoGoalForceChild(child) then
            return
        end

        local elapsed = tick() - (state.startTime or tick())
        if elapsed < 0.08 then
            task.delay(0.08 - elapsed, function()
                if autoGoalState.paths[ball] == state and child.Parent then
                    if child.Name == "SpinForce" and child:IsA("BodyAngularVelocity") then
                        if mods.knuckleShotsEnabled then
                            child.AngularVelocity = getKnuckleSpinVector()
                        else
                            local curveSide = state.curveSide or 1
                            child.AngularVelocity = Vector3.new(0, CONST.FINESSE_SPIN.Y * 0.5, CONST.FINESSE_SPIN.Z * 0.5 * curveSide)
                        end
                    elseif child.Name == "CurveForce" then
                        safeRemoveBallForce(child)
                    else
                        safeRemoveBallForce(child)
                    end
                end
            end)
            return
        end

        safeRemoveBallForce(child)
    end)
    trackConnection(state.forceConn)
end

local function getSmoothAutoGoalVelocity(ball, state, elapsed, dt)
    local duration = math.max(state.duration, 0.01)
    local step = dt or CONST.AUTO_GOAL_TICK
    local t = math.clamp(elapsed / duration, 0, 1)
    local tNext = math.clamp((elapsed + step) / duration, 0, 1)

    local pathPos = quadraticBezier(t, state.p0, state.p1, state.p2)
    local pathNext = quadraticBezier(tNext, state.p0, state.p1, state.p2)
    local tangent = pathNext - pathPos

    if tangent.Magnitude < 0.01 then
        tangent = state.target - pathPos
    end
    if tangent.Magnitude < 0.01 then
        return state.smoothVel or state.launchVel or Vector3.zero
    end

    local stepTime = math.max((tNext - t) * duration, 0.001)
    local pathSpeed = tangent.Magnitude / stepTime
    local speed = math.clamp(pathSpeed, state.speed * 0.92, state.speed * 1.08)
    local pathVel = tangent.Unit * speed

    local current = state.smoothVel or state.launchVel or pathVel
    local blended = current:Lerp(pathVel, 0.58)

    if blended.Magnitude > 1 then
        blended = blended.Unit * speed
    end

    state.smoothVel = blended
    return blended
end

local function getAutoGoalLaunchVelocity(state)
    local steps = math.max(math.ceil(state.duration / 0.01), 1)
    local tStep = 1 / steps
    local pos0 = quadraticBezier(0, state.p0, state.p1, state.p2)
    local pos1 = quadraticBezier(tStep, state.p0, state.p1, state.p2)
    local tangent = pos1 - pos0

    if tangent.Magnitude < 0.05 then
        local toTarget = state.target - state.p0
        if toTarget.Magnitude < 0.5 then
            return state.launchVel or Vector3.zero
        end
        tangent = toTarget
    end

    return tangent.Unit * state.speed
end

local function beginAutoGoalPath(ball, velocity, target)
    claimAutoGoalBall(ball)
    lockAutoGoalShotTarget(ball, target, velocity)

    local p0, p1, p2, profile = buildAutoGoalPath(ball.Position, target)
    local now = tick()
    local duration = profile.pathTime
    local speed = resolveAutoGoalSpeed(velocity.Magnitude, p0, p1, p2, duration)
    local state = {
        p0 = p0,
        p1 = p1,
        p2 = p2,
        target = target,
        startTime = now,
        lastUpdate = now,
        duration = duration,
        speed = speed,
        launchVel = velocity,
        launchSpeed = velocity.Magnitude,
        outsideBox = profile.outside,
        curveSide = profile.curveSide,
        smoothVel = velocity,
        deadline = now + duration + 0.25,
    }

    autoGoalState.paths[ball] = state
    bindAutoGoalForceStripper(ball, state)
    showAutoGoalMarker(target, false)
    applyAutoGoalShotPhysics(ball, state)
    applyKnuckleShotMods(ball, true)
end

clearAutoGoalPath = function(ball)
    local state = autoGoalState.paths[ball]
    if state and state.forceConn then
        pcall(function()
            state.forceConn:Disconnect()
        end)
    end
    autoGoalState.paths[ball] = nil
    releaseAutoGoalBall(ball)
    autoGoalState.lockedTarget = nil
    autoGoalState.lockedNet = nil
end

local function applyAutoGoalReactVector(rConfig, ball, vector)
    local target = getAutoGoalShotTarget(ball, vector)
    if not target then
        return false
    end

    beginAutoGoalPath(ball, vector, target)
    local state = autoGoalState.paths[ball]
    if not state then
        return false
    end

    local guided = getAutoGoalLaunchVelocity(state)
    rConfig.vector = guided
    state.launchVel = guided
    state.launchSpeed = guided.Magnitude
    state.smoothVel = guided
    applyAutoGoalShotPhysics(ball, state)

    return true
end

manipulateReactVector = function(rConfig)
    local ball = rConfig.ball
    local vector = rConfig.vector
    if not ball or not vector or vector.Magnitude < 1 then
        return
    end

    if not hasNetworkOwnership(ball) and networkState.Network then
        task.spawn(acquireNetworkOwnership, ball, { timeout = 0.6, pivot = true })
    end

    if mods.autoGoalEnabled and applyAutoGoalReactVector(rConfig, ball, vector) then
        return
    end

    if mods.autoGoalEnabled then
        return
    end

    if mods.insanePowerEnabled then
        rConfig.vector = applyShotPowerScale(vector, mods.insanePower, mods.insaneHeight)
        powerState.reactBoosted[ball] = tick()
    end
end

runVelocityTamperLoop = function()
    if shotTamperState.connection then
        return
    end

    shotTamperState.connection = RunService.Heartbeat:Connect(function()
        if not isScriptAlive() then
            return
        end

        if mods.autoGoalEnabled and next(autoGoalState.paths) then
            local now = tick()
            if now - shotTamperState.lastAutoGoal >= CONST.AUTO_GOAL_TICK then
                shotTamperState.lastAutoGoal = now

                for ball, state in autoGoalState.paths do
                    if not ball.Parent or now > (state.deadline or 0) then
                        clearAutoGoalPath(ball)
                        continue
                    end

                    applyAutoGoalShotPhysics(ball, state)

                    local elapsed = now - state.startTime
                    state.lastUpdate = now
                    local vel = getSmoothAutoGoalVelocity(ball, state, elapsed, CONST.AUTO_GOAL_TICK)
                    state.smoothVel = vel

                    local sv = ball:FindFirstChild("ShootVelocity")
                    if sv and sv.Parent then
                        setConstraintVelocity(sv, vel)
                    end
                    ball.AssemblyLinearVelocity = vel
                end
            end
        elseif next(autoGoalState.paths) then
            for ball, _ in autoGoalState.paths do
                clearAutoGoalPath(ball)
            end
            table.clear(autoGoalState.paths)
            table.clear(autoGoalState.claimed)
        end
    end)

    trackConnection(shotTamperState.connection)
end

local function applyAutoGoal(ball, constraint, velocity)
    if not mods.autoGoalEnabled or not canModifyShot(ball, constraint) then
        return velocity
    end

    claimAutoGoalBall(ball)

    local target = getAutoGoalShotTarget(ball, velocity)
    if not target then
        releaseAutoGoalBall(ball)
        return velocity
    end

    if not autoGoalState.paths[ball] then
        beginAutoGoalPath(ball, velocity, target)
    end

    local state = autoGoalState.paths[ball]
    if not state then
        return velocity
    end

    local elapsed = tick() - state.startTime
    applyAutoGoalShotPhysics(ball, state)

    local pathVel = getSmoothAutoGoalVelocity(ball, state, elapsed, CONST.AUTO_GOAL_TICK)
    if pathVel.Magnitude < 1 then
        return velocity
    end

    setBallVelocity(ball, constraint, pathVel)
    applyKnuckleShotMods(ball, true)
    return pathVel
end

local function applyInsanePowerToShot(ball, constraint, velocity)
    if not mods.insanePowerEnabled then
        return velocity
    end
    if velocity.Magnitude < 1 then
        return velocity
    end

    local boosted = applyShotPowerScale(velocity, mods.insanePower, mods.insaneHeight)
    setBallVelocity(ball, constraint, boosted)
    return boosted
end

local function applyShotMods(ball, constraint, velocity)
    local isShootVelocity = constraint.Name == "ShootVelocity"
    if not isShootVelocity and velocity.Magnitude < config.shotSpeedThreshold then
        return velocity
    end
    if not canModifyShot(ball, constraint) then
        return velocity
    end

    if mods.autoGoalEnabled then
        return applyAutoGoal(ball, constraint, velocity)
    end

    local result = velocity

    if mods.insanePowerEnabled then
        local reactBoosted = powerState.reactBoosted[ball]
        local boostedFromReact = reactBoosted and tick() - reactBoosted < 0.2

        if isShootVelocity then
            if not boostedFromReact then
                if velocity.Magnitude >= 1 then
                    result = applyInsanePowerToShot(ball, constraint, velocity)
                else
                    task.defer(function()
                        if not constraint.Parent or not mods.insanePowerEnabled then
                            return
                        end
                        local vel = getConstraintVelocity(constraint)
                        if vel and vel.Magnitude >= 1 then
                            applyInsanePowerToShot(ball, constraint, vel)
                        end
                    end)
                end
            end
            powerState.reactBoosted[ball] = nil
        elseif velocity.Magnitude >= config.shotSpeedThreshold then
            result = applyInsanePowerToShot(ball, constraint, velocity)
        end
    end

    applyKnuckleShotMods(ball, isShootVelocity)
    return result
end

local function onVelocityAdded(ball, constraint, tracked)
    if not (constraint:IsA("BodyVelocity") or constraint:IsA("LinearVelocity")) then return end

    local isGK = isGKConstraint(constraint)
    local seen = isGK and tracked.gk or tracked.shot
    if seen[constraint] then return end
    seen[constraint] = true

    constraint.AncestryChanged:Once(function()
        seen[constraint] = nil
    end)

    if isGK then return end

    local velocity = getConstraintVelocity(constraint)
    if not velocity then return end

    local isShot = constraint.Name == "ShootVelocity"
        or velocity.Magnitude >= config.shotSpeedThreshold

    if isShot then
        applyShotMods(ball, constraint, velocity)
    end
end

setupBallPrediction = function(ball)
    if not ball:IsA("BasePart") or trackedBalls[ball] then return end

    local tracked = { gk = {}, shot = {} }
    trackedBalls[ball] = tracked

    local function onVelocity(constraint)
        onVelocityAdded(ball, constraint, tracked)
    end

    trackConnection(ball.ChildAdded:Connect(function(child)
        if not isScriptAlive() then return end
        onVelocity(child)
        if child.Name == "ShootVelocity" and child:IsA("BodyVelocity") then
            markShotPredict(ball, 2.5)
        end
    end))
    for _, child in ball:GetChildren() do
        onVelocity(child)
    end
end

