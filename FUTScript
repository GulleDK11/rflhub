local function findGameRoot()
    if gameRoot.root then
        return true
    end
    if type(getgc) ~= "function" then
        return false
    end

    for _, object in getgc(true) do
        if type(object) == "table"
            and rawget(object, "react")
            and rawget(object, "gkReact")
            and rawget(object, "gkCheck")
        then
            gameRoot.root = object
            gameRoot.react = rawget(object, "react")
            gameRoot.gkReact = rawget(object, "gkReact")
            gameRoot.catch = rawget(object, "catch")
            return true
        end
    end

    return false
end

local function installReactManipulator()
    if gameRoot.manipulatorInstalled or type(gameRoot.react) ~= "function" then
        return
    end
    if type(getfenv) ~= "function" or type(setfenv) ~= "function" then
        return
    end

    local reactFn = gameRoot.react
    local reactEnv = getfenv(reactFn)
    gameRoot.reactEnv = reactEnv

    local wrapClosure = newcclosure or function(fn)
        return fn
    end

    local SMath = setmetatable({
        min = function(...)
            local args = { ... }
            if #args == 2 then
                return args[1]
            end
            return math.min(...)
        end,
        max = function(...)
            local args = { ... }
            if #args == 2 then
                return args[2]
            end
            return math.max(...)
        end,
    }, { __index = math })

    local STask = setmetatable({
        delay = function(time, ...)
            if time == 0.1 then
                return
            end
            return task.delay(time, ...)
        end,
    }, { __index = task })

    local reactMt = reactEnv and getrawmetatable and getrawmetatable(reactEnv) or nil
    if reactMt then
        pcall(function()
            reactMt.__eq = wrapClosure(function()
                return true
            end)
        end)
    end

    local spoofEnv = setmetatable({
        math = SMath,
        task = STask,
        assert = wrapClosure(function(...)
            local rConfig = select(1, ...)
            if type(rConfig) == "table" and rConfig.vector and rConfig.ball then
                manipulateReactVector(rConfig)
            end
        end),
        script = rawget(reactEnv, "script"),
        _G = rawget(reactEnv, "_G"),
        shared = rawget(reactEnv, "shared"),
    }, reactMt or { __index = reactEnv })

    pcall(function()
        setfenv(reactFn, spoofEnv)
    end)

    gameRoot.manipulatorInstalled = true
    gameRoot.revertManipulator = function()
        if gameRoot.reactEnv then
            pcall(function()
                setfenv(reactFn, gameRoot.reactEnv)
            end)
        end
        gameRoot.manipulatorInstalled = false
    end
end

local function patchGameReact()
    if gameRoot.patched or not gameRoot.root then
        return
    end

    local patchConstant = debug and debug.setconstant or setconstant
    local getConsts = debug and debug.getconstants or getconstants
    if type(patchConstant) ~= "function" or type(getConsts) ~= "function" then
        return
    end

    local reactFlags = {
        ignoreReactDecline = true,
        specialTool = true,
        exemptShielding = true,
        fromReflex = true,
        bypassChecks = true,
        overlapCheck = true,
    }

    for _, fn in { gameRoot.react, gameRoot.gkReact, gameRoot.catch } do
        if type(fn) == "function" then
            pcall(function()
                for idx, val in getConsts(fn) do
                    if reactFlags[val] then
                        patchConstant(fn, idx, val == "overlapCheck" and "getLookVector" or "ball")
                    elseif type(val) == "number" and (val == 3.25 or val == 8 or val == 4.05 or val == 3.2) then
                        patchConstant(fn, idx, 9999)
                    end
                end
            end)
        end
    end

    gameRoot.patched = true
    installReactManipulator()
end

