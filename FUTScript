goalTarget:Header({ Text = "Targeting" })
goalTarget:Toggle({
    Name = "Auto Goal",
    Default = false,
    Callback = function(v)
        mods.autoGoalEnabled = v
        if not v then
            for ball, _ in autoGoalState.paths do
                clearAutoGoalPath(ball)
            end
            table.clear(autoGoalState.paths)
            table.clear(autoGoalState.claimed)
            autoGoalState.lockedTarget = nil
            autoGoalState.lockedNet = nil
            if autoGoalState.marker then
                pcall(function() autoGoalState.marker:Destroy() end)
                autoGoalState.marker = nil
            end
            clearAutoGoalPreview()
            clearGoalPostESP()
            clearAutoGoalFolder()
        else
            refreshNetParts()
        end
    end,
}, "AutoGoal")
macDropdown(goalTarget, {
    name = "Goal Target",
    items = { "Opposite", "Closest", "Home", "Away", "Own" },
    default = "Opposite",
    callback = function(v)
        mods.autoGoalTarget = v
    end,
    flag = "GoalTarget",
})
macDropdown(goalTarget, {
    name = "Target Mode",
    items = { "Random Bin", "Top Left", "Top Right", "Center Crossbar", "Random Box" },
    default = "Random Bin",
    callback = function(v)
        for _, option in AUTO_GOAL_ZONE_OPTIONS do
            if option.label == v then
                mods.autoGoalZone = option.value
                return
            end
        end
        mods.autoGoalZone = "random_bins"
    end,
    flag = "GoalZone",
})
macToggle(goalTarget, {
    name = "Show Marker",
    default = true,
    callback = function(v)
        mods.autoGoalShowMarker = v
        if not v then
            clearAutoGoalPreview()
            clearGoalPostESP()
        end
    end,
    flag = "AutoGoalShowMarker",
})

