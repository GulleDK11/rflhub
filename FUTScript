--##AUTO GOAL##
local AUTO_GOAL_ZONES = { "random_bins", "top_left", "top_right", "top_center", "random_box" }
local AUTO_GOAL_ZONE_OPTIONS = {
    { label = "Random Bin", value = "random_bins" },
    { label = "Top Left", value = "top_left" },
    { label = "Top Right", value = "top_right" },
    { label = "Center Crossbar", value = "top_center" },
    { label = "Random Box", value = "random_box" },
}

local function resolveAutoGoalZone()
    if type(mods.autoGoalZone) == "string" and table.find(AUTO_GOAL_ZONES, mods.autoGoalZone) then
        return mods.autoGoalZone
    end

    if type(mods.autoGoalZone) == "number" then
        local idx = math.clamp(math.floor(mods.autoGoalZone + 0.5), 1, #AUTO_GOAL_ZONES)
        return AUTO_GOAL_ZONES[idx]
    end

    return "top_center"
end

local function jitterGoalTarget(pos, horizontal, vertical)
    return pos + Vector3.new(
        (math.random() - 0.5) * horizontal * 2,
        (math.random() - 0.5) * vertical,
        (math.random() - 0.5) * horizontal * 2
    )
end

local function getAutoGoalTarget(netModel, zone)
    local collide = getNetCollide(netModel)
    if collide then
        if zone == "random_bins" then
            zone = ({ "top_left", "top_right", "top_center" })[math.random(1, 3)]
        end

        if zone == "top_left" then
            return getTopCornerFromCollide(collide, "L")
        elseif zone == "top_right" then
            return getTopCornerFromCollide(collide, "R")
        elseif zone == "top_center" then
            return getCrossbarTarget(collide)
        elseif zone == "random_box" then
            return jitterGoalTarget(
                collide.Position + Vector3.new(0, collide.Size.Y * 0.2, 0),
                mods.autoGoalSpread,
                mods.autoGoalSpread
            )
        end
    end

    local bounds = netBounds[netModel]
    if not bounds then return nil end

    local minV, maxV = bounds.min, bounds.max
    local margin = 1.25
    local spread = mods.autoGoalSpread

    local lowX, highX = minV.X + margin, maxV.X - margin
    local lowZ, highZ = minV.Z + margin, maxV.Z - margin
    local topY = maxV.Y - margin
    local midX = (minV.X + maxV.X) * 0.5
    local midZ = (minV.Z + maxV.Z) * 0.5

    if zone == "random_bins" then
        zone = ({ "top_left", "top_right", "top_center" })[math.random(1, 3)]
    end

    if zone == "top_left" then
        return jitterGoalTarget(Vector3.new(lowX, topY, midZ), spread, spread * 0.5)
    elseif zone == "top_right" then
        return jitterGoalTarget(Vector3.new(highX, topY, midZ), spread, spread * 0.5)
    elseif zone == "top_center" then
        return jitterGoalTarget(Vector3.new(midX, topY, midZ), spread * 0.6, spread * 0.35)
    elseif zone == "random_box" then
        local upperY = minV.Y + (maxV.Y - minV.Y) * 0.5
        return Vector3.new(
            lowX + math.random() * math.max(0.1, highX - lowX),
            upperY + math.random() * math.max(0.1, topY - upperY),
            lowZ + math.random() * math.max(0.1, highZ - lowZ)
        )
    end

    return jitterGoalTarget(Vector3.new(midX, topY, midZ), spread, spread * 0.5)
end

