    local settingsConfig = macSection(settingsTab, "Left")
    settingsConfig:Header({ Text = "Configs" })
    settingsConfig:Paragraph({
        Header = "Overseer Configs",
        Body = "MacLib config API not found in this build. Using Overseer file configs instead.",
    })
    settingsConfig:Input({
        Name = "Config Name",
        Placeholder = "default",
        AcceptedCharacters = function(text)
            return text:gsub("[^%w%-_]", "")
        end,
        Callback = function(text)
            configState.pendingName = sanitizeConfigName(text)
        end,
        onChanged = function(text)
            configState.pendingName = sanitizeConfigName(text)
        end,
    })
    settingsConfig:Button({
        Name = "Save Config",
        Callback = function()
            if saveOverseerConfig(configState.pendingName) then
                notifyConfig("Saved config: " .. sanitizeConfigName(configState.pendingName))
            else
