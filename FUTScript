        return "Home"
    end
    return "Away"
end

local function resolveAutoGoalTeam()
    local myTeam = getPlayerTeamSide()
    local target = mods.autoGoalTarget

    if target == "Own" then
        return myTeam
    elseif target == "Home" then
        return "Home"
    elseif target == "Away" then
        return "Away"
    end

    return myTeam == "Home" and "Away" or "Home"
end

local function getNetModelByTeam(teamSide)
    local pitch = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Pitch")
    local netsFolder = pitch and pitch:FindFirstChild("Nets")
    if not netsFolder then
        return nil
    end

    for netName, mappedTeam in CONST.NET_TEAM_MAP do
        if mappedTeam == teamSide then
            local net = netsFolder:FindFirstChild(netName)
            if net then
                ensureNetBounds(net)
                return net
            end
        end
    end

    return nil
end

