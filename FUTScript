local function getBallsInReachBox(root, offset, size, compMode)
    local validBalls = getValidBalls()
    if #validBalls == 0 or not root then
        return nil, {}
    end

    local boxCFrame = root.CFrame * offset
    local balls = {}

    if type(firetouchinterest) == "function" then
        local overlap = OverlapParams.new()
        overlap.FilterType = Enum.RaycastFilterType.Include
        overlap.FilterDescendantsInstances = validBalls

        local success, bounds = pcall(function()
            return workspace:GetPartBoundsInBox(boxCFrame, size, overlap)
        end)

        if success and bounds and #bounds > 0 then
            table.sort(bounds, function(a, b)
                return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
            end)

            local target = getReachTarget(bounds, compMode)
            if target then
                table.insert(balls, target)
            end

            for _, ball in bounds do
                if ball ~= target and not table.find(balls, ball) then
                    table.insert(balls, ball)
                end
            end

            return target, balls
        end
    end

    local half = size * 0.5
    local nearestDist = math.huge
    local target = nil

    for _, ball in validBalls do
        local rel = boxCFrame:PointToObjectSpace(ball.Position)
        if math.abs(rel.X) <= half.X
            and math.abs(rel.Y) <= half.Y
            and math.abs(rel.Z) <= half.Z
        then
            if compMode and hasNetworkOwnership(ball) then
                continue
            end

            table.insert(balls, ball)
            local dist = (ball.Position - root.Position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                target = ball
            end
        end
    end

    return target, balls
end

local function applyBallPullVector(root, ball, dt)
    if not mods.pullVectorEnabled or not root or not ball then
        return
    end

    if not isCatchableBall(ball) or hasNetworkOwnership(ball) then
        return
    end

    local offset = root.Position - ball.Position
    local dist = offset.Magnitude
    if dist <= 0.05 or dist > mods.pullDistance then
        return
    end

    local closeness = 1 - (dist / mods.pullDistance)
    local pullDir = offset.Unit
    local yLift = ball.Position.Y > root.Position.Y and 0.35 or 0
    local pull = Vector3.new(pullDir.X, pullDir.Y + yLift, pullDir.Z)
        * mods.pullStrength
        * closeness
        * math.max(dt, 1 / 60)
        * 60

    pcall(function()
        ball.AssemblyLinearVelocity = ball.AssemblyLinearVelocity + pull
    end)
end

