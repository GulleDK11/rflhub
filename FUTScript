--##PING SPOOFER##
local pingState = {
    hooked = false,
    oldNamecall = nil,
    lastSpoof = 0,
    current = nil,
    target = nil,
    lastRetarget = 0,
}

local function getPingBounds()
    local minPing = math.min(mods.pingMin, mods.pingMax)
    local maxPing = math.max(mods.pingMin, mods.pingMax)
    return minPing, maxPing
end

local function getRealisticSpoofedPing()
    local minPing, maxPing = getPingBounds()
    if minPing == maxPing then
        return math.round(minPing)
    end

    local now = tick()
    if not pingState.current then
        pingState.current = minPing + math.random() * (maxPing - minPing)
        pingState.target = pingState.current
        pingState.lastRetarget = now
    end

    if now - pingState.lastRetarget >= math.random(1.8, 4.2) then
        local center = (minPing + maxPing) * 0.5
        local spread = (maxPing - minPing) * 0.45
        pingState.target = math.clamp(
            center + (math.random() - 0.5) * spread * 2,
            minPing,
            maxPing
        )
        pingState.lastRetarget = now
    end

    local drift = (pingState.target - pingState.current) * 0.22
    local jitter = (math.random() - 0.5) * 2.4
    if math.random() < 0.08 then
        jitter += (math.random() - 0.5) * 6
    end

    pingState.current = math.clamp(pingState.current + drift + jitter, minPing, maxPing)
    return math.round(pingState.current)
end

local function setupPingSpoof()
    if pingState.hooked or not PingEvent then return end

    if hookmetamethod and getnamecallmethod then
        pingState.oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if mods.pingSpoof and self == PingEvent and method == "FireServer" then
                return pingState.oldNamecall(self, getRealisticSpoofedPing())
            end
            return pingState.oldNamecall(self, ...)
        end)
        pingState.hooked = true
        return
    end

    table.insert(connections, RunService.Heartbeat:Connect(function()
        if not isScriptAlive() then return end
        if mods.pingSpoof and PingEvent and tick() - pingState.lastSpoof >= 0.5 then
            pingState.lastSpoof = tick()
            pcall(function()
                PingEvent:FireServer(getRealisticSpoofedPing())
            end)
        end
    end))
    pingState.hooked = true
end

