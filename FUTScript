local function buildKnuckleAxes(direction)
    local horiz = Vector3.new(direction.X, 0, direction.Z)
    local flatDir = horiz.Magnitude > 0.01 and horiz.Unit or Vector3.new(0, 0, -1)
    local right = flatDir:Cross(Vector3.yAxis)
    if right.Magnitude < 0.01 then
        right = Vector3.xAxis
    else
        right = right.Unit
    end
    return flatDir, right
end

local function buildKnuckleGoalCorridor(launchPos, flatDir, right, netModel)
    local bounds = netModel and ensureNetBounds(netModel)
    if not bounds then
        return {
            aimPoint = launchPos + flatDir * 70,
            center = launchPos + flatDir * 70,
            goalDist = 70,
            lateralMax = 5,
            verticalMax = 3.5,
            offsetRightMax = 0.11,
            offsetUpMax = 0.09,
        }
    end

    local minV, maxV = bounds.min, bounds.max
    local center = bounds.center
    local goalWidth = math.max(maxV.X - minV.X, maxV.Z - minV.Z)
    local goalHeight = maxV.Y - minV.Y
    local halfW = goalWidth * 0.5
    local halfH = goalHeight * 0.5

    local toCenter = center - launchPos
    local goalDist = math.max(flatDir:Dot(toCenter), 35)
    local aimPoint = launchPos + flatDir * goalDist

    local aimOffRight = right:Dot(aimPoint - center)
    local aimOffUp = aimPoint.Y - center.Y

    local lateralMax = math.max(1.5, (halfW - math.abs(aimOffRight)) * 0.8)
    local verticalMax = math.max(1.2, (halfH - math.abs(aimOffUp)) * 0.75)

    return {
        aimPoint = aimPoint,
        center = center,
        goalDist = goalDist,
        lateralMax = lateralMax,
        verticalMax = verticalMax,
        offsetRightMax = math.clamp(lateralMax * 0.095, 0.045, 0.16),
        offsetUpMax = math.clamp(verticalMax * 0.11, 0.035, 0.13),
    }
end

local function initKnuckleFlight(scaled)
    local speed = scaled.Magnitude
    local pitch = math.asin(math.clamp(scaled.Y / speed, -0.28, 0.28))
    local launchY = math.sin(pitch) * speed
    local horizSpeed = math.cos(pitch) * speed
    local flatDir, right = buildKnuckleAxes(scaled)
    return {
        speed = speed,
        launchY = launchY,
        horizSpeed = horizSpeed,
        flatDir = flatDir,
        right = right,
        offsetRight = 0,
        offsetUp = 0,
        breakIndex = 0,
        nextBreakAt = 0.16 + knuckleRand(speed) * 0.14,
        breakSeed = speed * 0.37 + launchY,
    }
end

local function applyKnuckleGoalGuard(state, ballPos, dt)
    local corridor = state.corridor
    if not corridor or not ballPos or not state.launchPos then
        return
    end

    local traveled = (ballPos - state.launchPos):Dot(state.flatDir)
    local progress = math.clamp(traveled / math.max(corridor.goalDist, 8), 0, 1)
    local guard = progress * progress

    local offRight = state.right:Dot(ballPos - corridor.aimPoint)
    local offUp = ballPos.Y - corridor.aimPoint.Y

    if math.abs(offRight) > corridor.lateralMax * 0.55 then
        state.offsetRight = state.offsetRight - knuckleSign(offRight) * guard * dt * 2.4
    end
    if math.abs(offUp) > corridor.verticalMax * 0.5 then
        state.offsetUp = state.offsetUp - knuckleSign(offUp) * guard * dt * 2.0
    end

    state.offsetRight = math.clamp(state.offsetRight, -corridor.offsetRightMax, corridor.offsetRightMax)
    state.offsetUp = math.clamp(state.offsetUp, -corridor.offsetUpMax, corridor.offsetUpMax)
end

local function stepKnuckleOffsets(state, elapsed, dt, ball)
    while elapsed >= state.nextBreakAt and state.breakIndex < 14 do
        local seed = state.breakSeed + state.breakIndex * 1.73
        local flipL = knuckleRand(seed) > 0.5 and 1 or -1
        local flipV = knuckleRand(seed + 6.4) > 0.5 and 1 or -1

        if state.breakIndex > 0 and knuckleRand(seed + 4.1) > 0.55 then
            flipL = -flipL
        end
        if knuckleRand(seed + 8.2) > 0.6 then
            flipV = -flipV
        end

        local breakL = mods.powerKnuckleIntensity * 0.009 * (0.55 + knuckleRand(seed + 1.9) * 0.95)
        local breakV = mods.powerKnuckleIntensity * 0.0075 * (0.45 + knuckleRand(seed + 3.3) * 0.9)

        state.offsetRight = state.offsetRight + flipL * breakL
        state.offsetUp = state.offsetUp + flipV * breakV

        if knuckleRand(seed + 5.5) > 0.68 then
            state.offsetUp = state.offsetUp + flipV * breakV * (0.8 + knuckleRand(seed + 9.1) * 0.6)
        end
        if knuckleRand(seed + 2.2) > 0.72 then
            state.offsetRight = state.offsetRight + flipL * breakL * 0.65
        end

        state.breakIndex = state.breakIndex + 1
        state.nextBreakAt = elapsed + 0.11 + knuckleRand(seed + 2.7) * 0.22
    end

    local decay = math.exp(-2.6 * dt)
    state.offsetRight = state.offsetRight * decay
    state.offsetUp = state.offsetUp * decay

    if ball and ball.Parent then
        applyKnuckleGoalGuard(state, ball.Position, dt)
    end
end

local function getKnuckleFlutterScalars(state, elapsed, fadeScale)
    local fade = math.clamp(1 - (elapsed / math.max(mods.powerKnuckleTime, 0.1)), 0.35, 1) * (fadeScale or 1)
    local flutterR = (
        math.sin(elapsed * 6.4 + state.breakSeed) * 0.55
        + math.sin(elapsed * 11.2 + state.breakSeed * 0.7) * 0.3
    ) * mods.powerKnuckleIntensity * 0.00042 * fade
    local flutterU = (
        math.cos(elapsed * 5.3 + state.breakSeed * 1.2) * 0.6
        + math.sin(elapsed * 9.7 + state.breakSeed * 0.5) * 0.35
    ) * mods.powerKnuckleIntensity * 0.00038 * fade
    local lateralScale = mods.powerKnuckleIntensity * 0.00115
    local verticalScale = mods.powerKnuckleIntensity * 0.00105
    return flutterR, flutterU, lateralScale, verticalScale, fade
end

local function initAutoGoalKnuckleState(agState, ball, velocity, target)
    local flatDir, right = buildKnuckleAxes(velocity)
    local goalDist = (target - ball.Position).Magnitude
    agState.knuckle = {
        offsetRight = 0,
        offsetUp = 0,
        breakIndex = 0,
        nextBreakAt = 0.16 + knuckleRand(velocity.Magnitude) * 0.14,
        breakSeed = velocity.Magnitude * 0.37 + velocity.Y,
        lastElapsed = nil,
        flatDir = flatDir,
        right = right,
        launchPos = ball.Position,
        corridor = {
            aimPoint = target,
            goalDist = math.max(goalDist, 20),
            lateralMax = 2.6,
            verticalMax = 2.1,
            offsetRightMax = 0.072,
            offsetUpMax = 0.062,
        },
    }
end

local function layerKnuckleOnAutoGoal(homingVel, kState, ball, elapsed, dt)
    local stepDt = math.max(
        kState.lastElapsed and (elapsed - kState.lastElapsed) or CONST.AUTO_GOAL_TICK,
        0.02
    )
    kState.lastElapsed = elapsed

    stepKnuckleOffsets(kState, elapsed, stepDt, ball)

    local flatDir, right = buildKnuckleAxes(homingVel)
    kState.flatDir = flatDir
    kState.right = right

    local speed = math.max(homingVel.Magnitude, 1)
    local flutterR, flutterU, lateralScale, verticalScale, fade = getKnuckleFlutterScalars(kState, elapsed, 0.9)

    local bentDir = flatDir + right * (kState.offsetRight * lateralScale + flutterR)
    if bentDir.Magnitude > 0.01 then
        bentDir = bentDir.Unit
    else
        bentDir = flatDir
    end

    local yVel = homingVel.Y + kState.offsetUp * speed * verticalScale + flutterU * speed
    local horizMag = Vector3.new(homingVel.X, 0, homingVel.Z).Magnitude
    if horizMag < 1 then
        horizMag = speed * 0.85
    end

    local flutterVel = Vector3.new(bentDir.X * horizMag, yVel, bentDir.Z * horizMag)
    local mix = math.clamp(0.2 + fade * 0.38, 0.22, 0.52)
    return homingVel:Lerp(flutterVel, mix)
end

local function computeCustomKnuckleVelocity(state, elapsed, ball)
    local dt = math.max(
        state.lastElapsed and (elapsed - state.lastElapsed) or CONST.KNUCKLE_TICK,
        0.02
    )
    state.lastElapsed = elapsed

    stepKnuckleOffsets(state, elapsed, dt, ball)

    local fade = math.clamp(1 - (elapsed / math.max(mods.powerKnuckleTime, 0.1)), 0.4, 1)
    local flutterR, flutterU, lateralScale, verticalScale = getKnuckleFlutterScalars(state, elapsed, 1)

    local bentDir = state.flatDir + state.right * (state.offsetRight * lateralScale + flutterR)
    if bentDir.Magnitude > 0.01 then
        bentDir = bentDir.Unit
    else
        bentDir = state.flatDir
    end

    local baseY = state.launchY - elapsed * 1.35
    local yVel = baseY + state.offsetUp * state.speed * verticalScale + flutterU * state.speed

    local horizMag = math.sqrt(math.max(state.speed * state.speed - yVel * yVel, 0))
    if horizMag < 1 then
        horizMag = state.horizSpeed * fade
    end

    return Vector3.new(bentDir.X * horizMag, yVel, bentDir.Z * horizMag)
end

local function setBallVelocity(ball, constraint, velocity)
    if constraint and constraint.Parent then
        setConstraintVelocity(constraint, velocity)
    end
    if ball and ball.Parent then
        ball.AssemblyLinearVelocity = velocity
    end
end

local function bindKnuckleForceStripper(ball, state)
    if state.forceConn then
        return
    end

    state.forceConn = ball.ChildAdded:Connect(function(child)
        if not knuckleState.active[ball] then
            return
        end
        if shouldStripForceChild(child) then
            safeRemoveBallForce(child)
        end
    end)
    trackConnection(state.forceConn)
end

local function beginKnuckleShot(ball, constraint, velocity)
    if not ball or typeof(ball) ~= "Instance" or not ball:IsA("BasePart") then
        return velocity
    end

    local now = tick()
    local existing = knuckleState.active[ball]
    if existing and now < existing.deadline and (now - existing.startedAt) < 0.35 then
        if constraint and constraint.Parent then
            existing.constraint = constraint
        end
        return computeCustomKnuckleVelocity(existing, os.clock() - existing.start, ball)
    end

    stripShotCurve(ball)

    local scaled = applyKnuckleShotScale(velocity, mods.knucklePower, mods.knuckleHeight)
    if scaled.Magnitude < config.shotSpeedThreshold then
        scaled = scaled.Magnitude > 0.1
            and scaled.Unit * config.shotSpeedThreshold
            or velocity.Unit * config.shotSpeedThreshold
    end

    local flight = initKnuckleFlight(scaled)
    local targetNet = getNetFromShotDirection(ball.Position, scaled)
    local corridor = buildKnuckleGoalCorridor(ball.Position, flight.flatDir, flight.right, targetNet)

    local state = {
        ball = ball,
        launchPos = ball.Position,
        corridor = corridor,
        speed = flight.speed,
        launchY = flight.launchY,
        horizSpeed = flight.horizSpeed,
        flatDir = flight.flatDir,
        right = flight.right,
        offsetRight = flight.offsetRight,
        offsetUp = flight.offsetUp,
        breakIndex = flight.breakIndex,
        nextBreakAt = flight.nextBreakAt,
        breakSeed = flight.breakSeed,
        start = os.clock(),
        startedAt = now,
        deadline = now + mods.powerKnuckleTime,
        constraint = constraint,
        lastVel = nil,
        lastElapsed = nil,
    }

    knuckleState.active[ball] = state
    bindKnuckleForceStripper(ball, state)

    if constraint and constraint.Parent then
        state.constraint = constraint
    elseif ball.Parent then
        state.constraint = ball:FindFirstChild("ShootVelocity")
    end

    local vel = computeCustomKnuckleVelocity(state, 0, ball)
    state.lastVel = vel
    setBallVelocity(ball, state.constraint, vel)
    return vel
end

local function quadraticBezier(t, p0, p1, p2)
    local inv = 1 - t
    return inv * inv * p0 + 2 * inv * t * p1 + t * t * p2
end

local function smoothstep(t)
    t = math.clamp(t, 0, 1)
    return t * t * (3 - 2 * t)
end

local function buildAutoGoalCurve(startPos, targetPos)
    local delta = targetPos - startPos
    if delta.Magnitude < 1 then
        return startPos, startPos, targetPos
    end

    local direction = delta.Unit
    local foot = getCurrentFoot()
    local side = foot == "L" and -1 or 1
    local curvePower = mods.autoGoalCurve * side * 0.55
    local curveDir = direction:Cross(Vector3.yAxis)
    if curveDir.Magnitude < 0.01 then
        curveDir = Vector3.xAxis
    else
        curveDir = curveDir.Unit
    end

    local control = (startPos + targetPos) * 0.5
        + curveDir * curvePower
        + Vector3.new(0, math.min(mods.autoGoalHeight * 0.08, 6), 0)

    return startPos, control, targetPos
end

local function resolveAutoGoalSpeed(baseSpeed)
    return math.clamp(
        math.max(baseSpeed, config.shotSpeedThreshold) * mods.autoGoalSpeed,
        config.shotSpeedThreshold,
        300
    )
end

local function bindAutoGoalForceStripper(ball, state)
    if state.forceConn then
        return
    end

    state.forceConn = ball.ChildAdded:Connect(function(child)
        if not autoGoalState.paths[ball] then
            return
        end
        if not shouldStripForceChild(child) then
            return
        end

        local elapsed = tick() - (state.startTime or tick())
        if elapsed < 0.08 then
            task.delay(0.08 - elapsed, function()
                if autoGoalState.paths[ball] == state and child.Parent then
                    safeRemoveBallForce(child)
                end
            end)
            return
        end

        safeRemoveBallForce(child)
    end)
    trackConnection(state.forceConn)
end

local function getSmoothAutoGoalVelocity(ball, state, elapsed, dt)
    local duration = math.max(state.duration, 0.1)
    local rawT = math.clamp(elapsed / duration, 0, 1)
    local t = smoothstep(rawT)

    local steerBlend = smoothstep(math.clamp(elapsed / (state.launchBlend or 0.32), 0, 1))
    local lookT = math.clamp(t + 0.12 * steerBlend, 0, 1)
    local aimPoint = quadraticBezier(lookT, state.p0, state.p1, state.p2)
    if rawT > 0.45 then
        local homeBlend = ((rawT - 0.45) / 0.55) ^ 1.35
        aimPoint = aimPoint:Lerp(state.p2, homeBlend)
    end

    local toTarget = aimPoint - ball.Position
    if toTarget.Magnitude < 0.75 then
        toTarget = state.p2 - ball.Position
    end
    if toTarget.Magnitude < 0.25 then
        return state.smoothVel or state.launchVel or Vector3.zero
    end

    local dist = toTarget.Magnitude
    local launchSpeed = state.launchSpeed or state.speed
    local speed = launchSpeed + (state.speed - launchSpeed) * steerBlend
    speed = math.min(speed, dist / math.max(dt, CONST.AUTO_GOAL_TICK) * 0.9)

    local pathDir = toTarget.Unit
    local launchVel = state.launchVel
    local launchDir = launchVel and launchVel.Magnitude > 1 and launchVel.Unit or pathDir
    local blendedDir = launchDir:Lerp(pathDir, steerBlend)
    if blendedDir.Magnitude < 0.01 then
        blendedDir = pathDir
    else
        blendedDir = blendedDir.Unit
    end

    local targetVel = blendedDir * speed
    local alpha = 1 - math.exp(-10 * math.max(dt, 1 / 240))
    state.smoothVel = (state.smoothVel or launchVel or targetVel):Lerp(targetVel, alpha)
    local vel = state.smoothVel

    if mods.autoGoalKnuckle and state.knuckle then
        vel = layerKnuckleOnAutoGoal(vel, state.knuckle, ball, elapsed, dt)
        state.smoothVel = vel
    end

    return vel
end

local function beginAutoGoalPath(ball, velocity, target)
    local p0, p1, p2 = buildAutoGoalCurve(ball.Position, target)
    local now = tick()
    local speed = resolveAutoGoalSpeed(velocity.Magnitude)
    local distance = (target - ball.Position).Magnitude
    local duration = math.clamp(math.max(mods.autoGoalPathTime, distance / math.max(speed, 1) * 0.95), 0.7, 2.4)
    local state = {
        p0 = p0,
        p1 = p1,
        p2 = p2,
        target = target,
        startTime = now,
        lastUpdate = now,
        duration = duration,
        speed = speed,
        launchVel = velocity,
        launchSpeed = velocity.Magnitude,
        launchBlend = 0.32,
        smoothVel = velocity,
        deadline = now + duration + 0.45,
    }

    autoGoalState.paths[ball] = state
    bindAutoGoalForceStripper(ball, state)
    showAutoGoalMarker(target, false)

    if mods.autoGoalKnuckle then
        initAutoGoalKnuckleState(state, ball, velocity, target)
    end

    task.delay(0.08, function()
        if autoGoalState.paths[ball] == state then
            stripShotCurveForAutoGoal(ball)
        end
    end)
end

local function clearAutoGoalPath(ball)
    local state = autoGoalState.paths[ball]
    if state and state.forceConn then
        pcall(function()
            state.forceConn:Disconnect()
        end)
    end
    autoGoalState.paths[ball] = nil
end

local function manipulateReactVector(rConfig)
    local ball = rConfig.ball
    local vector = rConfig.vector
    if not ball or not vector or vector.Magnitude < 1 then
        return
    end

    if not hasNetworkOwnership(ball) and networkState.Network then
        task.spawn(acquireNetworkOwnership, ball, { timeout = 0.6, pivot = true })
    end

    if mods.autoGoalEnabled then
        local target = getAutoGoalShotTarget(ball, vector)
        if target then
            beginAutoGoalPath(ball, vector, target)
            return
        end
    end

    if mods.powerKnuckleEnabled then
        rConfig.vector = beginKnuckleShot(ball, nil, vector)
        return
    end

    if mods.insanePowerEnabled then
        stripRisingForce(ball)
        local boosted = applyShotPowerScale(vector, mods.insanePower, mods.insaneHeight)
        rConfig.vector = boosted
        beginInsanePowerMaintain(ball, boosted)
    end
end

local function runVelocityTamperLoop()
    if shotTamperState.connection then
        return
    end

    shotTamperState.connection = RunService.Heartbeat:Connect(function()
        if not isScriptAlive() then
            return
        end

        if mods.autoGoalEnabled and next(autoGoalState.paths) then
            local now = tick()
            if now - shotTamperState.lastAutoGoal >= CONST.AUTO_GOAL_TICK then
                shotTamperState.lastAutoGoal = now

                for ball, state in autoGoalState.paths do
                    if not ball.Parent or now > (state.deadline or 0) then
                        clearAutoGoalPath(ball)
                        continue
                    end

                    local elapsed = now - state.startTime
                    local dt = math.max(now - (state.lastUpdate or now), CONST.AUTO_GOAL_TICK)
                    state.lastUpdate = now
                    local vel = getSmoothAutoGoalVelocity(ball, state, elapsed, dt)

                    local sv = ball:FindFirstChild("ShootVelocity")
                    if sv and sv.Parent then
                        setConstraintVelocity(sv, vel)
                    end
                    ball.AssemblyLinearVelocity = vel
                end
            end
        elseif next(autoGoalState.paths) then
            table.clear(autoGoalState.paths)
        end

        if mods.powerKnuckleEnabled and next(knuckleState.active) then
            local now = tick()
            if now - shotTamperState.lastKnuckle >= CONST.KNUCKLE_TICK then
                shotTamperState.lastKnuckle = now

                for ball, state in knuckleState.active do
                    if not ball.Parent or now > (state.deadline or 0) then
                        stopKnuckle(ball)
                        continue
                    end

                    local elapsed = os.clock() - state.start
                    local vel = computeCustomKnuckleVelocity(state, elapsed, ball)
                    state.lastVel = vel

                    local sv = state.constraint
                    if not sv or not sv.Parent then
                        sv = ball:FindFirstChild("ShootVelocity")
                        state.constraint = sv
                    end

                    if sv and sv.Parent then
                        setConstraintVelocity(sv, vel)
                    end
                    ball.AssemblyLinearVelocity = vel
                end
            end
        elseif next(knuckleState.active) then
            table.clear(knuckleState.active)
        end

        if mods.insanePowerEnabled and not mods.autoGoalEnabled and not mods.powerKnuckleEnabled then
            for ball, state in powerState.maintain do
                if not ball.Parent or tick() > (state.deadline or 0) then
                    powerState.maintain[ball] = nil
                    continue
                end

                stripRisingForce(ball)
                local sv = ball:FindFirstChild("ShootVelocity")
                setBallVelocity(ball, sv, state.vel)
            end
        elseif next(powerState.maintain) then
            table.clear(powerState.maintain)
        end
    end)

    trackConnection(shotTamperState.connection)
end

local function applyAutoGoal(ball, constraint, velocity)
    if not mods.autoGoalEnabled or not canModifyShot(ball, constraint) then
        return velocity
    end

    local target = getAutoGoalShotTarget(ball, velocity)
    if not target then
        return velocity
    end

    if not autoGoalState.paths[ball] then
        beginAutoGoalPath(ball, velocity, target)
    end

    local state = autoGoalState.paths[ball]
    if not state then
        return velocity
    end

    local elapsed = tick() - state.startTime
    if elapsed < 0.1 then
        state.smoothVel = velocity
        return velocity
    end

    local pathVel = getSmoothAutoGoalVelocity(ball, state, elapsed, CONST.AUTO_GOAL_TICK)
    if pathVel.Magnitude < 1 then
        return velocity
    end

    setBallVelocity(ball, constraint, pathVel)
    return pathVel
end

local function enforceInsanePowerShot(ball, constraint, boostedVelocity)
    if powerState.enforcers[constraint] then
        return
    end
    powerState.enforcers[constraint] = true

    task.spawn(function()
        local deadline = tick() + 0.75
        while constraint.Parent and ball.Parent and tick() < deadline and mods.insanePowerEnabled and isScriptAlive() do
            stripRisingForce(ball)
            setConstraintVelocity(constraint, boostedVelocity)
            ball.AssemblyLinearVelocity = boostedVelocity
            task.wait()
        end
        powerState.enforcers[constraint] = nil
    end)
end

local function applyInsanePowerToShot(ball, constraint, velocity)
    if not mods.insanePowerEnabled then
        return velocity
    end
    if velocity.Magnitude < 1 then
        return velocity
    end

    stripRisingForce(ball)

    local boosted = applyShotPowerScale(velocity, mods.insanePower, mods.insaneHeight)
    setBallVelocity(ball, constraint, boosted)
    beginInsanePowerMaintain(ball, boosted)
    enforceInsanePowerShot(ball, constraint, boosted)

    return boosted
end

local function applyPowerKnuckle(ball, constraint, velocity)
    if not mods.powerKnuckleEnabled or not canModifyShot(ball, constraint) then
        return velocity
    end

    return beginKnuckleShot(ball, constraint, velocity)
end

local function applyShotMods(ball, constraint, velocity)
    local isShootVelocity = constraint.Name == "ShootVelocity"
    if not isShootVelocity and velocity.Magnitude < config.shotSpeedThreshold then
        return velocity
    end
    if not canModifyShot(ball, constraint) then
        return velocity
    end

    if mods.autoGoalEnabled then
        return applyAutoGoal(ball, constraint, velocity)
    end

    if mods.powerKnuckleEnabled then
        return applyPowerKnuckle(ball, constraint, velocity)
    end

    if mods.insanePowerEnabled and (isShootVelocity or velocity.Magnitude >= config.shotSpeedThreshold) then
        return applyInsanePowerToShot(ball, constraint, velocity)
    end

    return velocity
end

local function onVelocityAdded(ball, constraint, tracked)
    if not (constraint:IsA("BodyVelocity") or constraint:IsA("LinearVelocity")) then return end

    local isGK = isGKConstraint(constraint)
    local seen = isGK and tracked.gk or tracked.shot
    if seen[constraint] then return end
    seen[constraint] = true

    constraint.AncestryChanged:Once(function()
        seen[constraint] = nil
    end)

    if isGK then return end

    local velocity = getConstraintVelocity(constraint)
    if not velocity then return end

    local isShot = constraint.Name == "ShootVelocity"
        or velocity.Magnitude >= config.shotSpeedThreshold

    if isShot then
        applyShotMods(ball, constraint, velocity)
    end
end

local function setupBallPrediction(ball)
    if not ball:IsA("BasePart") or trackedBalls[ball] then return end

    local tracked = { gk = {}, shot = {} }
    trackedBalls[ball] = tracked

    local function onVelocity(constraint)
        onVelocityAdded(ball, constraint, tracked)
    end

    trackConnection(ball.ChildAdded:Connect(function(child)
        if not isScriptAlive() then return end
        onVelocity(child)
        if child.Name == "ShootVelocity" and child:IsA("BodyVelocity") then
            predState.forcePredictUntil[ball] = tick() + 2.5
            if config.predictorEnabled then
                task.defer(runPredictionVisualize)
            end
        end
    end))
    for _, child in ball:GetChildren() do
        onVelocity(child)
    end
end

