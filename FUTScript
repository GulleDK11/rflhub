--##NETWORK FORGER##
do

do
local FORGER_REQUIRED = { "getgc", "getfenv", "setfenv", "getupvalues", "getconstants", "newcclosure", "islclosure", "loadstring" }

local function forgerHasCapabilities()
    for _, name in FORGER_REQUIRED do
        if not getfenv()[name] then
            return false, "Missing executor API: " .. name
        end
    end
    return true
end

local function forgerSpoof(callback)
    local dummy
    for _, object in getgc() do
        if typeof(object) == "function" and debug.getinfo(object).source:find("PlayerScripts") and islclosure(object) then
            dummy = getfenv(object)
            break
        end
    end
    if not dummy then
        return nil
    end

    local thread = coroutine.running()
    if setthreadidentity then
        pcall(setthreadidentity, 2)
    end

    local async = function()
        coroutine.resume(thread, callback())
    end

    setfenv(async, dummy)
    setfenv(callback, dummy)
    task.defer(async)

    if setthreadidentity then
        pcall(setthreadidentity, 8)
    end

    return coroutine.yield()
end

local function forgerForgeTable(tableRef)
    return {
        __index = newcclosure(function(_, key)
            return tableRef[key]
        end),
        __newindex = newcclosure(function(_, key, value)
            tableRef[key] = value
        end),
        __tostring = newcclosure(function()
            return tostring(tableRef)
        end),
        __len = newcclosure(function()
            return #tableRef
        end),
        __iter = newcclosure(function()
            return pairs(tableRef)
        end),
    }
end

local function findOriginalNetwork()
    for _, object in getgc(true) do
        if typeof(object) == "table" and rawget(object, "send") and rawget(object, "fetch") and rawget(object, "add") then
            return object
        end
    end
    return nil
end

local function buildNetworkForger(originalNetwork)
    local ok, result = pcall(function()
        return loadstring((function()
            local fakeNumber = {}
            fakeNumber.__index = fakeNumber
            local memory = {}

            local function getValue(n)
                return type(n) == "table" and n.Value or n
            end

            local function getExpression(n)
                if type(n) == "table" then
                    return n.Expression
                end
                return memory[n] or tostring(n)
            end

            local function newNumber(value, expression)
                local self = setmetatable({}, fakeNumber)
                self.Value = value
                self.Expression = expression
                memory[value] = expression
                return self
            end

            fakeNumber.New = newNumber

            function fakeNumber:__add(o)
                local v = getValue(o)
                return newNumber(self.Value + v, "(" .. self.Expression .. " + " .. getExpression(o) .. ")")
            end

            function fakeNumber:__sub(o)
                local v = getValue(o)
                return newNumber(self.Value - v, "(" .. self.Expression .. " - " .. getExpression(o) .. ")")
            end

            function fakeNumber:__mul(o)
                local v = getValue(o)
                return newNumber(self.Value * v, "(" .. self.Expression .. " * " .. getExpression(o) .. ")")
            end

            function fakeNumber:__div(o)
                local v = getValue(o)
                return newNumber(self.Value / v, "(" .. self.Expression .. " / " .. getExpression(o) .. ")")
            end

            function fakeNumber:__mod(o)
                local v = getValue(o)
                return newNumber(self.Value % v, "(" .. self.Expression .. " % " .. getExpression(o) .. ")")
            end

            function fakeNumber:__pow(o)
                local v = getValue(o)
                return newNumber(self.Value ^ v, "(" .. self.Expression .. " ^ " .. getExpression(o) .. ")")
            end

            function fakeNumber:__unm()
                return newNumber(-self.Value, "(-" .. self.Expression .. ")")
            end

            function fakeNumber:__idiv(o)
                local v = getValue(o)
                return newNumber(math.floor(self.Value / v), "(math.floor(" .. self.Expression .. " / " .. getExpression(o) .. "))")
            end

            function fakeNumber:__eq(o)
                return self.Value == getValue(o)
            end

            function fakeNumber:__lt(o)
                return self.Value < getValue(o)
            end

            function fakeNumber:__le(o)
                return self.Value <= getValue(o)
            end

            function fakeNumber:__tostring()
                return tostring(self.Value)
            end

            function fakeNumber.GetMemory()
                return memory
            end

            local spoofedTime = 1000
            local networkEnv = getfenv(originalNetwork.send)

            if #getconstants(originalNetwork.send) < 70 then
                local key = getupvalue(originalNetwork.send, 3)
                return "return function(Time)\n    return " .. tostring(key) .. "\nend"
            end

            local oldDebug = networkEnv.debug
            local oldPcall = networkEnv.pcall
            local oldWorkspace = networkEnv.workspace

            networkEnv.workspace = {
                GetServerTimeNow = function()
                    return newNumber(spoofedTime, tostring(spoofedTime))
                end,
            }

            networkEnv.debug = setmetatable({
                traceback = function()
                    return {
                        gmatch = function()
                            return function() end
                        end,
                    }
                end,
            }, forgerForgeTable(networkEnv.debug))

            networkEnv.pcall = function() end

            local scanned = {}
            local function scan(tbl)
                scanned[tbl] = true
                for _, v in tbl do
                    if type(v) == "table" and not scanned[v] then
                        local results = { scan(v) }
                        if #results > 0 then
                            return unpack(results)
                        end
                    elseif typeof(v) == "Instance" and v:IsA("RemoteEvent") then
                        return tbl
                    end
                end
            end

            local upvalueTable = scan(getupvalues(originalNetwork.send))
            local originalFireServer = rawget(upvalueTable, 1)
            local capturedArgs

            rawset(upvalueTable, 1, function(_, ...)
                capturedArgs = { ... }
            end)

            setfenv(1, networkEnv)
            originalNetwork:send("fut_forge_probe")

            rawset(upvalueTable, 1, originalFireServer)
            networkEnv.workspace = oldWorkspace
            networkEnv.debug = oldDebug
            networkEnv.pcall = oldPcall

            if not capturedArgs or not capturedArgs[1] then
                error("Network forge probe returned no args")
            end

            local spoofedTimeStr = tostring(spoofedTime)
            local data = capturedArgs[1]
            local parts = {}

            for index, value in data do
                parts[#parts + 1] = '      ["' .. index .. '"] = ' .. string.gsub(memory[value.Value], spoofedTimeStr, "Time")
            end

            return "return function(Time)\n    return {\n" .. table.concat(parts, ",\n") .. "\n    }\nend"
        end)())()
    end)

    if not ok then
        return nil, result
    end

    return result
end

local function createForgedNetwork(references, networkForger)
    local function getNetworkKey(time)
        return networkForger(time or workspace:GetServerTimeNow())
    end

    local network = {
        send = function(self, ...)
            return self:_send(workspace:GetServerTimeNow(), ...)
        end,
        _send = function(self, time, ...)
            local remoteEvent = rawget(references, "RemoteEvent")
            if not remoteEvent then
                return
            end
            return remoteEvent:FireServer(getNetworkKey(time), ...)
        end,
        fetch = function(self, ...)
            return self:_fetch(workspace:GetServerTimeNow(), ...)
        end,
        _fetch = function(self, time, ...)
            local remoteFunction = rawget(references, "RemoteFunction")
            if not remoteFunction then
                return
            end
            return remoteFunction:InvokeServer(getNetworkKey(time), ...)
        end,
    }

    return network, getNetworkKey
end

tryInitNetworkForger = function()
    if networkState.ready then
        return true
    end

    local capable, capErr = forgerHasCapabilities()
    if not capable then
        networkState.error = capErr
        networkState.ready = false
        return false
    end

    local originalNetwork = findOriginalNetwork()
    if not originalNetwork then
        networkState.error = "Could not find client network module (send/fetch/add)"
        networkState.ready = false
        return false
    end

    local references = forgerSpoof(function()
        return _G._references
    end)

    if not references then
        networkState.error = "Could not read _G._references (spoof failed)"
        networkState.ready = false
        return false
    end

    local forger, forgeErr = buildNetworkForger(originalNetwork)
    if not forger then
        networkState.error = "Forge build failed: " .. tostring(forgeErr)
        networkState.ready = false
        return false
    end

    local network, getNetworkKey = createForgedNetwork(references, forger)

    networkState.ready = true
    networkState.error = nil
    networkState.Network = network
    networkState.GetNetworkKey = getNetworkKey
    return true
end
end

local function fetchNetworkOwner(ball, options)
    if not networkState.ready or not networkState.Network then
