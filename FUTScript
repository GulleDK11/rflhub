local function absorbPartBounds(minV, maxV, cf, half)
    for _, sign in CONST.CORNER_SIGNS do
        local world = cf:PointToWorldSpace(Vector3.new(half.X * sign.X, half.Y * sign.Y, half.Z * sign.Z))
        minV = Vector3.new(math.min(minV.X, world.X), math.min(minV.Y, world.Y), math.min(minV.Z, world.Z))
        maxV = Vector3.new(math.max(maxV.X, world.X), math.max(maxV.Y, world.Y), math.max(maxV.Z, world.Z))
    end
    return minV, maxV
end

local function getNetCollide(netModel)
    if not netModel then
        return nil
    end

    local direct = netModel:FindFirstChild("Collide")
    if direct and direct:IsA("BasePart") then
        return direct
    end

    for _, desc in netModel:GetDescendants() do
        if desc.Name == "Collide" and desc:IsA("BasePart") then
            return desc
        end
    end

    return nil
end

local function collectNetParts(netModel)
    local collected = {}
    if not netModel then
        return collected
    end

    local partsFolder = netModel:FindFirstChild("parts")
    if partsFolder then
        for _, part in partsFolder:GetChildren() do
            if part:IsA("BasePart") then
                table.insert(collected, part)
            end
        end
    end

    if #collected == 0 then
        local collide = getNetCollide(netModel)
        if collide then
            table.insert(collected, collide)
        end
    end

    return collected
end

local function computeNetBounds(netModel)
    local partList = collectNetParts(netModel)
    if #partList == 0 then
        return nil
    end

    local minV = Vector3.new(math.huge, math.huge, math.huge)
    local maxV = Vector3.new(-math.huge, -math.huge, -math.huge)

    for _, part in partList do
        minV, maxV = absorbPartBounds(minV, maxV, part.CFrame, part.Size * 0.5)
    end

    return {
        min = minV,
        max = maxV,
        center = (minV + maxV) * 0.5,
    }
end

local function refreshNetParts()
    table.clear(netParts)
    table.clear(netBounds)
    table.clear(netPartLookup)

    local nets = workspace:FindFirstChild("Game")
        and workspace.Game:FindFirstChild("Pitch")
        and workspace.Game.Pitch:FindFirstChild("Nets")
    if not nets then return end

    for _, netModel in ipairs({ nets:FindFirstChild("EfNeth"), nets:FindFirstChild("EfNeta") }) do
        if netModel then
            for _, part in collectNetParts(netModel) do
                table.insert(netParts, part)
                netPartLookup[part] = true
            end
            local bounds = computeNetBounds(netModel)
            if bounds then
                netBounds[netModel] = bounds
            end
        end
    end
end

local function ensureNetBounds(netModel)
    if netBounds[netModel] then
        return netBounds[netModel]
    end

    refreshNetParts()
    if netBounds[netModel] then
        return netBounds[netModel]
    end

    local collide = getNetCollide(netModel)
    if not collide then
        return nil
    end

    local half = collide.Size * 0.5
    netBounds[netModel] = {
        min = collide.Position - half,
        max = collide.Position + half,
        center = collide.Position,
    }
    netPartLookup[collide] = true
    if not table.find(netParts, collide) then
        table.insert(netParts, collide)
    end
    return netBounds[netModel]
end

