    local sprint = findSprintState()
    if sprint then
        sprint.Stamina = STAMINA_TARGET
        sprint.CanSprint = true
    end

    local movementStamina = findMovementStaminaValue()
    if movementStamina then
        movementStamina.Value = STAMINA_TARGET
