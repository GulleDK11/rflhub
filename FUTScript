local function applyWidgets(section, widgets)
    for _, w in widgets do
        local t = w.t
        if t == "header" then
            section:Header({ Text = w.text })
        elseif t == "sublabel" then
            section:SubLabel({ Text = w.text })
        elseif t == "divider" then
            section:Divider()
        elseif t == "toggle" then
            section:Toggle({
                Name = w.name,
                Default = w.default,
                Callback = uiCallback(w),
            }, w.flag)
        elseif t == "slider" then
            macSlider(section, {
                name = w.name,
                min = w.min,
                max = w.max,
                default = w.default,
                callback = uiCallback(w),
            }, SLIDER[w.preset or "stud"])
        elseif t == "dropdown" then
            macDropdown(section, {
                name = w.name,
                items = w.items,
                default = w.default,
                callback = uiCallback(w),
                flag = w.flag,
            })
        elseif t == "color" then
            section:Colorpicker({
                Name = w.name,
                Default = w.default,
                Callback = uiCallback(w),
            }, w.flag)
        elseif t == "button" then
            section:Button({ Name = w.name, Callback = uiCallback(w) })
        elseif t == "paragraph" then
            section:Paragraph({ Header = w.header, Body = w.body })
        elseif t == "keybind" then
            local bind = KEYBIND_HANDLERS[w.bind]
            section:Keybind({
                Name = w.name,
                Default = w.default,
                Callback = bind.Callback,
                onBinded = bind.onBinded,
            }, w.flag)
        end
    end
end
