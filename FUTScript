local setupPingSpoof
local resetPingSpoofState

--##PING SPOOFER##
do

local pingState = {
    hooked = false,
    oldNamecall = nil,
    displayPing = nil,
    nextUpdate = 0,
    heartbeatConn = nil,
}

resetPingSpoofState = function()
    pingState.displayPing = nil
    pingState.nextUpdate = 0
end

local function getPingBounds()
    local minPing = math.min(mods.pingMin, mods.pingMax)
    local maxPing = math.max(mods.pingMin, mods.pingMax)
    return minPing, maxPing
end

local function pickSpoofedPing()
    local minPing, maxPing = getPingBounds()
    if minPing == maxPing then
        return math.round(minPing)
    end

    local center = (minPing + maxPing) * 0.5
    local spread = (maxPing - minPing) * 0.45
    return math.round(math.clamp(
        center + (math.random() - 0.5) * spread * 2,
        minPing,
        maxPing
    ))
end

local function getRealisticSpoofedPing()
    local now = tick()
    if pingState.displayPing == nil or now >= pingState.nextUpdate then
        pingState.displayPing = pickSpoofedPing()
        pingState.nextUpdate = now + math.random(4, 5)
    end
    return pingState.displayPing
end

setupPingSpoof = function()
    if not PingEvent then
        return
    end

    if pingState.hooked then
        return
    end

    if hookmetamethod and getnamecallmethod then
        pingState.oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if mods.pingSpoof and self == PingEvent and method == "FireServer" then
                return pingState.oldNamecall(self, getRealisticSpoofedPing())
            end
            return pingState.oldNamecall(self, ...)
        end)
        pingState.hooked = true
        return
    end

    pingState.heartbeatConn = trackConnection(RunService.Heartbeat:Connect(function()
        if not isScriptAlive() then
            return
        end
        if mods.pingSpoof and PingEvent and tick() >= pingState.nextUpdate then
            pcall(function()
                PingEvent:FireServer(getRealisticSpoofedPing())
            end)
        end
    end))
    pingState.hooked = true
end

setupPingSpoof()
end

