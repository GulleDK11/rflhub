local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function getPointColor(point, maxSpeed)
    local accent = config.predictorColor
    if point.hitNet then
        return accent
    end
    if point.time < 0.30 then
        return Color3.fromRGB(255, 70, 70)
    elseif point.time < 0.385 then
        return Color3.fromRGB(60, 255, 120)
    elseif point.hit then
        return Color3.fromRGB(255, 240, 90)
    end
    local t = math.clamp((point.time - 0.385) / math.max(predPhysics.MaxTime - 0.385, 0.001), 0, 1)
    return lerpColor(Color3.fromRGB(255, 255, 255), accent, t)
end

getBallMotionVelocity = function(ball)
    if not ball then
        return Vector3.zero, nil
    end

    local shootVel = ball:FindFirstChild("ShootVelocity")
    if shootVel and shootVel:IsA("BodyVelocity") then
        local velocity = shootVel.Velocity
        if velocity.Magnitude >= config.dribbleSpeedThreshold then
            return velocity, shootVel
        end
    end

    local bodyVel = ball:FindFirstChild("BodyVelocity")
    if bodyVel and bodyVel:IsA("BodyVelocity") then
        local velocity = bodyVel.Velocity
        if velocity.Magnitude >= config.dribbleSpeedThreshold then
            return velocity, bodyVel
        end
    end

    local linearVel = ball:FindFirstChildWhichIsA("LinearVelocity", true)
    if linearVel then
        local velocity = linearVel.VectorVelocity
        if velocity.Magnitude >= config.dribbleSpeedThreshold then
            return velocity, linearVel
        end
    end

    return ball.AssemblyLinearVelocity, nil
end

isActiveShotBall = function(ball)
    local shootVel = ball:FindFirstChild("ShootVelocity")
    return shootVel
        and shootVel:IsA("BodyVelocity")
        and shootVel.Velocity.Magnitude >= config.shotSpeedThreshold
end

local function updateVelocityHistory(ball, now)
    if isActiveShotBall(ball) then
        local history = predState.velocityHistory
        if not history[ball] then
            history[ball] = { samples = {}, lastBigChangeTime = 0, stable = true }
        else
            history[ball].stable = true
            history[ball].lastBigChangeTime = 0
        end
        predState.forcePredictUntil = predState.forcePredictUntil or {}
        predState.forcePredictUntil[ball] = now + 2
        return
    end

    local history = predState.velocityHistory
    if not history[ball] then
        history[ball] = { samples = {}, lastBigChangeTime = 0, stable = false }
    end

    local tracker = history[ball]
    local currentVel = ball.AssemblyLinearVelocity
    local samples = tracker.samples

    table.insert(samples, {
        vel = currentVel,
        speed = currentVel.Magnitude,
        time = now,
    })

    while #samples > predPhysics.VelocityStabilizeFrames + 2 do
        table.remove(samples, 1)
    end

    if #samples < 2 then
        tracker.stable = false
        return
    end

    local prev = samples[#samples - 1]
    local curr = samples[#samples]
    local delta = (curr.vel - prev.vel).Magnitude / math.max(curr.time - prev.time, 0.001)

    if delta > predPhysics.VelocityDeltaThreshold * math.max(curr.speed, 1) then
        tracker.lastBigChangeTime = now
        tracker.stable = false
        return
    end

    tracker.stable = (now - tracker.lastBigChangeTime) >= (predPhysics.VelocityStabilizeFrames / 60)
end

local function isBallStable(ball)
    local tracker = predState.velocityHistory[ball]
    return tracker and tracker.stable
end

local function buildSimState(ball)
    local bav = ball:FindFirstChild("SpinForce") or ball:FindFirstChild("BodyAngularVelocity")
    local shootVelocity = ball:FindFirstChild("ShootVelocity")
    local bodyVelocity = shootVelocity or ball:FindFirstChild("BodyVelocity")

    local state = {
        mass = math.max(ball.AssemblyMass, 0.01),
        density = ball.CustomPhysicalProperties and ball.CustomPhysicalProperties.Density or 1,
        bodyForce = ball:FindFirstChild("CurveForce") or ball:FindFirstChild("RisingForce") or ball:FindFirstChild("BodyForce"),
        curveForce = ball:FindFirstChild("CurveForce"),
        risingForce = ball:FindFirstChild("RisingForce"),
        bodyVelocity = bodyVelocity,
        bodyAngularVelocity = bav,
        vectorForce = ball:FindFirstChild("FUT_KnuckleForce") or ball:FindFirstChildWhichIsA("VectorForce", true),
        linearVelocity = ball:FindFirstChildWhichIsA("LinearVelocity", true),
        initialBodyVelocity = nil,
        hasCurve = false,
        hasBackspin = false,
        direction = "none",
    }

    if state.bodyVelocity then
        state.initialBodyVelocity = state.bodyVelocity.Velocity
    else
        state.initialBodyVelocity = getBallMotionVelocity(ball)
    end

    if bav then
        local angVel = bav.AngularVelocity
        if predPhysics.EnableCurve then
            if angVel.Y > 1 then
                state.direction = "left"
                state.hasCurve = true
            elseif angVel.Y < -1 then
                state.direction = "right"
                state.hasCurve = true
            end
        end
        if predPhysics.EnableBackspin and (math.abs(angVel.X) > 10 or math.abs(angVel.Z) > 10) then
            state.hasBackspin = true
        end
    end

    return state
end

local function getAcceleration(state, velocity, angularVelocity, tNow)
    local accel = Vector3.new(0, -workspace.Gravity, 0)

    if state.curveForce and tNow <= predPhysics.BodyForceDuration then
        accel += state.curveForce.Force / state.mass
    elseif state.risingForce and tNow <= predPhysics.BodyForceDuration then
        accel += state.risingForce.Force / state.mass
    elseif state.bodyForce and tNow <= predPhysics.BodyForceDuration then
        accel += state.bodyForce.Force / state.mass
    end

    if state.vectorForce and (not state.vectorForce:IsA("VectorForce") or state.vectorForce.Enabled ~= false) then
        accel += state.vectorForce.Force / state.mass
    end

    if state.linearVelocity and state.linearVelocity.Enabled then
        accel += (state.linearVelocity.VectorVelocity - velocity) * 20
    end

    if angularVelocity.Magnitude > 0.01 and velocity.Magnitude > 0.01 then
        local magnusEffect = angularVelocity:Cross(velocity) * predPhysics.Magnus
        if state.hasCurve then
            local horizontalSpeed = Vector2.new(velocity.X, velocity.Z).Magnitude
            local right = Vector3.new(velocity.Z, 0, -velocity.X)
            if right.Magnitude > 0.001 then
                local curveDir = right.Unit
                local spinForce = predPhysics.SpinForceMultiplier * (state.density * predPhysics.BallDensity)
                magnusEffect += curveDir * horizontalSpeed * predPhysics.CurveMultiplier * spinForce * 0.001
            end
        end
        accel += magnusEffect
    end

    if predPhysics.Drag > 0 then
        accel -= velocity * predPhysics.Drag
    end

    return accel
end

local function isSurfaceHit(instance)
    if netPartLookup[instance] then
        return true, true
    end

    local name = string.lower(instance.Name)
    return instance == workspace.Terrain
        or (instance:IsA("BasePart") and instance.CanCollide and (
            name == "grass" or name == "outer" or name == "wall" or name == "frame"
            or name == "collide" or name == "support" or name == "support main"
            or name == "support top" or name == "ropes" or name == "pitch"
        )),
        false
end

local function castPath(origin, delta, ignore)
    if delta.Magnitude < 0.001 then
        return nil
    end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true

    local localIgnore = table.clone(ignore)
    for _ = 1, 8 do
        params.FilterDescendantsInstances = localIgnore
        local result = workspace:Raycast(origin, delta, params)
        if not result then
            return nil
        end

        local hit, isNet = isSurfaceHit(result.Instance)
        if hit then
            return result, isNet
        end

        table.insert(localIgnore, result.Instance)
    end

    return nil
end

local function handleBounce(velocity, normal, state, bounceCount)
    local vNormal = normal * velocity:Dot(normal)
    local tangent = velocity - vNormal
    local newTangent = tangent * predPhysics.Friction
    local bounceVel = -(vNormal * predPhysics.Restitution)

    if state.hasBackspin and bounceCount == 0 then
        local r = predPhysics.BackspinBounceReduction
        bounceVel = Vector3.new(bounceVel.X / r[1], bounceVel.Y / r[2], bounceVel.Z / r[3])
        newTangent = Vector3.new(newTangent.X / r[1], newTangent.Y / r[2], newTangent.Z / r[3])
    end

    if bounceVel.Y > predPhysics.GroundBounceHeight then
        bounceVel *= Vector3.new(1, 0.85, 1)
        newTangent *= 0.95
    end

    return bounceVel + newTangent
end

local function predictBallPath(ball)
    local vel = getBallMotionVelocity(ball)
    if vel.Magnitude < config.dribbleSpeedThreshold then
        return {}
    end
    if vel == CONST.FREEKICK_GATE then
        return {}
    end

    local state = buildSimState(ball)
    local points = {}
    local currentTime = 0
    local bounceCount = 0
    local nextVisualTime = 0
    local position = ball.Position
    local velocity = Vector3.new(
        math.clamp(vel.X, -predPhysics.MaxVelocityClamp.X, predPhysics.MaxVelocityClamp.X),
        math.clamp(vel.Y, -predPhysics.MaxVelocityClamp.Y, predPhysics.MaxVelocityClamp.Y),
        math.clamp(vel.Z, -predPhysics.MaxVelocityClamp.Z, predPhysics.MaxVelocityClamp.Z)
    )
    local angularVelocity = (state.bodyAngularVelocity and state.bodyAngularVelocity.AngularVelocity)
        or ball.AssemblyAngularVelocity
    local ignore = { ball }
    local lastAddedPos = position
    local radius = ball.Size.Y * 0.5

    table.insert(points, {
        pos = position,
        time = 0,
        speed = velocity.Magnitude,
        bounce = bounceCount,
        hit = false,
        hitNet = false,
    })

    while currentTime < predPhysics.MaxTime do
        if state.bodyVelocity and state.initialBodyVelocity and currentTime < predPhysics.BvLockTime then
            local yVel = state.initialBodyVelocity.Y + (-workspace.Gravity) * currentTime
            velocity = Vector3.new(state.initialBodyVelocity.X, yVel, state.initialBodyVelocity.Z)
        else
            local accel = getAcceleration(state, velocity, angularVelocity, currentTime)
            velocity = velocity + accel * predPhysics.Step
            velocity = Vector3.new(
                math.clamp(velocity.X, -predPhysics.MaxVelocityClamp.X, predPhysics.MaxVelocityClamp.X),
                math.clamp(velocity.Y, -predPhysics.MaxVelocityClamp.Y, predPhysics.MaxVelocityClamp.Y),
                math.clamp(velocity.Z, -predPhysics.MaxVelocityClamp.Z, predPhysics.MaxVelocityClamp.Z)
            )
        end

        local delta = velocity * predPhysics.Step
        local nextPos = position + delta
        currentTime += predPhysics.Step

        local ray, hitNet = castPath(position, delta, ignore)
        if ray then
            if (ray.Position - lastAddedPos).Magnitude > predPhysics.MinPointDistance then
                table.insert(points, {
                    pos = ray.Position,
                    time = currentTime,
                    speed = velocity.Magnitude,
                    bounce = bounceCount,
                    hit = true,
                    hitNet = hitNet,
                    normal = ray.Normal,
                })
                lastAddedPos = ray.Position
            end

            if hitNet then
                break
            end

            velocity = handleBounce(velocity, ray.Normal, state, bounceCount)
            position = ray.Position + ray.Normal * 0.06
            bounceCount += 1

            if bounceCount > predPhysics.MaxBounces or velocity.Magnitude < predPhysics.MinSpeed then
                break
            end
        else
            position = nextPos
            if position.Y < radius then
                position = Vector3.new(position.X, radius, position.Z)
                table.insert(points, {
                    pos = position,
                    time = currentTime,
                    speed = velocity.Magnitude,
                    bounce = bounceCount,
                    hit = true,
                    hitNet = false,
                })
                break
            end

            if currentTime >= nextVisualTime and (position - lastAddedPos).Magnitude > predPhysics.MinPointDistance then
                table.insert(points, {
                    pos = position,
                    time = currentTime,
                    speed = velocity.Magnitude,
                    bounce = bounceCount,
                    hit = false,
                    hitNet = false,
                })
                lastAddedPos = position
                nextVisualTime = currentTime + predPhysics.VisualStep
            end
        end

        if position.Y < -25 then
            break
        end
    end

    return points
end

local function createPredBeam(p0, p1, maxSpeed)
    local att0 = predState.attachmentTemplate:Clone()
    local att1 = predState.attachmentTemplate:Clone()
    att0.WorldPosition = p0.pos
    att1.WorldPosition = p1.pos
    att0.Parent = visuals.trajectoryFolder
    att1.Parent = visuals.trajectoryFolder

    local beam = Instance.new("Beam")
    beam.Attachment0 = att0
    beam.Attachment1 = att1
    beam.Width0 = predPhysics.BeamWidth
    beam.Width1 = predPhysics.BeamWidth * 0.9
    beam.Color = ColorSequence.new(getPointColor(p0, maxSpeed), getPointColor(p1, maxSpeed))
    beam.FaceCamera = true
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.Transparency = NumberSequence.new(0.12)
    beam.Parent = visuals.trajectoryFolder
end

local function createLandingMarker(worldPos, hitNet)
    local marker = Instance.new("Part")
    marker.Name = hitNet and "GoalZone" or "LandingZone"
    marker.Shape = Enum.PartType.Ball
    marker.Material = Enum.Material.Neon
    marker.Anchored = true
    marker.CanCollide = false
    marker.CastShadow = false
    marker.Color = hitNet and config.predictorColor or Color3.fromRGB(255, 240, 90)
    marker.Transparency = 0.35
    marker.Size = Vector3.new(config.impactRadius * 2, config.impactRadius * 2, config.impactRadius * 2)
    marker.CFrame = CFrame.new(worldPos)
    marker.Parent = visuals.trajectoryFolder
end

runPredictionVisualize = function()
    if not config.predictorEnabled then return end

    local now = tick()
    if now - predState.lastUpdate < predPhysics.UpdateRate then
        return
    end
    predState.lastUpdate = now

    for _, ball in reachState.balls do
        if ball and ball.Parent then
            updateVelocityHistory(ball, now)
        end
    end

    clearTrajectory()

    local folder = Instance.new("Folder")
    folder.Name = "FUT_Prediction"
    folder.Parent = workspace
    visuals.trajectoryFolder = folder

    for _, ball in reachState.balls do
        if not (ball and ball.Parent and ball:IsA("BasePart")) then
            continue
        end

        local vel = getBallMotionVelocity(ball)
        if not isValidTrajectoryBall(ball, vel) then
            continue
        end

        local forceUntil = predState.forcePredictUntil and predState.forcePredictUntil[ball]
        local isForcedShot = forceUntil and tick() < forceUntil

        local points = predictBallPath(ball)
        if #points < 2 then
            continue
        end

        local maxSpeed = 0
        for _, p in points do
            if p.speed > maxSpeed then
                maxSpeed = p.speed
            end
        end

        for i = 1, #points - 1 do
            local p0, p1 = points[i], points[i + 1]
            if (p1.pos - p0.pos).Magnitude >= 0.05 then
                createPredBeam(p0, p1, maxSpeed)
            end
        end

        local endPoint = points[#points]
        createLandingMarker(endPoint.pos, endPoint.hitNet == true)
    end
end

setPredictionEnabled = function(enabled)
    if visuals.predConnection then
        visuals.predConnection:Disconnect()
        visuals.predConnection = nil
    end
    clearTrajectory()
    if enabled and isScriptAlive() then
        visuals.predConnection = trackConnection(RunService.RenderStepped:Connect(runPredictionVisualize))
    end
end
end

