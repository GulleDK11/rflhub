local function quadraticBezier(t, p0, p1, p2)
    local inv = 1 - t
    return inv * inv * p0 + 2 * inv * t * p1 + t * t * p2
end
local function buildAutoGoalPath(ballPos, targetPos)
    local delta = targetPos - ballPos
    if delta.Magnitude < 1 then
        return ballPos, ballPos, targetPos, {
            outside = false,
            flatDist = 0,
            curve = 0,
            curveSide = 1,
            pathTime = mods.autoGoalPathTime,
        }
    end
    local foot = getCurrentFoot()
    local side = foot == "L" and -1 or 1
    local curvePower = mods.autoGoalCurve * side
    local flat = Vector3.new(delta.X, 0, delta.Z)
    local flatDist = flat.Magnitude
    local curveDir
    if flatDist > 0.1 then
        curveDir = delta.Unit:Cross(Vector3.yAxis).Unit
    else
        curveDir = Vector3.xAxis * side
    end
    local control = (targetPos + ballPos) * 0.5
        + curveDir * curvePower
        + Vector3.new(0, math.abs(curvePower), 0)
    return ballPos, control, targetPos, {
        outside = not isInsidePitchBoxAt(ballPos),
        flatDist = flatDist,
        curve = curvePower,
        curveSide = side,
        pathTime = mods.autoGoalPathTime,
    }
end
local function resolveBiggieAutoGoalSpeed(p0, p1, p2, pathTime, fallbackSpeed)
    local steps = math.max(math.ceil(pathTime / 0.01), 1)
    local stepTime = pathTime / steps
    local pos0 = quadraticBezier(0, p0, p1, p2)
    local pos1 = quadraticBezier(1 / steps, p0, p1, p2)
    local segmentSpeed = (pos1 - pos0).Magnitude / math.max(stepTime, 0.001)
    return math.clamp(
        math.max(segmentSpeed, fallbackSpeed * 0.9),
        config.shotSpeedThreshold,
        700
    )
end
