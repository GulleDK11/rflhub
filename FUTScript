            pingState.hooked = false
            pingState.oldNamecall = nil
        end
        pingState.current = nil
        pingState.target = nil
        pingState.lastRetarget = 0

        if gameRoot.revertManipulator then
            pcall(gameRoot.revertManipulator)
        end

        if shotTamperState.connection then
            shotTamperState.connection:Disconnect()
            shotTamperState.connection = nil
        end

        local conns = table.clone(connections)
        table.clear(connections)
        for _, conn in conns do
            conn:Disconnect()
        end

        if GUI then
            GUI:Destroy()
        end
    end)

    getgenv().futmod = nil
    print("FUT MOD killed")
end

