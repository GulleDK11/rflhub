local function getClosestNet(fromPos)
    if next(netBounds) == nil then
        refreshNetParts()
    end

    local pitch = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Pitch")
    local netsFolder = pitch and pitch:FindFirstChild("Nets")
    if not netsFolder then
        return nil
    end

    local best, bestDist = nil, math.huge

    for _, name in { "EfNeth", "EfNeta" } do
        local net = netsFolder:FindFirstChild(name)
        if net then
            ensureNetBounds(net)
            local bounds = netBounds[net]
            if bounds then
                local dist = (bounds.center - fromPos).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best = net
                end
            end
        end
    end

    return best
end

local function resolveAutoGoalNet(fromPos, velocity)
    if mods.autoGoalTarget == "Closest" then
        local closest = getClosestNet(fromPos)
        if closest then
            return closest
        end
    end

    local preferred = getNetModelByTeam(resolveAutoGoalTeam())
    if preferred then
        return preferred
    end

    return getGoalNet(fromPos, velocity or Vector3.new(0, 0, -1))
end

