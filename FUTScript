    local composure = findFreekickComposure()
    if not composure then
        setpieceState.wasFreekickGreen = false
        return
    end

    local isGreen = isFreekickComposureGreen(composure)
    if isGreen and not setpieceState.wasFreekickGreen then
        tapKey(Enum.KeyCode.Space, 0.1)
    end
    setpieceState.wasFreekickGreen = isGreen
end

local function tryAutoPenalty()
    if not mods.autoPenEnabled or setpieceState.penDebounce then
        return
    end

    local composure = findPenaltyComposure()
    if not isPenaltyComposureReady(composure) then
        return
    end

    setpieceState.penDebounce = true
    tapKey(Enum.KeyCode.Space, 0.1)
    task.delay(0.25, function()
        setpieceState.penDebounce = false
    end)
end

local function bindSetpieceWatcher()
    local button = getSetpieceButton()
    if not button or setpieceState.button == button then
        return
    end

    if setpieceState.connection then
        setpieceState.connection:Disconnect()
        setpieceState.connection = nil
    end

    setpieceState.button = button
    setpieceState.connection = button:GetPropertyChangedSignal("Visible"):Connect(function()
        if button.Visible then
            tryAutoSetpieceReady()
        end
    end)
    trackConnection(setpieceState.connection)
end

trackConnection(player.ChildAdded:Connect(function(child)
    if not isScriptAlive() then return end
    if child.Name == "PlayerGui" then
        task.defer(bindSetpieceWatcher)
    end
end))

trackConnection(RunService.RenderStepped:Connect(function()
    if not isScriptAlive() then return end

    if mods.autoSetpieceEnabled then
        bindSetpieceWatcher()
        tryAutoSetpieceReady()
    end

    if mods.autoFreekickEnabled then
        tryAutoFreekick()
    end

    if mods.autoPenEnabled then
        tryAutoPenalty()
    end
end))

task.defer(bindSetpieceWatcher)
end

