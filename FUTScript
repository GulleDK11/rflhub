local settingsUi = macSection(SettingsTab, "Right")
settingsUi:Header({ Text = "Interface" })
macDropdown(settingsUi, {
    name = "Drag Mode",
    items = { "Full Window", "Move Icon" },
    default = uiState.dragStyle == 1 and "Move Icon" or "Full Window",
    callback = function(v)
        uiState.dragStyle = v == "Move Icon" and 1 or 2
        if uiState.showNotifications then
            GUI:Notify({
                Title = "Overseer FUT",
                Description = "Drag mode updates on next script load",
                Lifetime = 3,
            })
        end
    end,
})
settingsUi:SubLabel({ Text = "Full Window = drag anywhere on the menu." })
settingsUi:Keybind({
    Name = "Toggle Menu",
    Default = Enum.KeyCode.RightShift,
    Callback = function()
    end,
    onBinded = function(bind)
        pcall(function()
            GUI:SetKeybind(bind)
        end)
        if uiState.showNotifications then
            GUI:Notify({
                Title = "Overseer FUT",
                Description = "Menu keybind set to " .. bind.Name,
                Lifetime = 3,
            })
        end
    end,
}, "MenuKeybind")
settingsUi:Divider()
settingsUi:Header({ Text = "Feature Keybinds" })
settingsUi:Keybind({
    Name = "Toggle Reach",
