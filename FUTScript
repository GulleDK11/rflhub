local function applyInsanePower(constraint)
    if not mods.insanePowerEnabled then return end
    if powerState.processed[constraint] then return end
    if not (constraint:IsA("BodyVelocity") or constraint:IsA("LinearVelocity")) then return end
    if isGKConstraint(constraint) then return end
    if constraint.Name == "ShootVelocity" then return end

    local parent = constraint.Parent
    if not parent or not parent:IsA("BasePart") or parent.Name ~= "Ball" then return end
    if not isNetworkOwnerPart(parent) then return end

    markProcessed(constraint)

    task.spawn(function()
        if constraint:IsA("BodyVelocity") then
            local timeout = os.clock() + 3
            while constraint.Parent and constraint.Velocity == CONST.FREEKICK_GATE and os.clock() < timeout do
                task.wait()
            end
            if not constraint.Parent or not mods.insanePowerEnabled then return end

            local vel = constraint.Velocity
            if vel.Magnitude < 1 then return end

            applyInsanePowerToShot(parent, constraint, vel)
        elseif constraint:IsA("LinearVelocity") then
            local vel = constraint.VectorVelocity
            if vel.Magnitude >= config.shotSpeedThreshold then
                applyInsanePowerToShot(parent, constraint, vel)
            end
        end
    end)
end

