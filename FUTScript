local function absorbPartBounds(minV, maxV, cf, half)
    for _, sign in CONST.CORNER_SIGNS do
        local world = cf:PointToWorldSpace(Vector3.new(half.X * sign.X, half.Y * sign.Y, half.Z * sign.Z))
        minV = Vector3.new(math.min(minV.X, world.X), math.min(minV.Y, world.Y), math.min(minV.Z, world.Z))
        maxV = Vector3.new(math.max(maxV.X, world.X), math.max(maxV.Y, world.Y), math.max(maxV.Z, world.Z))
    end
    return minV, maxV
end
