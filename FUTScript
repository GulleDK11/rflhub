local function addReachBall(ball)
    if ball:IsA("BasePart") and ball.Name == "Ball" and not table.find(reachState.balls, ball) then
        table.insert(reachState.balls, ball)
        setupBallPrediction(ball)
    end
end

local function removeReachBall(ball)
    local idx = table.find(reachState.balls, ball)
    if idx then
        table.remove(reachState.balls, idx)
    end
end

local function scanWorldBalls(root)
    if not root then return end
    for _, desc in root:GetDescendants() do
        if desc:IsA("BasePart") and desc.Name == "Ball" then
            addReachBall(desc)
        end
    end
end

