local function shouldKeepPredictionVisible()
    for _, ball in reachState.balls do
        if not (ball and ball.Parent) then
            continue
        end

        if isForcePredictBall(ball) or isActiveShotBall(ball) then
            return true
        end

        local vel = getBallMotionVelocity(ball)
        if vel.Magnitude >= config.dribbleSpeedThreshold and vel ~= CONST.FREEKICK_GATE then
            return true
        end
    end

    return false
end

runPredictionVisualize = function()
    if not config.predictorEnabled then
        return
    end

    local ok, err = pcall(function()
        local pred = getPredState()
        local now = tick()
        if now - pred.lastUpdate < predPhysics.UpdateRate then
            return
        end
        pred.lastUpdate = now

        for _, ball in reachState.balls do
            if ball and ball.Parent then
                updateVelocityHistory(ball, now)
            end
        end

        local draws = {}

        for _, ball in reachState.balls do
            if not (ball and ball.Parent and ball:IsA("BasePart")) then
                continue
            end

            local vel = getBallMotionVelocity(ball)
            if not isValidTrajectoryBall(ball, vel) then
                continue
            end

            local points = predictBallPath(ball)
            if #points < 2 then
                continue
            end

            local maxSpeed = 0
            for _, p in points do
                if p.speed > maxSpeed then
                    maxSpeed = p.speed
                end
            end

            table.insert(draws, { points = points, maxSpeed = maxSpeed })
        end

        if #draws == 0 then
            if shouldKeepPredictionVisible() then
                return
            end
            clearTrajectoryChildren()
            return
        end

        local folder = ensureTrajectoryFolder()
        clearTrajectoryChildren()

        for _, draw in draws do
            local points = draw.points
            local maxSpeed = draw.maxSpeed

            for i = 1, #points - 1 do
                local p0, p1 = points[i], points[i + 1]
                if (p1.pos - p0.pos).Magnitude >= 0.05 then
                    createPredBeam(p0, p1, maxSpeed)
                end
            end

            local endPoint = points[#points]
            createLandingMarker(endPoint.pos, endPoint.hitNet == true)
        end
    end)

    if not ok then
        warn("[FUT] prediction error:", err)
    end
end

setPredictionEnabled = function(enabled)
    if visuals.predConnection then
        visuals.predConnection:Disconnect()
        visuals.predConnection = nil
    end
    clearTrajectory()
    if enabled and isScriptAlive() then
        visuals.predConnection = trackConnection(RunService.RenderStepped:Connect(runPredictionVisualize))
    end
end
