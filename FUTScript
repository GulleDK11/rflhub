local function applyShotPowerScale(velocity, powerMult, heightMult)
    local horizontal = Vector3.new(velocity.X, 0, velocity.Z)
    return Vector3.new(
        horizontal.X * powerMult,
        velocity.Y * heightMult,
        horizontal.Z * powerMult
    )
end

local function applyKnuckleShotScale(velocity, powerMult, loftStuds)
    local horizontal = Vector3.new(velocity.X, 0, velocity.Z)
    local horizMag = horizontal.Magnitude
    local dir

    if horizMag > 0.01 then
        dir = horizontal.Unit
    elseif velocity.Magnitude > 0.01 then
        dir = Vector3.new(velocity.X, 0, velocity.Z).Unit
        horizMag = Vector3.new(velocity.X, 0, velocity.Z).Magnitude
    else
        dir = Vector3.new(0, 0, -1)
        horizMag = 1
    end

    local speed = horizMag * powerMult
    local loftY = math.max(0, loftStuds) * 3.25

    return Vector3.new(dir.X * speed, loftY, dir.Z * speed)
end

