local function applyShotPowerScale(velocity, powerMult, heightMult)
    if velocity.Magnitude < 0.01 then
        return velocity
    end

    powerMult = math.max(tonumber(powerMult) or 1, 0.01)
    heightMult = math.max(tonumber(heightMult) or 1, 0.01)

    return Vector3.new(
        velocity.X * powerMult,
        velocity.Y * heightMult,
        velocity.Z * powerMult
    )
end

