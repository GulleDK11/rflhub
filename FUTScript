local function isCatchableBall(ball)
    if not ball or not ball:IsA("BasePart") or ball.Name ~= "Ball" then
        return false
    end
    if ball:FindFirstChild("catched") then return false end
    if ball:FindFirstChild("SAVE") then return false end
    if ball:FindFirstChild("Motor6D") then return false end
    if ball:FindFirstChild("OriginalSize") then return false end
    if ball.Material == Enum.Material.Sand then return false end
    if ball.Parent and ball.Parent:FindFirstChild("UpperTorso") then
        return false
    end
    return true
end

local function canReactToBall(ball, force)
    if not ball or not isCatchableBall(ball) then
        return false
    end
    if force then
        return true
    end
    if ball:FindFirstChild("ReactDecline") then
        return false
    end
    if ball:FindFirstChild("TouchCooldown") and not ballOwnedByPlayer(ball) then
        return false
    end
    return true
end

local function getValidBalls()
    local valid = {}
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

    for _, ball in reachState.balls do
        if ball and ball.Parent and ball:IsDescendantOf(workspace) and isCatchableBall(ball) then
            table.insert(valid, ball)
        end
    end

    if root and #valid > 1 then
        table.sort(valid, function(a, b)
            return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
        end)
    end

    return valid
end

local function getReachTarget(bounds, compMode)
    if compMode then
        for _, ball in bounds do
            if not hasNetworkOwnership(ball) then
                return ball
            end
        end
        return nil
    end
    return bounds[1]
end

