            destroyReachVisual("visualFolder", "box")
        end
        if uiState.showNotifications then
            GUI:Notify({
                Title = "Reach",
                Description = mods.reachEnabled and "Enabled" or "Disabled",
                Lifetime = 2,
            })
        end
