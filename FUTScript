local function collectGKGloveParts(character)
    local seen = {}
    local parts = {}

    local function addPart(part)
        if part and part:IsA("BasePart") and not seen[part] and part.Name ~= "Ball" then
            seen[part] = true
            table.insert(parts, part)
        end
    end

    if not character then
        return parts
    end

    for _, handName in GK_LIMBS do
        local hand = character:FindFirstChild(handName)
        if hand and hand:IsA("BasePart") then
            addPart(hand)
            for _, desc in hand:GetDescendants() do
                if desc:IsA("BasePart") and not desc.Name:find("^FUT_GKReach_") then
                    addPart(desc)
                end
            end
        end
    end

    for _, desc in character:GetDescendants() do
        if isGKGlovePart(desc) and not desc.Name:find("^FUT_GKReach_") then
            addPart(desc)
        end
    end

    return parts
end

