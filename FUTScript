    if staminaState.sprintData then
        return staminaState.sprintData
    end

    if _G.SprintController then
        staminaState.sprintApi = _G.SprintController
    end

    if type(filtergc) ~= "function" then
        return nil
    end

    local results = filtergc("table", { Keys = { "Stamina", "IsSprinting", "CanSprint", "LastTime" } })
    if results and results[1] then
        staminaState.sprintData = results[1]
    end

    return staminaState.sprintData
end

