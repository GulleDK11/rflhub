local function hasConfigFileIO()
    return typeof(writefile) == "function"
        and typeof(readfile) == "function"
        and typeof(isfile) == "function"
        and typeof(isfolder) == "function"
        and typeof(makefolder) == "function"
end
local function ensureConfigDir()
    if not hasConfigFileIO() then
        return false
    end
    local ok = pcall(function()
        if not isfolder(configState.root) then
            makefolder(configState.root)
        end
        if not isfolder(configState.dir) then
            makefolder(configState.dir)
        end
    end)
    return ok and isfolder(configState.dir)
end
local function sanitizeConfigName(name)
    local cleaned = tostring(name or "default"):gsub("[^%w%-_]", "")
    if cleaned == "" then
        return "default"
    end
    return cleaned
end
local function serializeConfigValue(value)
    local valueType = typeof(value)
    if valueType == "Color3" then
        return { _t = "Color3", R = value.R, G = value.G, B = value.B }
    end
    if valueType == "table" then
        local out = {}
        for key, child in value do
            local serialized = serializeConfigValue(child)
            if serialized ~= nil then
                out[key] = serialized
            end
        end
        return out
    end
    if valueType == "boolean" or valueType == "number" or valueType == "string" then
        return value
    end
    return nil
end
local function deserializeConfigValue(value)
    if type(value) ~= "table" then
        return value
    end
    if value._t == "Color3" then
        return Color3.new(value.R, value.G, value.B)
    end
    return value
end
local function mergeConfigTable(source, dest)
    if type(source) ~= "table" or type(dest) ~= "table" then
        return
    end
    for key, value in source do
        if type(value) == "table" and value._t ~= "Color3" then
            if type(dest[key]) ~= "table" then
                dest[key] = {}
            end
            mergeConfigTable(value, dest[key])
        else
            dest[key] = deserializeConfigValue(value)
        end
    end
end
local function applyOverseerConfig(data)
    if type(data) ~= "table" then
        return false
    end
    if type(data.mods) == "table" then
        mergeConfigTable(data.mods, mods)
    end
    if type(data.config) == "table" then
        mergeConfigTable(data.config, config)
    end
    if type(data.uiState) == "table" then
        mergeConfigTable(data.uiState, uiState)
    end
    setPredictionEnabled(config.predictorEnabled)
    setInfiniteStamina(mods.infiniteStamina)
    setAntiIdle(mods.antiIdle)
    resetPingSpoofState()
    if mods.pingSpoof then
        setupPingSpoof()
    end
    return true
end
local function saveOverseerConfig(name)
    local configName = sanitizeConfigName(name or configState.pendingName)
    if not ensureConfigDir() then
        warn("Overseer FUT: config save unavailable (no writefile)")
        return false
    end
    local payload = {
        mods = serializeConfigValue(mods),
        config = serializeConfigValue(config),
        uiState = serializeConfigValue(uiState),
    }
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(payload)
    end)
    if not ok or not encoded then
        return false
    end
    writefile(configState.dir .. "/" .. configName .. ".json", encoded)
    return true
end
local function loadOverseerConfig(name)
    local configName = sanitizeConfigName(name or configState.pendingName)
    local path = configState.dir .. "/" .. configName .. ".json"
    if not hasConfigFileIO() or not isfile(path) then
        return false
    end
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok or type(decoded) ~= "table" then
        return false
    end
    return applyOverseerConfig(decoded)
end
local function setAutoloadConfig(name)
    local configName = sanitizeConfigName(name)
    if not hasConfigFileIO() then
        return false
    end
    ensureConfigDir()
    writefile(configState.autoloadFile, configName)
    return true
end
local function tryLoadAutoloadConfig()
    if not hasConfigFileIO() or not isfile(configState.autoloadFile) then
        return false
    end
    local ok, name = pcall(function()
        return readfile(configState.autoloadFile)
    end)
    if not ok or not name or name == "" then
        return false
    end
    return loadOverseerConfig(name)
end
