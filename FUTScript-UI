local function macDropdown(section, opts)
    local items = opts.items or opts.Options
    local defaultValue = opts.default or opts.Default
    local defaultIndex = 1
    for index, item in items do
        if item == defaultValue then
            defaultIndex = index
            break
        end
    end
    section:Dropdown({
        Name = opts.name or opts.Name,
        Options = items,
        Default = defaultIndex,
        Callback = opts.callback or opts.Callback,
    }, opts.flag)
end
