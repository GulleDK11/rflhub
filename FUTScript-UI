local function renderUiSchema(group, tabName, sections)
    local tab = group:Tab({ Name = tabName })
    for _, sectionDef in sections do
        buildSection(tab, sectionDef.side, sectionDef.header, sectionDef.widgets)
    end
    return tab
end
local function renderUiSections(tab, sections)
    for _, sectionDef in sections do
        buildSection(tab, sectionDef.side, sectionDef.header, sectionDef.widgets)
    end
end
local function buildSettingsConfigSection(settingsTab)
    if configState.macLibConfig and type(settingsTab.InsertConfigSection) == "function" then
        settingsTab:InsertConfigSection("Left")
        return
    end
    local settingsConfig = macSection(settingsTab, "Left")
    settingsConfig:Header({ Text = "Configs" })
    settingsConfig:Paragraph({
        Header = "Overseer Configs",
        Body = "MacLib config API not found in this build. Using Overseer file configs instead.",
    })
    settingsConfig:Input({
        Name = "Config Name",
        Placeholder = "default",
        AcceptedCharacters = function(text)
            return text:gsub("[^%w%-_]", "")
        end,
        Callback = function(text)
            configState.pendingName = sanitizeConfigName(text)
        end,
        onChanged = function(text)
            configState.pendingName = sanitizeConfigName(text)
        end,
    })
    settingsConfig:Button({
        Name = "Save Config",
        Callback = function()
            if saveOverseerConfig(configState.pendingName) then
                notifyConfig("Saved config: " .. sanitizeConfigName(configState.pendingName))
            else
                notifyConfig("Failed to save config")
            end
        end,
    })
    settingsConfig:Button({
        Name = "Load Config",
        Callback = function()
            if loadOverseerConfig(configState.pendingName) then
                notifyConfig("Loaded config: " .. sanitizeConfigName(configState.pendingName))
            else
                notifyConfig("Failed to load config")
            end
        end,
    })
    settingsConfig:Button({
        Name = "Set Autoload",
        Callback = function()
            if setAutoloadConfig(configState.pendingName) then
                notifyConfig("Autoload set: " .. sanitizeConfigName(configState.pendingName))
            else
                notifyConfig("Failed to set autoload")
            end
        end,
    })
end
local function buildFutUI()
local MacLib = loadMacLib()
if not MacLib then
    warn("Overseer FUT v5.6: UI failed to load. Gameplay mods are still active.")
    getgenv().OverseerFUT = {
        Network = networkState,
        GameRoot = gameRoot,
        RetryForge = tryInitNetworkForger,
        RetryRoot = function()
            if findGameRoot() then
                patchGameReact()
                if not gameRoot.manipulatorInstalled then
                    installReactManipulator()
                end
                return true
            end
            return false
        end,
        Kill = killScript,
    }
    print("Overseer FUT v5.6 | UI offline | Balls:", #reachState.balls)
    return
end
configState.macLibConfig = type(MacLib.SetFolder) == "function"
if configState.macLibConfig then
    pcall(function()
        MacLib:SetFolder(configState.root)
    end)
else
    warn("Overseer FUT: MacLib config API missing, using file-based configs")
end
GUI = MacLib:Window({
    Title = "Overseer FUT",
    Subtitle = "v5.6 | Overseer FUT",
    Size = UDim2.fromOffset(868, 650),
    DragStyle = uiState.dragStyle or 2,
    DisabledWindowControls = {},
    ShowUserInfo = false,
    Keybind = Enum.KeyCode.RightShift,
    AcrylicBlur = uiState.acrylicBlur,
})
GUI.onUnloaded(function()
    killScript(true)
end)
for _, gs in {
    { name = "Acrylic Blur", key = "acrylicBlur", setter = "SetAcrylicBlurState" },
    { name = "Notifications", key = "showNotifications", setter = "SetNotificationsState" },
    { name = "Show User Info", key = "showUserInfo", setter = "SetUserInfoState" },
} do
    GUI:GlobalSetting({
        Name = gs.name,
        Default = uiState[gs.key],
        Callback = function(state)
            uiState[gs.key] = state
            pcall(function()
                if GUI and GUI[gs.setter] then
                    GUI[gs.setter](GUI, state)
                end
            end)
        end,
    })
end
local VisualGroup = GUI:TabGroup()
renderUiSchema(VisualGroup, "Visual", UI_SCHEMA.visual)
local GameplayGroup = GUI:TabGroup()
renderUiSchema(GameplayGroup, "Reach", UI_SCHEMA.reach)
