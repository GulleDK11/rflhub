renderUiSections(SettingsTab, UI_SCHEMA.settings)
getgenv().OverseerFUT = {
    Network = networkState,
    GameRoot = gameRoot,
    RetryForge = tryInitNetworkForger,
    RetryRoot = function()
        if findGameRoot() then
            patchGameReact()
            if not gameRoot.manipulatorInstalled then
                installReactManipulator()
            end
            return true
        end
        return false
    end,
    Kill = killScript,
    ConfirmKill = confirmKillScript,
    SaveConfig = function(name)
        if configState.macLibConfig and type(MacLib.SaveConfig) == "function" then
            return MacLib:SaveConfig(name)
        end
        return saveOverseerConfig(name)
    end,
    LoadConfig = function(name)
        if configState.macLibConfig and type(MacLib.LoadConfig) == "function" then
            return MacLib:LoadConfig(name)
        end
        return loadOverseerConfig(name)
    end,
}
GUI:Notify({
    Title = "Overseer FUT",
    Description = "v5.6 loaded — configs ready",
    Lifetime = 4,
})
if configState.macLibConfig and type(MacLib.LoadAutoLoadConfig) == "function" then
